//--------------------------------------------------------------------
Name = "狂気のハープ";
with(o[Name])
{
	.toEnemy = true;
	.scene = "battle";
	.range = 2;
	.reach = 3;
	.magicLV = -1;	// 反射・無効化の対象になる
	.anime = "*music_insanity";

	.doDamage = function(self, target)
	{
		if(random > 0.6) return 0;
		if(target.setStatus(o.混乱)) return o.混乱.doDamage(self, target);
		if(target.setStatus(o.恐怖)) return o.恐怖.doDamage(self, target);
		if(target.setStatus(o.魅了)) return o.魅了.doDamage(self, target);
		if(target.setStatus(o.酩酊)) return o.酩酊.doDamage(self, target);
		if(target.setStatus(o.気絶)) return o.気絶.doDamage(self, target);
		return 0;
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work!";
		return "Disaster struck " + target.displayName + "!";
	};
}
//--------------------------------------------------------------------
Name = "いやしの竪琴";
with(o[Name])
{
	.toGuest = true;
	.scene = "battle";
	.range = 3;
	.magicLV = -1;	// 反射・無効化の対象になる
	.anime = "*music_healing";

	.doDamage = function(self, target)
	{
		if(target.dead || target.status.has(o.石化)) return 0;
		target.removeStatus(o.眠り);	// 目覚まし効果
		target.removeStatus(o.恐怖);	// 鎮静効果
		var heal = intrandom(48, 64);
		if(self.equipStat.main <= BROKEN) heal \= 2;
		target.life += heal;
		return "0,0x80F080," + heal;
	};
}
//--------------------------------------------------------------------
Name = "天使の竪琴";
with(o[Name])
{
	.toGuest = true;
	.scene = "battle";
	.range = 3;
	.magicLV = -1;	// 反射・無効化の対象になる
	.anime = "*music_angel";

	.doDamage = function(self, target)
