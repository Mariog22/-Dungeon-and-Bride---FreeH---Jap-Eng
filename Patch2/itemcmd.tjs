Name = "リターンの巻物";
with(o[Name])
{
	.scene = "explore";
	.checkCurrentAction = function(owner)
	{
		if(master.map.kind == "town" || master.map.isAntiWarpZone())
		{
			playSound("buzzer");
			return "Used " + displayName + ". But warping is forbidden here!";
		}
		return global.BattleCommand.checkCurrentAction(owner);
	};
}
//--------------------------------------------------------------------
Name = "ワープの巻物";
with(o[Name])
{
	.scene = "explore";

	.checkCurrentAction = function(owner)
	{
		if(! master.warpSpellEnabled)
		{
			return owner.displayName + " used " + displayName + "!\nHowever the warp network is down!";
		}
		if(master.map.kind == "town" || master.map.isAntiWarpZone())
		{
			playSound("buzzer");
			return "Used " + displayName + ". But warping is forbidden here!";
		}
		return global.BattleCommand.checkCurrentAction(owner);
	};
}
