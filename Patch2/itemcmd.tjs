//--------------------------------------------------------------------
Name = "時のスイッチ";
with(o[Name])
{
	.anime = "*press_button";

	.doDamage = function(self, target)
	{
		if(master.inBattle) return 0;
		try
		{
			kag.process(master.map.mapFile, "*reset_floor");
		}
		catch(e)
		{
			master.noReturnMenu = true;
			kag.process("anime.ks", "*failed_to_reset");
			return 0;
		}
		master.battleInfo.close();
	};
}
//--------------------------------------------------------------------
Name = "取消しスイッチ";
with(o[Name])
{
	.anime = "*press_button";

	.doDamage = function(self, target)
	{
		if(master.inBattle) return 0;
		master.noReturnMenu = true;
		if(! master.party.lastIsPush) return 0;
		var nextPos = master.map.getNextFloorInfo();
		if(nextPos.type != "movable") return 0;	// 落下等で目の前に岩がなかったら戻れない
		var p = master.map.getPosRelatively();
		master.party.changeObjectPos(master.map, p.x, p.y, master.party.curX, master.party.curY);
		master.walk("goBackward");
		master.updateView();
		master.battleInfo.open();
		playSound("dragstone");
		return true;
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "Nothing happened!";
		return "It returned to the previous state!";
	};
}
//--------------------------------------------------------------------
Name = "はちみつパン";
with(o[Name])
{
	.determined = o.ヒール.determined;
	.pickUpTarget = o.ヒール.pickUpTarget;
}
//--------------------------------------------------------------------
Name = "カマンベール";
with(o[Name])
{
	.determined = o.ヒール.determined;
	.pickUpTarget = o.ヒール.pickUpTarget;
}
//--------------------------------------------------------------------
Name = "気付けの花";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(master.checkMapEvent()) return;	// マップイベントで使用された場合通常使用はしない
		if(target.dead || target.status.has(o.石化)) return 0;
		if(! target.status.has(o.眠り) && ! target.status.has(o.恐怖) && ! target.status.has(o.混乱))
		{
			if(target.heat == 0) return 0;
			target.heat -= 5;
			return "0,0x80F0F0,5";
		}
		target.heat -= 5;
		target.removeStatus(o.眠り);
		target.removeStatus(o.恐怖);
		target.removeStatus(o.混乱);
		return "0,0x80F080,SANITY";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		if(value.length == 12) return target.displayName + "'s excitement reduced by 5!"
;
		return "It cured " + target.displayName + "!";
	};
}
//--------------------------------------------------------------------
Name = "毒消しの花";
