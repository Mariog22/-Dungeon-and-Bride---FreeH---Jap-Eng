//--------------------------------------------------------------------
Name = "火花のマラカス";
with(o[Name])
{
	.toEnemy = true;
	.scene = "battle";
	.range = 2;
	.reach = 3;
	.attrib = "火";
	.magicLV = -1;	// 反射・無効化の対象になる
	.anime = "*music_fire_cracker";

	.doDamage = function(self, target)
	{
		var dmg = intrandom(16, 24) \ (self.equipStat.main > BROKEN ? 1 : 2);
		if(self.equip.sub == this)
		{
			// 両手に同じ物を持っていたら威力増加
			dmg += intrandom(16, 24) \ (self.equipStat.sub > BROKEN ? 1 : 2);
		}
		dmg = target.getAffectedDamage(dmg, "火");
		target.life -= dmg;
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "氷結の鈴";
with(o[Name])
{
	.toEnemy = true;
	.scene = "battle";
	.range = 2;
	.reach = 3;
	.attrib = "冷";
	.magicLV = -1;	// 反射・無効化の対象になる
	.anime = "*music_diamonddust";

	.doDamage = function(self, target)
	{
		var dmg = intrandom(12, 18) \ (self.equipStat.main > BROKEN ? 1 : 2);
		if(self.equip.sub == this)
		{
			// 両手に同じ物を持っていたら威力増加
			dmg += intrandom(12, 18) \ (self.equipStat.sub > BROKEN ? 1 : 2);
		}
		dmg = target.getAffectedDamage(dmg, "冷");
		target.life -= dmg;
		if(dmg > 0 && target.setStatus(o.凍結)) master.extraEffect = o.凍結;
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "聖なるハンドベル";
with(o[Name])
{
	.toEnemy = true;
	.scene = "battle";
	.range = 2;
	.reach = 3;
	.attrib = "聖";
	.magicLV = -1;	// 反射・無効化の対象になる
	.anime = "*music_holy_chimes";

	.doDamage = function(self, target)
	{
		if(target.race.name != "アンデッド" && target.race.name != "幽霊") return 0;
		var dmg = intrandom(24, 32) \ (self.equipStat.main > BROKEN ? 1 : 2);
		if(self.equip.sub == this)
		{
			// 両手に同じ物を持っていたら威力増加
			dmg += intrandom(24, 32) \ (self.equipStat.sub > BROKEN ? 1 : 2);
		}
		if(random < dmg / 100)
		{
			target.life = 0;
			return "0,0x80F0F0,DISPEL";
		}
		dmg = target.getAffectedDamage(dmg, "聖");
		target.life -= dmg;
		return dmg;
	};
}
//--------------------------------------------------------------------
