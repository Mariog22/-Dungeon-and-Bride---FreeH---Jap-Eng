}
//--------------------------------------------------------------------
Name = "背徳の鎧・下";
with(o[Name])
{
	.curseScript = function(owner)
	{
		var rec = owner.getSexRecord(o["アイテム"], 1, 0, "膣挿入");
		owner.addSexRecordAndChangeHeart(rec);
		owner.events.push2(59);
	};
}
//--------------------------------------------------------------------
Name = "ＳＰ転職";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		var params = master.curItem.cmdParam.split(",");
		var jobObj = o[params[master.curItem.special.find(this)]];
		if(self.job == jobObj) return 0;
		self.setJob(jobObj);
		playSound("period");
		return "0,0x80FF80,CHANGE";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work!";
		var params = master.curItem.cmdParam.split(",");
		var jobObj = o[params[master.curItem.special.find(this)]];
		return target.displayName + " changed jobs to " + jobObj.displayName + "!";
	};
}
//--------------------------------------------------------------------
Name = "ＳＰパラメータ変化";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		var params = master.curItem.cmdParam.split(",");
		var arr = params[master.curItem.special.find(this)].split(":");
		var v = +arr[2];
		self.addParam(arr[1], v);
		return (v > 0 ? "0,0x80FF80,+" : "0,0xFFC0C0,") + v;
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work!";
		var params = master.curItem.cmdParam.split(",");
		var arr = params[master.curItem.special.find(this)].split(":");
		var v = +arr[2];
		return target.displayName + "'s " + arr[0] + (v > 0 ? " increased by " : " decreased by ") + abs(v) + "!";
	};
}
//--------------------------------------------------------------------
Name = "ＳＰパラメータ変化２";
with(o[Name])
{
	.doDamage = o.ＳＰパラメータ変化.doDamage;
	.resultMessage = o.ＳＰパラメータ変化.resultMessage;
}
//--------------------------------------------------------------------
Name = "ＳＰパラメータ変化３";
with(o[Name])
{
	.doDamage = o.ＳＰパラメータ変化.doDamage;
	.resultMessage = o.ＳＰパラメータ変化.resultMessage;
}
//--------------------------------------------------------------------
Name = "ＳＰ属性変化";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		var params = master.curItem.cmdParam.split(",");
		var alignmentObj = o[params[master.curItem.special.find(this)]];
		if(self.alignment == alignmentObj) return 0;
		self.alignment = alignmentObj;
		self.updateBadge();
		self.mindBalance = 0;
		playSound("period");
		return "0,0xFF80FF,CHANGE";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work!";
		var params = master.curItem.cmdParam.split(",");
		var alignmentObj = o[params[master.curItem.special.find(this)]];
		return target.displayName + "'s alignment changed to " + alignmentObj.displayName + "!";
	};
}
//--------------------------------------------------------------------
Name = "ＳＰＨＰ回復";
with(o[Name])
{
	.doDamage = o.リカバリー.doDamage;
	.resultMessage = o.リカバリー.resultMessage;
}
//--------------------------------------------------------------------
Name = "ＳＰＭＰ回復";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		target.mmagic.assign(target.mmagicMax);
		target.pmagic.assign(target.pmagicMax);
		target.amagic.assign(target.amagicMax);
		target.smagic.assign(target.smagicMax);
		return "0,0x80F080,9";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		return target.displayName + "'s MP has been restored!";
	};
}
//--------------------------------------------------------------------
Name = "ＳＰＭＰ消滅";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		var arr = [0, 0, 0, 0, 0, 0, 0, 0, 0];
		target.mmagic.assign(arr);
		target.pmagic.assign(arr);
		target.amagic.assign(arr);
		target.smagic.assign(arr);
		return "0,0x80F080,-9";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		return target.displayName + "'s MP was reduced to 0!";
	};
}
//--------------------------------------------------------------------
Name = "ＳＰ魔法忘却";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		var flag = false;
		var arr = target.btcmd;
		for(var i = arr.count - 1; i >= 0; i--)
		{
			if(arr[i].magicLV <= 0) continue;
			arr.erase(i);
			flag = true;
		}
		if(flag) return "0,0xF08080,FORGET";
		else return 0;
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		return target.displayName + " forgot all magic!";
	};
}
//--------------------------------------------------------------------
Name = "ＳＰ石化";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(! target.setStatus(o.石化, true)) return 0;
		return o.石化.doDamage(self, target);
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work!";
		else return target.displayName + " is petrified!";
	};
}
//--------------------------------------------------------------------
Name = "ＳＰ死亡";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(! target.setStatus(o.死亡, true)) return 0;
		return o.死亡.doDamage(self, target);
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work!";
		else return target.displayName + " died!";
	};
}
//--------------------------------------------------------------------
Name = "ＳＰ灰";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(! target.setStatus(o.灰, true)) return 0;
		return o.灰.doDamage(self, target);
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work!";
		else return target.displayName + " has become ashes!";
	};
}
