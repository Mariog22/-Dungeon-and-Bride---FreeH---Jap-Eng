//--------------------------------------------------------------------
Name = "フェロモンの粉";
with(o[Name])
{
	.cond = function(owner)
	{
		if(master.inBattle)
		{
			range = 3;
			owner.target = master.enemy.members;
			master.curTarget = owner.getTarget();
			return true;
		}
		if(master.isFreeMode) return false;
		range = 1;
		return true;
	};

	.doDamage = function(self, target)
	{
		if(master.inBattle)
		{
			self.useResource(true);
			return o.チャーム.doDamage(...);
		}

		if(target.dead || target.status.has(o.石化)) return 0;
		if(target.sex == "男")
		{
			for(var i = 0; i < master.party.members.count; i++)
			{
				var one = master.party.members[i];
				if(one.sex == "男") continue;
				one.moveHeart(target, 20);
			}
		}
		else if(target.isUserChara)
		{
			target.guard.max = cap(target.guard.max - 1);
			target.guard.linus = cap(target.guard.linus - 1);
			target.guard.blue = cap(target.guard.blue - 1);
			target.guard.alex = cap(target.guard.alex - 1);
		}
		return "0,0xFFC0C0,SEXY";
	};

	.resultMessage = function(target, value)
	{
		if(master.inBattle) return o.チャーム.resultMessage(...);

		if(value === 0) return "It didn't work on " + target.displayName + "!";
		if(target.sex == "男") return target.displayName + " looks better to the party!";
		else return target.displayName + " had shields for all men reduced by 1!";
	};
}
//--------------------------------------------------------------------
Name = "男の秘薬";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(target.dead || target.status.has(o.石化)) return 0;
		if(target.sex != "男") return 0;
		target.penis += 1;
		return "0,0xF0C080,GROW";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		return target.displayName + "'s erect penis grew to " + target.penis + "!";
	};
}
