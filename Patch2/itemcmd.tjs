//--------------------------------------------------------------------
Name = "アンロックの巻物";
with(o[Name])
{
	// この魔法だけの特殊なメンバを巻物にも追加
	.unlockTarget = "";
	.checkUnlock = o.アンロック.checkUnlock;
}
//--------------------------------------------------------------------
Name = "たいまつ";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(master.view != master.dungeonView) return 0;
		return o.トーチ.doDamage(self, target);
	};

	.resultMessage = function(target, value)
	{
		if(master.map.getFloorInfo().eraseMagic) return "Magic was cancelled!";
		if(value === 0) return "It didn't work!";
		return o.トーチ.resultMessage(target, value);
	};
}
//--------------------------------------------------------------------
Name = "こじあけの鍵";
with(o[Name])
{
	// 使い捨てじゃない属性のアイテムを使い捨てにするには以下２行を追加する
	.isConsumed = function(){ return true; };	// 消費アイテムへ変更
	&.disposable = true;	// １回使いきりへ変更

	.checkCurrentAction = function(owner)
	{
		if(master.inBattle)
		{
			playSound("buzzer");
			return "戦闘中に扉を開けることはできません";
		}
		var str;
		if(master.map.kind != "dungeon")
		{
			str = "There is no door here";
		}
		else
		{
			var wall = master.map.getWallInfo();
			if(wall.type != "door") str = "There is no door here";
			else if(wall.key === void) str = "扉はすでに開いています";
			else if(wall.key != "pickable") str = "The door can't be opened with this key.";
		}
		if(str === void) return;
		playSound("buzzer");
		master.notice.open(master.enterTravelMode);
		master.notice.write("y" + str);
		return str;
	};

	.doDamage = function(self, target)
	{
		playSound("kacha");
		master.noReturnMenu = true;
		master.map.unlockDoor();
		master.notice.open(master.enterTravelMode);
		master.notice.write("I used <p>" + displayName + "<y> to open the door!");
		return "0,0x80FFFF,UNLOCK";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work!";
		return "The door was unlocked!";
	};
}
//--------------------------------------------------------------------
Name = "精霊の縫い糸";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(! target instanceof "GuestObject") return 0;
		if(target.equipLife == G_WHOLE) return 0;
		if(target.sex == "男" && target.equipLife >= G_FLYING) return 0;	// わざわざ修復しなくて良い
		target.equipLife = G_WHOLE;
		target.makeBustups();
		return "0,0xFFFFFF,REPAIR";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work!";
		return target.displayName + " had equipment repaired!";
	};
}
//--------------------------------------------------------------------
Name = "行動力増加袋";
with(o[Name])
{
	.cond = function(owner)
	{
		if(master.inBattle)
		{
			owner.target = master.party.allMembers;
			master.curTarget = owner.getTarget();
			return true;
		}
		if(! master.isFreeMode) return true;
		return false;
	};

	.doDamage = function(self, target)
	{
		if(master.inBattle) return o.アクセラレート.doDamage(...);
		master.maxInnActionCount ++;
		return "0,0xFFFFFF,1";
	};

	.resultMessage = function(target, value)
	{
		if(master.inBattle) return o.アクセラレート.resultMessage(...);
		return "Inn action points increaded by 1!";
	};
}
//--------------------------------------------------------------------
Name = "召喚の札";
with(o[Name])
{
	.anime = "*summoning_card";

	.checkCurrentAction = function(owner)
	{
		if(master.getBestSummoningMonster() == master.guest.getSummonedMonster())
		{
			return owner.displayName + " used a summoning card!\nBut summon was already present!";
		}
		owner.ejectItem(this, owner.reservedGrid);
	};
}
//--------------------------------------------------------------------
Name = "けむり玉";
with(o[Name])
{
	.scene = "battle";
	.anime = o.エスケープ.anime;
	.cond = o.エスケープ.cond;
	.doDamage = o.エスケープ.doDamage;
	.resultMessage = o.エスケープ.resultMessage;
}
//--------------------------------------------------------------------
Name = "ボム";
with(o[Name])
{
	.toEnemy = true;
	.scene = "battle";
	.range = 3;
	.reach = 3;
	.attrib = "爆発";

	.cond = function(owner)
	{
		if(master.inBattle)
		{
			owner.target = master.enemy.members;
			master.curTarget = owner.getTarget();
		}
		return true;	// これに限っては他で判定する
	};

	.checkCurrentAction = function(owner)
	{
		if(master.party.status.has(o.禁止))
		{
			return owner.displayName + "used " + displayName + "! But magical powers have been sealed!";
		}
		result = master.party.setBomb();
	};

	.doDamage = function(self, target)
	{
		if(! master.inBattle)
		{
			if(result.res == "forbidden" || result.res == "useless") return 0;
			return;
		}
		if(result.res != "success") return 0;
		var dmg = intrandom(24, 28);
		target.life -= dmg;
		return dmg;
	};

	.actionMessage = function(self, target)
	{
		if(result.res != "forbidden") return global.ItemObject.actionMessage(self, target);
	};

	.resultMessage = function(target, value)
	{
		if(master.inBattle && result.res == "success") return target.displayName + " took " + value + " damage!";
		if(result.res != "forbidden") return result.msg;
	};
}
//--------------------------------------------------------------------
Name = "ハイパーボム";
with(o[Name])
{
	.toEnemy = true;
	.scene = "battle";
	.range = 3;
	.reach = 3;
	.attrib = "爆発";

	.cond = o.ボム.cond;
	.actionMessage = o.ボム.actionMessage;
	.resultMessage = o.ボム.resultMessage;

	.checkCurrentAction = function(owner)
	{
		if(master.party.status.has(o.禁止))
		{
			return owner.displayName + "used " + displayName + "! But magical powers have been sealed!";
		}
		result = master.party.setBomb(true);
		if(result.res == "success") master.hyperBombsCount ++;
	};

	.doDamage = function(self, target)
	{
		if(! master.inBattle)
		{
			if(result.res == "forbidden" || result.res == "useless") return 0;
			return;
		}
		if(result.res != "success") return 0;
		var dmg = intrandom(300, 500);
		target.life -= dmg;
		return dmg;
	};
}
