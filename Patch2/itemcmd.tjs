//--------------------------------------------------------------------
Name = "戦いの銅鑼";
with(o[Name])
{
	.toGuest = true;
	.scene = "battle";
	.range = 3;
	.anime = "*music_gong";

	.doDamage = function(self, target)
	{
		if(random > 0.3) return 0;
		if(target.setStatus(o.祝福)) return o.祝福.doDamage(self, target);
		if(target.setStatus(o.硬化)) return o.硬化.doDamage(self, target);
		if(target.setStatus(o.抵抗)) return o.抵抗.doDamage(self, target);
		if(target.setStatus(o.疾風)) return o.疾風.doDamage(self, target);
		if(target.setStatus(o.付与)) return o.付与.doDamage(self, target);
		if(target.setStatus(o.倍加)) return o.倍加.doDamage(self, target);
		return 0;
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work!";
		return target.displayName + "'s abilities were enhanced!";
	};
}
//--------------------------------------------------------------------
