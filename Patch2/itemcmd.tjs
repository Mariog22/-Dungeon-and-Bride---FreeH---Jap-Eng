// アイテムコマンド詳細登録
var Name;


//--------------------------------------------------------------------
Name = "悪魔の彫像";
with(o[Name])
{
	.anime = "*nothing";

	.doDamage = function(self, target)
	{
		if(! master.checkMapEvent())
		{
			playSound("buzzer");
			return 0;
		}
		playSound("switch1");
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "But nothing happened!";
		return "I put " + displayName + " on the pedestal!";
	};
}
