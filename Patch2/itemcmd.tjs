Name = "ポーション";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(target.dead || target.status.has(o.石化)) return 0;
		target.removeStatus(o.恐怖);
		target.removeStatus(o.混乱);
		target.heat -= 5;
		target.life += life;
		return "0,0x80F080," + life;
	};
}
