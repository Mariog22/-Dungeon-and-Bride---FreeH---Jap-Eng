		wall_left__b4 = new WallLayer(this, "side_b4" ,  80, 420, 300, 0, 570, true);
		wall_right_B4 = new WallLayer(this, "side_b4" ,  80, 420, 640, 0, 570, true, true);
		wall_left__c4 = new WallLayer(this, "side_c4" , 110, 420, 170, 0, 560, true);
		wall_right_C4 = new WallLayer(this, "side_c4" , 110, 420, 740, 0, 560, true, true);

		wall_left__a5 = new WallLayer(parent, "side_a5" , 240, 400, 180, 0, 80);
		wall_right_a5 = new WallLayer(parent, "side_a5" , 240, 400, 480, 0, 80,, true);
		wall_left__b5 = new WallLayer(parent, "side_b5" , 250, 400,  80, 0, 80);
		wall_right_B5 = new WallLayer(parent, "side_b5" , 250, 400, 570, 0, 80,, true);
		wall_left__c5 = new WallLayer(parent, "side_c5" , 160, 400,  80, 0, 80);
		wall_right_C5 = new WallLayer(parent, "side_c5" , 160, 400, 660, 0, 80,, true);

		hang_left__a0 = new PartsLayer(wall_left__a0, "side_a0" , 360, 680, 0, 0, 1);
		hang_right_a0 = new PartsLayer(wall_right_a0, "side_a0" , 360, 680, 0, 0, 1,, true);
