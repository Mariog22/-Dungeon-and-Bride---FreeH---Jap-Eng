	function updateView(cx, cy, cf, dkz)
	{
		// パーツを操作して現在の座標からビューを構築する
		// cx : 描画したいＸ座標   cy : 描画したいＹ座標   cf : 描画したい方角

		var startTick = System.getTickCount();

		var pf, pl, pr;		// 正面、左の方角、右の方角の画像パーツの種類
		var map = parent.master.map;	// 現在のマップ
		var pos = map.pos;	// 位置情報が格納された変数
		var short = false;	// 高いファイルを低くするかどうか

		// スコープガードがあれば表示
		scopeGuard.visible = false;
		if(wall_front_a0.opacity != 255 && pos[cx][cy][cf].antiScope !== void)
		{
			scopeGuard.load("antiscope_" + pos[cx][cy][cf].antiScope);
		}

		// ダークゾーン
		darkZone.visible = (dkz !== void);
		if(darkZone.visible)
		{
			darkZone.loadImages("darkzone_" + dkz);
			return;
		}

		// 水面の直下
		if(map.isUnderSurface()) short = true;

		// 方角の決定
		if(cf == "n") pf = "n", pl = "w", pr = "e";
		else if(cf == "s") pf = "s", pl = "e", pr = "w";
		else if(cf == "e") pf = "e", pl = "n", pr = "s";
		else pf = "w", pl = "s", pr = "n";

		// 符号と距離を決定
		// vertical/horizontal - depth/width - blockCount
		var maxW = map.mapWidth + map.mapMarginW;
		var maxH = map.mapHeight + map.mapMarginH;
		var vd1 = 0, vd2 = 0, vd3 = 0, vd4 = 0, vd5 = 0, hd1 = 0, hd2 = 0, hd3 = 0, hd4 = 0, hd5 = 0;
		var vl1 = 0, vl2 = 0, vl3 = 0, vr1 = 0, vr2 = 0, vr3 = 0;
		var hl1 = 0, hl2 = 0, hl3 = 0, hr1 = 0, hr2 = 0, hr3 = 0;
		if(cf == "n")
		{
			vd5 = 5 - maxH, vd4 = 4 - maxH, vd3 = 3 - maxH, vd2 = 2 - maxH, vd1 = 1 - maxH;
			vl3 = -3, vl2 = -2, vl1 = -1;
			vr3 = 3 - maxW, vr2 = 2 - maxW, vr1 = 1 - maxW;
		}
		else if(cf == "s")
		{
			vd5 = -5, vd4 = -4, vd3 = -3, vd2 = -2, vd1 = -1;
			vl3 = 3 - maxW, vl2 = 2 - maxW, vl1 = 1 - maxW;
			vr3 = -3, vr2 = -2, vr1 = -1;
		}
		else if(cf == "e")
		{
			hd5 = 5 - maxW, hd4 = 4 - maxW, hd3 = 3 - maxW, hd2 = 2 - maxW, hd1 = 1 - maxW;
			hl3 = 3 - maxH, hl2 = 2 - maxH, hl1 = 1 - maxH;
			hr3 = -3, hr2 = -2, hr1 = -1;
		}
		else
		{
			hd5 = -5, hd4 = -4, hd3 = -3, hd2 = -2, hd1 = -1;
			hl3 = -3, hl2 = -2, hl1 = -1;
			hr3 = 3 - maxH, hr2 = 2 - maxH, hr1 = 1 - maxH;
		}

		// 天井の状態を調査
		// １つ前のブロックを参照することで壁の向こうを透視したときに矛盾がなくなる
		// 連続した空間内で屋根が途中で途絶える状況（アーケード等）はこのゲームには登場しない、
		// つまり、天井の状況が変化するとき空間は壁によって完全に仕切られているので
		// 目の前が壁になる状況のときは天井が一切見えなくなる。
		// よって１つ前のブロックを参照しても問題ない
		var ceil_a1 = map.isCeiling(cx + hd1, cy + vd1);
		var ceil_b1 = map.isCeiling(cx + hd1 + vl1, cy + vd1 + hl1);
		var ceil_B1 = map.isCeiling(cx + hd1 + vr1, cy + vd1 + hr1);
		ceiling = ceil_a1;	// 屋根画像を読み込むかどうか。１つ前が屋根の下なら読み込む

		if(! ceiling && map.isCeiling(cx, cy))
		{
			// １つ前が屋根でなくてもその両脇の屋根が見えているなら読み込む
			if(ceil_b1 && ! map.isPartition(cx, cy, pl,, true)
				 && ! map.isPartition(cx + vl1, cy + hl1, pf,, true)) ceiling = true;
			if(ceil_B1 && ! map.isPartition(cx, cy, pr,, true)
				 && ! map.isPartition(cx + vr1, cy + hr1, pf,, true)) ceiling = true;
		}
		if(ceiling) short = true;

		// 天井とその影の画像を読み込み
		shadow_roof.visible = roof.visible = ceiling;
		if(ceiling) roof.load("roof_" + map.roof);
		var shadow = map.shadow;
		if(shadow == "auto") shadow = ceiling ? "dark" : "light";
		shadow_floor.load("shadow_floor_" + shadow);
		if(shadow_roof.visible) shadow_roof.load("shadow_roof_" + shadow);

		// 天井が読み込まれ、その一部が屋外の場合
		// 屋外にあたる屋根部分だけ消去する
		if(ceiling)
		{
			if(! ceil_a1)
			{
				roof.fillRect(220, 0, 580, 600, 0);
				shadow_roof.fillRect(220, 0, 580, 600, 0);
				roof.masked = shadow_roof.masked = true;
			}
			if(! ceil_b1 && ! map.isPartition(cx, cy, pl,, true))
			{
				roof.fillRect(0, 0, 220, 600, 0);
				shadow_roof.fillRect(0, 0, 220, 600, 0);
				roof.masked = shadow_roof.masked = true;
			}
			if(! ceil_B1 && ! map.isPartition(cx, cy, pr,, true))
			{
				roof.fillRect(800, 0, 220, 600, 0);
				shadow_roof.fillRect(800, 0, 220, 600, 0);
				roof.masked = shadow_roof.masked = true;
			}
		}

		// ０列目を表示
		wall_left__a0.load(pos[cx][cy][pl].img, short);
		wall_right_a0.load(pos[cx][cy][pr].img, short);
		wall_front_a0.load(pos[cx][cy][pf].img, short);
		wall_front_b0.load(pos[cx + vl1][cy + hl1][pf].img, short);
		wall_front_B0.load(pos[cx + vr1][cy + hr1][pf].img, short);
		hang_left__a0.load(pos[cx][cy][pl].himg);
		hang_right_a0.load(pos[cx][cy][pr].himg);
		hang_front_a0.load(pos[cx][cy][pf].himg);
		hang_front_b0.load(pos[cx + vl1][cy + hl1][pf].himg);
		hang_front_B0.load(pos[cx + vr1][cy + hr1][pf].himg);
		floor_a0.load(pos[cx][cy].f.img, short);
		floor_b0.load(pos[cx + vl1][cy + hl1].f.img, short);
		floor_B0.load(pos[cx + vr1][cy + hr1].f.img, short);
		put_a0.load(pos[cx][cy].f.pimg, short);
		put_b0.load(pos[cx + vl1][cy + hl1].f.pimg, short);
		put_B0.load(pos[cx + vr1][cy + hr1].f.pimg, short);

		wall_left__a0.loadMask(pos[cx][cy][pl].mask);
		wall_right_a0.loadMask(pos[cx][cy][pr].mask);
		wall_front_a0.loadMask(pos[cx][cy][pf].mask);
		wall_front_b0.loadMask(pos[cx + vl1][cy + hl1][pf].mask);
		wall_front_B0.loadMask(pos[cx + vr1][cy + hr1][pf].mask);

		// １列目を表示
		wall_left__a1.load(pos[cx + hd1][cy + vd1][pl].img, short);
		wall_right_a1.load(pos[cx + hd1][cy + vd1][pr].img, short);
		wall_front_a1.load(pos[cx + hd1][cy + vd1][pf].img, short);
		wall_left__b1.load(pos[cx + hd1 + vl1][cy + vd1 + hl1][pl].img, short);
		wall_right_B1.load(pos[cx + hd1 + vr1][cy + vd1 + hr1][pr].img, short);
		wall_front_b1.load(pos[cx + hd1 + vl1][cy + vd1 + hl1][pf].img, short);
		wall_front_B1.load(pos[cx + hd1 + vr1][cy + vd1 + hr1][pf].img, short);
		wall_front_c1.load(pos[cx + hd1 + vl2][cy + vd1 + hl2][pf].img, short);
		wall_front_C1.load(pos[cx + hd1 + vr2][cy + vd1 + hr2][pf].img, short);
		hang_left__a1.load(pos[cx + hd1][cy + vd1][pl].himg);
		hang_right_a1.load(pos[cx + hd1][cy + vd1][pr].himg);
		hang_front_a1.load(pos[cx + hd1][cy + vd1][pf].himg);
		hang_left__b1.load(pos[cx + hd1 + vl1][cy + vd1 + hl1][pl].himg);
		hang_right_B1.load(pos[cx + hd1 + vr1][cy + vd1 + hr1][pr].himg);
		hang_front_b1.load(pos[cx + hd1 + vl1][cy + vd1 + hl1][pf].himg);
		hang_front_B1.load(pos[cx + hd1 + vr1][cy + vd1 + hr1][pf].himg);
		hang_front_c1.load(pos[cx + hd1 + vl2][cy + vd1 + hl2][pf].himg);
		hang_front_C1.load(pos[cx + hd1 + vr2][cy + vd1 + hr2][pf].himg);
		floor_a1.load(pos[cx + hd1][cy + vd1].f.img, short);
		floor_b1.load(pos[cx + hd1 + vl1][cy + vd1 + hl1].f.img, short);
		floor_B1.load(pos[cx + hd1 + vr1][cy + vd1 + hr1].f.img, short);
		floor_c1.load(pos[cx + hd1 + vl2][cy + vd1 + hl2].f.img, short);
		floor_C1.load(pos[cx + hd1 + vr2][cy + vd1 + hr2].f.img, short);
		put_a1.load(pos[cx + hd1][cy + vd1].f.pimg, short);
		put_ex.load(pos[cx + hd1][cy + vd1].f.eximg, short);	// 特殊な演出用
		put_b1.load(pos[cx + hd1 + vl1][cy + vd1 + hl1].f.pimg, short);
		put_B1.load(pos[cx + hd1 + vr1][cy + vd1 + hr1].f.pimg, short);

		wall_left__a1.loadMask(pos[cx + hd1][cy + vd1][pl].mask);
		wall_right_a1.loadMask(pos[cx + hd1][cy + vd1][pr].mask);
		wall_front_a1.loadMask(pos[cx + hd1][cy + vd1][pf].mask);
		wall_left__b1.loadMask(pos[cx + hd1 + vl1][cy + vd1 + hl1][pl].mask);
		wall_right_B1.loadMask(pos[cx + hd1 + vr1][cy + vd1 + hr1][pr].mask);
		wall_front_b1.loadMask(pos[cx + hd1 + vl1][cy + vd1 + hl1][pf].mask);
		wall_front_B1.loadMask(pos[cx + hd1 + vr1][cy + vd1 + hr1][pf].mask);
		wall_front_c1.loadMask(pos[cx + hd1 + vl2][cy + vd1 + hl2][pf].mask);
		wall_front_C1.loadMask(pos[cx + hd1 + vr2][cy + vd1 + hr2][pf].mask);

		// ２列目を表示
		wall_left__a2.load(pos[cx + hd2][cy + vd2][pl].img, short);
		wall_right_a2.load(pos[cx + hd2][cy + vd2][pr].img, short);
		wall_front_a2.load(pos[cx + hd2][cy + vd2][pf].img, short);
		wall_left__b2.load(pos[cx + hd2 + vl1][cy + vd2 + hl1][pl].img, short);
		wall_front_b2.load(pos[cx + hd2 + vl1][cy + vd2 + hl1][pf].img, short);
		wall_right_B2.load(pos[cx + hd2 + vr1][cy + vd2 + hr1][pr].img, short);
		wall_front_B2.load(pos[cx + hd2 + vr1][cy + vd2 + hr1][pf].img, short);
		wall_left__c2.load(pos[cx + hd2 + vl2][cy + vd2 + hl2][pl].img, short);
		wall_front_c2.load(pos[cx + hd2 + vl2][cy + vd2 + hl2][pf].img, short);
		wall_right_C2.load(pos[cx + hd2 + vr2][cy + vd2 + hr2][pr].img, short);
		wall_front_C2.load(pos[cx + hd2 + vr2][cy + vd2 + hr2][pf].img, short);
		wall_front_d2.load(pos[cx + hd2 + vl3][cy + vd2 + hl3][pf].img, short);
		wall_front_D2.load(pos[cx + hd2 + vr3][cy + vd2 + hr3][pf].img, short);
		hang_left__a2.load(pos[cx + hd2][cy + vd2][pl].himg);
		hang_right_a2.load(pos[cx + hd2][cy + vd2][pr].himg);
		hang_front_a2.load(pos[cx + hd2][cy + vd2][pf].himg);
		hang_left__b2.load(pos[cx + hd2 + vl1][cy + vd2 + hl1][pl].himg);
		hang_front_b2.load(pos[cx + hd2 + vl1][cy + vd2 + hl1][pf].himg);
		hang_right_B2.load(pos[cx + hd2 + vr1][cy + vd2 + hr1][pr].himg);
		hang_front_B2.load(pos[cx + hd2 + vr1][cy + vd2 + hr1][pf].himg);
		hang_left__c2.load(pos[cx + hd2 + vl2][cy + vd2 + hl2][pl].himg);
		hang_front_c2.load(pos[cx + hd2 + vl2][cy + vd2 + hl2][pf].himg);
		hang_right_C2.load(pos[cx + hd2 + vr2][cy + vd2 + hr2][pr].himg);
		hang_front_C2.load(pos[cx + hd2 + vr2][cy + vd2 + hr2][pf].himg);
		hang_front_d2.load(pos[cx + hd2 + vl3][cy + vd2 + hl3][pf].himg);
		hang_front_D2.load(pos[cx + hd2 + vr3][cy + vd2 + hr3][pf].himg);
		floor_a2.load(pos[cx + hd2][cy + vd2].f.img, short);
		floor_b2.load(pos[cx + hd2 + vl1][cy + vd2 + hl1].f.img, short);
		floor_B2.load(pos[cx + hd2 + vr1][cy + vd2 + hr1].f.img, short);
		floor_c2.load(pos[cx + hd2 + vl2][cy + vd2 + hl2].f.img, short);
		floor_C2.load(pos[cx + hd2 + vr2][cy + vd2 + hr2].f.img, short);
		floor_d2.load(pos[cx + hd2 + vl3][cy + vd2 + hl3].f.img, short);
		floor_D2.load(pos[cx + hd2 + vr3][cy + vd2 + hr3].f.img, short);
		put_a2.load(pos[cx + hd2][cy + vd2].f.pimg, short);
		put_b2.load(pos[cx + hd2 + vl1][cy + vd2 + hl1].f.pimg, short);
		put_B2.load(pos[cx + hd2 + vr1][cy + vd2 + hr1].f.pimg, short);
		put_c2.load(pos[cx + hd2 + vl2][cy + vd2 + hl2].f.pimg, short);
		put_C2.load(pos[cx + hd2 + vr2][cy + vd2 + hr2].f.pimg, short);

		wall_left__a2.loadMask(pos[cx + hd2][cy + vd2][pl].mask);
		wall_right_a2.loadMask(pos[cx + hd2][cy + vd2][pr].mask);
		wall_front_a2.loadMask(pos[cx + hd2][cy + vd2][pf].mask);
		wall_left__b2.loadMask(pos[cx + hd2 + vl1][cy + vd2 + hl1][pl].mask);
		wall_front_b2.loadMask(pos[cx + hd2 + vl1][cy + vd2 + hl1][pf].mask);
		wall_right_B2.loadMask(pos[cx + hd2 + vr1][cy + vd2 + hr1][pr].mask);
		wall_front_B2.loadMask(pos[cx + hd2 + vr1][cy + vd2 + hr1][pf].mask);
		wall_left__c2.loadMask(pos[cx + hd2 + vl2][cy + vd2 + hl2][pl].mask);
		wall_front_c2.loadMask(pos[cx + hd2 + vl2][cy + vd2 + hl2][pf].mask);
		wall_right_C2.loadMask(pos[cx + hd2 + vr2][cy + vd2 + hr2][pr].mask);
		wall_front_C2.loadMask(pos[cx + hd2 + vr2][cy + vd2 + hr2][pf].mask);
		wall_front_d2.loadMask(pos[cx + hd2 + vl3][cy + vd2 + hl3][pf].mask);
		wall_front_D2.loadMask(pos[cx + hd2 + vr3][cy + vd2 + hr3][pf].mask);

		// ３列目を表示
		wall_left__a3.load(pos[cx + hd3][cy + vd3][pl].img, short);
		wall_right_a3.load(pos[cx + hd3][cy + vd3][pr].img, short);
		wall_front_a3.load(pos[cx + hd3][cy + vd3][pf].img, short);
		wall_left__b3.load(pos[cx + hd3 + vl1][cy + vd3 + hl1][pl].img, short);
		wall_front_b3.load(pos[cx + hd3 + vl1][cy + vd3 + hl1][pf].img, short);
		wall_right_B3.load(pos[cx + hd3 + vr1][cy + vd3 + hr1][pr].img, short);
		wall_front_B3.load(pos[cx + hd3 + vr1][cy + vd3 + hr1][pf].img, short);
		wall_left__c3.load(pos[cx + hd3 + vl2][cy + vd3 + hl2][pl].img, short);
		wall_front_c3.load(pos[cx + hd3 + vl2][cy + vd3 + hl2][pf].img, short);
		wall_right_C3.load(pos[cx + hd3 + vr2][cy + vd3 + hr2][pr].img, short);
		wall_front_C3.load(pos[cx + hd3 + vr2][cy + vd3 + hr2][pf].img, short);
		wall_front_d3.load(pos[cx + hd3 + vl3][cy + vd3 + hl3][pf].img, short);
		wall_front_D3.load(pos[cx + hd3 + vr3][cy + vd3 + hr3][pf].img, short);
		hang_left__a3.load(pos[cx + hd3][cy + vd3][pl].himg);
		hang_right_a3.load(pos[cx + hd3][cy + vd3][pr].himg);
		hang_front_a3.load(pos[cx + hd3][cy + vd3][pf].himg);
		hang_left__b3.load(pos[cx + hd3 + vl1][cy + vd3 + hl1][pl].himg);
		hang_front_b3.load(pos[cx + hd3 + vl1][cy + vd3 + hl1][pf].himg);
		hang_right_B3.load(pos[cx + hd3 + vr1][cy + vd3 + hr1][pr].himg);
		hang_front_B3.load(pos[cx + hd3 + vr1][cy + vd3 + hr1][pf].himg);
		hang_left__c3.load(pos[cx + hd3 + vl2][cy + vd3 + hl2][pl].himg);
		hang_front_c3.load(pos[cx + hd3 + vl2][cy + vd3 + hl2][pf].himg);
		hang_right_C3.load(pos[cx + hd3 + vr2][cy + vd3 + hr2][pr].himg);
		hang_front_C3.load(pos[cx + hd3 + vr2][cy + vd3 + hr2][pf].himg);
		hang_front_d3.load(pos[cx + hd3 + vl3][cy + vd3 + hl3][pf].himg);
		hang_front_D3.load(pos[cx + hd3 + vr3][cy + vd3 + hr3][pf].himg);
		floor_a3.load(pos[cx + hd3][cy + vd3].f.img, short);
		floor_b3.load(pos[cx + hd3 + vl1][cy + vd3 + hl1].f.img, short);
		floor_B3.load(pos[cx + hd3 + vr1][cy + vd3 + hr1].f.img, short);
		floor_c3.load(pos[cx + hd3 + vl2][cy + vd3 + hl2].f.img, short);
		floor_C3.load(pos[cx + hd3 + vr2][cy + vd3 + hr2].f.img, short);
		floor_d3.load(pos[cx + hd3 + vl3][cy + vd3 + hl3].f.img, short);
		floor_D3.load(pos[cx + hd3 + vr3][cy + vd3 + hr3].f.img, short);
		put_a3.load(pos[cx + hd3][cy + vd3].f.pimg, short);
		put_b3.load(pos[cx + hd3 + vl1][cy + vd3 + hl1].f.pimg, short);
		put_B3.load(pos[cx + hd3 + vr1][cy + vd3 + hr1].f.pimg, short);
		put_c3.load(pos[cx + hd3 + vl2][cy + vd3 + hl2].f.pimg, short);
		put_C3.load(pos[cx + hd3 + vr2][cy + vd3 + hr2].f.pimg, short);
		put_d3.load(pos[cx + hd3 + vl3][cy + vd3 + hl3].f.pimg, short);
		put_D3.load(pos[cx + hd3 + vr3][cy + vd3 + hr3].f.pimg, short);

		wall_left__a3.loadMask(pos[cx + hd3][cy + vd3][pl].mask);
		wall_right_a3.loadMask(pos[cx + hd3][cy + vd3][pr].mask);
		wall_front_a3.loadMask(pos[cx + hd3][cy + vd3][pf].mask);
		wall_left__b3.loadMask(pos[cx + hd3 + vl1][cy + vd3 + hl1][pl].mask);
		wall_front_b3.loadMask(pos[cx + hd3 + vl1][cy + vd3 + hl1][pf].mask);
		wall_right_B3.loadMask(pos[cx + hd3 + vr1][cy + vd3 + hr1][pr].mask);
		wall_front_B3.loadMask(pos[cx + hd3 + vr1][cy + vd3 + hr1][pf].mask);
		wall_left__c3.loadMask(pos[cx + hd3 + vl2][cy + vd3 + hl2][pl].mask);
		wall_front_c3.loadMask(pos[cx + hd3 + vl2][cy + vd3 + hl2][pf].mask);
		wall_right_C3.loadMask(pos[cx + hd3 + vr2][cy + vd3 + hr2][pr].mask);
		wall_front_C3.loadMask(pos[cx + hd3 + vr2][cy + vd3 + hr2][pf].mask);

		// ４列目を表示（側壁と床だけ。正面の壁は暗くて見えない）
		if(pos[cx + hd4] === void || pos[cx + hd4][cy + vd4] === void) return;
		wall_left__a4.load(pos[cx + hd4][cy + vd4][pl].img, short);
		wall_right_a4.load(pos[cx + hd4][cy + vd4][pr].img, short);
		wall_left__b4.load(pos[cx + hd4 + vl1][cy + vd4 + hl1][pl].img, short);
		wall_right_B4.load(pos[cx + hd4 + vr1][cy + vd4 + hr1][pr].img, short);
		wall_left__c4.load(pos[cx + hd4 + vl2][cy + vd4 + hl2][pl].img, short);
		wall_right_C4.load(pos[cx + hd4 + vr2][cy + vd4 + hr2][pr].img, short);
		floor_a4.load(pos[cx + hd4][cy + vd4].f.img, short);
		floor_b4.load(pos[cx + hd4 + vl1][cy + vd4 + hl1].f.img, short);
		floor_B4.load(pos[cx + hd4 + vr1][cy + vd4 + hr1].f.img, short);
		floor_c4.load(pos[cx + hd4 + vl2][cy + vd4 + hl2].f.img, short);
		floor_C4.load(pos[cx + hd4 + vr2][cy + vd4 + hr2].f.img, short);
		floor_d4.load(pos[cx + hd4 + vl3][cy + vd4 + hl3].f.img, short);
		floor_D4.load(pos[cx + hd4 + vr3][cy + vd4 + hr3].f.img, short);
		put_a4.load(pos[cx + hd4][cy + vd4].f.pimg, short);
		put_b4.load(pos[cx + hd4 + vl1][cy + vd4 + hl1].f.pimg, short);
		put_B4.load(pos[cx + hd4 + vr1][cy + vd4 + hr1].f.pimg, short);
		put_c4.load(pos[cx + hd4 + vl2][cy + vd4 + hl2].f.pimg, short);
		put_C4.load(pos[cx + hd4 + vr2][cy + vd4 + hr2].f.pimg, short);
		put_d4.load(pos[cx + hd4 + vl3][cy + vd4 + hl3].f.pimg, short);
		put_D4.load(pos[cx + hd4 + vr3][cy + vd4 + hr3].f.pimg, short);

		// ５列目を表示（一部特殊な壁のみ）
		if(pos[cx + hd5] === void || pos[cx + hd5][cy + vd5] === void) return;
		wall_left__a5.load(pos[cx + hd5][cy + vd5][pl].img, short);
		wall_right_a5.load(pos[cx + hd5][cy + vd5][pr].img, short);
		wall_left__b5.load(pos[cx + hd5 + vl1][cy + vd5 + hl1][pl].img, short);
		wall_right_B5.load(pos[cx + hd5 + vr1][cy + vd5 + hr1][pr].img, short);
		wall_left__c5.load(pos[cx + hd5 + vl2][cy + vd5 + hl2][pl].img, short);
		wall_right_C5.load(pos[cx + hd5 + vr2][cy + vd5 + hr2][pr].img, short);

		dm("ダンジョンの描画に " + (System.getTickCount() - startTick) + " ms かかりました");
	}
}
//----------------------------------------------------------------------------------------
