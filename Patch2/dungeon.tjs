		wall_left__a3 = new WallLayer(this, "side_a3" , 100, 450, 390, 0, 680, true,, true);
		wall_right_a3 = new WallLayer(this, "side_a3" , 100, 450, 530, 0, 680, true, true, true);
		wall_left__b3 = new WallLayer(this, "side_b3" , 130, 450, 220, 0, 670, true,, true);
