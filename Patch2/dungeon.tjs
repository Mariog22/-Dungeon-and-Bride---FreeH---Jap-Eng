		wall_front_C1 = new WallLayer(this, "front_c1", 140, 490, 880, 0, 820,, true, true);

		wall_left__a2 = new WallLayer(this, "side_a2" , 140, 500, 340, 0, 780, true,, true);
		wall_right_a2 = new WallLayer(this, "side_a2" , 140, 500, 540, 0, 780, true, true, true);
		wall_left__b2 = new WallLayer(this, "side_b2" , 240, 500,  70, 0, 770, true,, true);
		wall_right_B2 = new WallLayer(this, "side_b2" , 240, 500, 710, 0, 770, true, true, true);
