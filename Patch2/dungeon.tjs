		// 透視を防止する壁
		scopeGuard = new PartsLayer(this,, 820, 680, 100, 0, 935);

		// 暗闇エリアのレイヤーを作成
		darkZone = new global.Layer(par.window, par);
		darkZone.setSize(par.width, par.height);
		darkZone.hitThreshold = 256;
		darkZone.absolute = 990;

		// 決闘の網レイヤーを作成
		duelNet = new global.Layer(window, this);
		duelNet.setSize(width, height);
		duelNet.loadImages("duel_net");
		duelNet.hitThreshold = 256;
		duelNet.absolute = 900;
		duelNet.type = ltDodge;
	}

