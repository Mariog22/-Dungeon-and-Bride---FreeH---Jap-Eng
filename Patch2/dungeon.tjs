// dungeon.tjs
// ダンジョン画面生成＆移動


//----------------------------------------------------------------------------------------
class DungeonView extends Layer
{
	// ダンジョンのビュー（景色）画面のクラス
	// ここにフォーカスを持ってくるとキー入力で移動するようになる

	var master;	// 管理オブジェクト
	var defaultX = 0;	// レイヤーの初期位置Ｘ
	var defaultY = -40;	// レイヤーの初期位置Ｙ
	var walkTimer;	// アニメ用タイマー
	var walkSpeed = 20;	// 移動アニメ速度。短いほど速い
	var animCount = 0;	// アニメ用カウント
	var waitTimer;	// マウスの連続移動を開始するまで待つタイマー
	var repeatStarted = true;	// マウスの連続移動が開始したかどうか
	var viewScreen;	// 実際に画面に表示されるダンジョン画面
	var bufScreen;	// レイヤーの表示状態を操作し構成する裏画面
	var sideScreen;	// 横移動＆横回転時に利用する横から出てくる画面
	var tempScreen;	// レイヤー合成など一時的に利用する見えない画面
	var effectLayer;	// 演出用レイヤー（アニメ・スクリーン等）
	var emitLayer;	// 演出用レイヤー（パーティクル）
	var skyLayer;	// 空のレイヤー
	var blindScreen;	// 暗闇レイヤー
	var objectLayer;	// クリックできるオブジェクトを読み込むレイヤー
	var boatLayer;	// ボート
	var fallenObject;	// 落下する物体
	var controlBoard;	// 移動操作ボード
	var borderLayer;	// 分割線を描画するレイヤー
	var backSound;	// 環境音オブジェクト
	var _skyImage;	// 空の画像（ updateView を実行するまで読み込まれない）
	var _blindImage;	// 目隠しの画像（ updateView を実行するまで読み込まれない）
	var _effectFile;	// 演出ファイル（ updateView を実行するまで読み込まれない）
	var _soundFile;	// 効果音ファイル（ updateView を実行するまで読み込まれない）
	var nextX = 0;	// 移動後のＸ座標
	var nextY = 0;	// 移動後のＹ座標
	var middleX = 0;	// ジャンプする際の中間のＸ座標（ジャンプ演出用）
	var middleY = 0;	// ジャンプする際の中間のＹ座標（ジャンプ演出用）
	var nextFront = "n";	// 移動後の前方の方角
	var nextDarkZone;	// 次のエリアをダークゾーンにするかどうか
	var walkType = "goForward";	// 移動のタイプ。これを参照してアニメを行う
	var cursorDirect = "crArrow";	// マウス移動用カーソル
	var centerBorder = 420;	// マウスカーソルが変化する境界（縦分割・中央）
	var sideBorder   = 400;	//   〃  （縦分割・外側）
	var leftBorder   = 320;	//   〃  （横分割・左）
	var rightBorder  = 580;	//   〃  （横分割・右）
	var downKeyAction = "goBackward";	// 下キーを押した時の動作  後退 or 転回
	var anotherDecideKey = BT_UP;	// 決定キーが決定以外に果たす役割のキー

	function DungeonView(par, master)
	{
		super.Layer(par.window, par);
		name = "ダンジョンビュー";
		this.master = master;
		focusable = true;
		setSize(900, 600);
		hitThreshold = 0;
		fillRect(0, 0, width, height, 0);

		// 移動アニメ用タイマーを作成
		walkTimer = new Timer(walking, "");
		walkTimer.interval = walkSpeed;	// 移動アニメの速度

		// 連続移動開始待ち用タイマーを作成
		waitTimer = new Timer(startRepeat, "");
		waitTimer.interval = 300;	// 待ち時間

		// 裏構成画面を作成
		bufScreen = new ViewLayer(this);
		bufScreen.absolute = 0;
		bufScreen.hitThreshold = 256;

		// 表示画面を作成
		viewScreen = new KAGLayer(window, this);
		viewScreen.setSize(this.width, this.height);
		viewScreen.absolute = 100;
		viewScreen.visible = true;
		viewScreen.hitThreshold = 256;

		// 横から出てくる画面を作成
		sideScreen = new KAGLayer(window, this);
		sideScreen.setSize(this.width, this.height);
		sideScreen.left = 900;
		sideScreen.absolute = 90;
		sideScreen.visible = true;
		sideScreen.hitThreshold = 256;

		// 一時レイヤーを作成
		tempScreen = new KAGLayer(window, this);
		tempScreen.setSize(bufScreen.width, bufScreen.height);
		tempScreen.absolute = 0;
		tempScreen.hitThreshold = 256;

		// 空のレイヤーを作成
		skyLayer = new global.Layer(window, parent);
		skyLayer.setSize(width, height);
		skyLayer.hitThreshold = 256;
		skyLayer.visible = true;

		// 演出用レイヤーを作成
		emitLayer = new EffectLayer(parent);
		emitLayer.setSize(width, height);
		emitLayer.visible = false;

		// 手前のスクリーンレイヤーを作成
		effectLayer = new EffectLayer(parent);
		effectLayer.setSize(width, height);
		effectLayer.visible = false;

		// 暗闇レイヤー作成
		blindScreen = new global.Layer(window, this);
		blindScreen.setSize(this.width, this.height);
		blindScreen.absolute = 900;
		blindScreen.hitThreshold = 256;

		// クリックオブジェクトレイヤー作成
		objectLayer = new TouchableObject(this, master);
		objectLayer.setSize(700, 660);
		objectLayer.setPos(100, -40);
		objectLayer.absolute = 800;

		// ボート作成
		boatLayer = new global.Layer(window, parent);
		boatLayer.loadImages("magical_boat");
		boatLayer.setSizeToImageSize();
		boatLayer.setPos(width - boatLayer.width >> 1, height - boatLayer.height - 40);
		boatLayer.hitThreshold = 256;

		// 移動操作ボード作成
		controlBoard = new ControlBoard(master.gameFrame, master);
		controlBoard.setPos(width - controlBoard.width - 15, height - controlBoard.height - 45);

		// 分割線を描画するレイヤーを作成
		borderLayer = new global.Layer(window, this);
		borderLayer.setSize(this.width, this.height);
		borderLayer.absolute = 1200;
		borderLayer.hitThreshold = 256;

		// 環境音を再生するバッファを作成（ＫＡＧの物を使うとロード時に再生されてしまうため）
		backSound = new WaveSoundBuffer(window);
		backSound.looping = true;
	}

	function finalize()
	{
		invalidate walkTimer;
		invalidate waitTimer;
		invalidate viewScreen;
		invalidate bufScreen;
		invalidate sideScreen;
		invalidate tempScreen;
		invalidate emitLayer;
		invalidate effectLayer;
		invalidate skyLayer;
		invalidate blindScreen;
		invalidate objectLayer;
		invalidate boatLayer;
		invalidate controlBoard;
		invalidate borderLayer;
		invalidate backSound;
		super.finalize();
	}

	property visible
	{
		setter(v)
		{
			skyLayer.visible = v;
			if(! v) stopEffect();
			else if(master.map.effect !== void) startEffect(master.map.effect, true);
			super.visible = v;
		}
		getter
		{
			return super.visible;
		}
	}

	property enabled
	{
		setter(v)
		{
			hitThreshold = v ? 0 : 256;
			objectLayer.touchable = v;
			focusable = v;
		}
		getter
		{
			return focusable;
		}
	}

	property inStable
	{
		getter{ return ! walkTimer.enabled; }
	}

	function resetPos()
	{
		// ビュー位置リセット。浮遊状態かどうかで違う
		setPos(0, master.party.isFloating() ? 0 : -40);
	}

	function open()
	{
		// 表示（画面は構築済み）
		visible = true;
		skyLayer.visible = true;
	}

	function startExplore()
	{
		// ダンジョン探索開始
		open();
		master.onGameRestart();
		playMusic(master.map.bgm);
		master.walkFinished(true);	// 入ってすぐのイベントを調べる
	}

	function close()
	{
		// ダンジョンを閉じる
		enabled = false;
		visible = false;
		boatLayer.visible = false;
		skyLayer.visible = false;
		objectLayer.visible = false;
		bufScreen.duelNet.visible = false;
		master.miniMap.close();
		stopEffect();
		stopMapSound();
	}

	function goToStreet()
	{
		// 店舗等から戻る時に呼ぶ
		master.clearWindows();
		master.itemWin.close();
		master.updateView();
		kag.process("script.ks", "*shop_exit");
	}

	function setTouchableObject(info)
	{
		// クリックできるオブジェクトを設置する
		objectLayer.loadImages(info.img);
		objectLayer.isButton = +info.button;
		objectLayer.visible = true;
	}

	function setBlindScreen(enabled)
	{
		// ダンジョンの目隠し状態を設定する
		blindScreen.visible = (enabled && master.map.blind !== void);
	}

	function setClairvoyance(enabled)
	{
		// 透視状態を設定する
		bufScreen.wall_front_a0.opacity = enabled ? 64 : 255;
		updateView(master.party.curX, master.party.curY, master.party.curFront);
	}

	function loadInitialParts(dic)
	{
		// マップデータを読み込みするときに必ず必要になる画像を先にある程度まとめて読み込む
		// 操作開始初期に読み込まれてないパーツ画像が多いせいでもたつくのを回避するのも兼ねる
		bufScreen.loadMainDungeonParts(dic.defWall, dic.defFloor);
		setEnvironmentInfo(dic);
	}

	function setEnvironmentInfo(dic)
	{
		// ダンジョンの壁や床以外の周囲の状況を表す画像を設定する
		if(dic.sky !== void) _skyImage = dic.sky;	// 空（背景）
		if(dic.effect !== void) _effectFile = dic.effect;	// 演出
		if(dic.sound !== void) _soundFile = dic.sound;	// 効果音
		if(dic.blind !== void) _blindImage = dic.blind;	// 暗闇
	}

	function startEffect(file, quickly = false)
	{
		// 演出を開始する
		stopEffect();	// いったん止める
		if(Storages.isExistentStorage(file + ".pee"))
		{
			// パーティクル
			emitLayer.loadImages(%[storage: "PE_base_view"]);
			particle_object.start(emitLayer, 12, file + ".pee", -1);
			if(quickly) particle_object.emitters[12].advanceTime(5);
			emitLayer.visible = true;
		}
		if(Storages.isExistentStorage(file + ".asd"))
		{
			// アニメ
			effectLayer.loadImages(%[storage: file, clipwidth: 900, clipheight: 560]);
			effectLayer.visible = true;
			effectLayer.startAnim(%[seg: 1, target: "*start"]);
		}
		else if(Storages.isExistentStorage(file + ".png"))
		{
			// 手前のスクリーンに画像を読み込むだけ
			effectLayer.loadImages(%[storage: file]);
			effectLayer.visible = true;
		}
	}

	function stopEffect()
	{
		// 演出を終了する
		effectLayer.freeImage();
		if(emitLayer.visible)
		{
			emitLayer.visible = false;
			particle_object.emitters[12].stop(true);
		}
	}

	function fadeEffect()
	{
		// 演出をゆっくり終了する  シナリオの先で stopEffect を実行すること
		if(particle_object.emitters[12].active) particle_object.emitters[12].stop(false);
		if(effectLayer.visible) effectLayer.beginMove(%[time: 1000, path: ",,0"]);
	}

	function playMapSound(file)
	{
		// 環境音を開始する
		backSound.volume2 = kag.se[0].volume2;
		backSound.open(file + ".wav");
		backSound.play();
	}

	function stopMapSound()
	{
		// 効果音を終了する
		backSound.stop();
	}

	function showWarpingEffect()
	{
		// 移動アニメ中に次の座標がワープだった場合その演出を行う
		if(master.party.afterEscaped) return;
		if(master.party.lastX == nextX && master.party.lastY == nextY) return;
		var warp = master.map.getWarpInfo(nextX, nextY);
		if(warp === void) return;
		if(warp.ask !== void || warp.click !== void || warp.stair !== void) return;
		if(warp.stealth || warp.fall || warp.climb) return;
		master.backScreen.visible = true;
		if(warp.symbol === void) playSound("poyon");
	}

	function updateView(x, y, front)
	{
		// 指定したビューを表示する
		nextDarkZone = master.map.getDarkZoneName(x, y);
		bufScreen.updateView(x, y, front, nextDarkZone);
		viewScreen.piledCopy(0, 0, bufScreen, 60, 40, 900, 600);
		master.backScreen.visible = false;
		if(_skyImage !== void)
		{
			skyLayer.loadImages("sky_" + _skyImage);
			_skyImage = void;
		}
		if(_effectFile !== void)
		{
			startEffect(_effectFile);
			_effectFile = void;
		}
		if(_soundFile !== void)
		{
			playMapSound(_soundFile);
			_soundFile = void;
		}
		if(_blindImage !== void)
		{
			blindScreen.loadImages("blind_" + _blindImage);
			blindScreen.visible = true;
			_blindImage = void;
		}
	}

	function startWalk(type, x, y, front, darkZone, mx, my)
	{
		// 移動アニメをしつつ指定のビューを表示する
		if(walkTimer.enabled) return;
		nextX = x;
		nextY = y;
		middleX = mx;
		middleY = my;
		nextFront = front;
		nextDarkZone = darkZone;
		walkType = type;
		animCount = 0;
		walkTimer.enabled = true;	// 移動開始
		objectLayer.visible = false;	// オブジェクトを消しておく
	}

	function stretchAndPrintToViewScreen(sleft, stop, swidth, sheight)
	{
		// 子レイヤを１枚にまとめつつ拡縮コピー
		tempScreen.piledCopy(0, 0, bufScreen, 0, 0, 1020, 680);
		viewScreen.stretchCopy(0, 0, 900, 600, tempScreen, sleft, stop, swidth, sheight);
			// operateStretch だとコピー先への合成機能が災いして前の画像が残ってしまうのでこれを使う
	}

	function walking()
	{
		// 歩行や方向転換のビューアニメ処理

		// ジャンプ前進
		if(walkType == "jumpForward")
		{
			sideScreen.left = 2000;
			if(animCount == 0)
			{
				bufScreen.shiftWallImage(1);
				stretchAndPrintToViewScreen(75, 50, 870, 580);	// 0.967
				top += 30;
			}
			else if(animCount == 1)
			{
				bufScreen.shiftWallImage(2);
				stretchAndPrintToViewScreen(120, 80, 780, 520);	// 0.867
				top += 20;
			}
			else if(animCount == 2)
			{
				// 中間表示・一瞬途中の画像を見せることで大きく移動していることを意識させる
				bufScreen.updateView(middleX, middleY, nextFront, nextDarkZone);
				bufScreen.shiftWallImage(0);
				viewScreen.piledCopy(0, 0, bufScreen, 60, 40, 900, 600);
				top += 10;
			}
			else if(animCount == 6)
			{
				bufScreen.updateView(nextX, nextY, nextFront, nextDarkZone);
				bufScreen.shiftWallImage(3);
				stretchAndPrintToViewScreen(0, 0, 1020, 680);		// 1.133
				top -= 10;
			}
			else if(animCount == 7)
			{
				bufScreen.shiftWallImage(4);
				stretchAndPrintToViewScreen(45, 30, 930, 620);	// 1.033
				top -= 20;
			}
			else if(animCount == 8)
			{
				bufScreen.shiftWallImage(0);
				viewScreen.piledCopy(0, 0, bufScreen, 60, 40, 900, 600);
				walkTimer.enabled = false;
				resetPos();
			}
			else
			{
				// 中間表示 ( animCount が 3 ～ 5 ) 実際は止まっているが一瞬なので動いているように見える
				bufScreen.shiftWallImage(0);
				viewScreen.piledCopy(0, 0, bufScreen, 60, 40, 900, 600);
			}
		}

		// 前進／後退／逃亡／ジャンプ後の逃亡による後退
		if(walkType == "goForward" || walkType == "goBackward"
			 || walkType == "escapeToBack" || walkType == "jumpToBack")
		{
			sideScreen.left = 2000;
			var d = (walkType != "goForward");
			if(animCount == 2)
			{
				bufScreen.updateView(nextX, nextY, nextFront, nextDarkZone);
				showWarpingEffect();
			}
			if(animCount == 4)
			{
				bufScreen.shiftWallImage(0);
				viewScreen.piledCopy(0, 0, bufScreen, 60, 40, 900, 600);
				walkTimer.enabled = false;
			}
			else if(animCount == 3 * d)
			{
				bufScreen.shiftWallImage(1);
				stretchAndPrintToViewScreen(75, 50, 870, 580);	// 0.967
			}
			else if(animCount == 1 + d)
			{
				bufScreen.shiftWallImage(2);
				stretchAndPrintToViewScreen(120, 80, 780, 520);	// 0.867
			}
			else if(animCount == 2 - d)
			{
				bufScreen.shiftWallImage(3);
				stretchAndPrintToViewScreen(0, 0, 1020, 680);		// 1.133
			}
			else
			{
				bufScreen.shiftWallImage(4);
				stretchAndPrintToViewScreen(45, 30, 930, 620);	// 1.033
			}
		}

		// カニ歩き
		else if(walkType == "stepToLeft" || walkType == "stepToRight")
		{
			var d = (walkType == "stepToLeft" ? 1 : -1);
			if(animCount == 0)
			{
				// 次がワープだった場合一瞬暗くなり音も鳴る
				bufScreen.updateView(nextX, nextY, nextFront, nextDarkZone);
				showWarpingEffect();

				// 画面を準備
				sideScreen.width = 900;
				sideScreen.piledCopy(0, 0, bufScreen, 60, 40, 900, 600);
				viewScreen.left =  20 * d; sideScreen.left = -580 * d + 300;
				sideScreen.width = 300;
				sideScreen.imageLeft = 300 * d - 300;
			}
			else if(animCount == 1)
			{
				viewScreen.left =  60 * d; sideScreen.left = -540 * d + 300;
			}
			else if(animCount == 2)
			{
				// ここで sideScreen が広くなる
				viewScreen.left = 540 * d + 300; sideScreen.left =  -60 * d;
				viewScreen.width = 300;
				viewScreen.imageLeft = -300 * d - 300;
				sideScreen.width = 900;
				sideScreen.imageLeft = 0;
			}
			else if(animCount == 3)
			{
				viewScreen.left = 580 * d + 300; sideScreen.left =  -20 * d;
			}
			else if(animCount == 4)
			{
				viewScreen.left = 600 * d + 300; sideScreen.left = 0;
				walkTimer.enabled = false;
				viewScreen <-> sideScreen;	// 参照を入れ替える
			}
		}

		// 方向転換
		else if(walkType == "turnLeft" || walkType == "turnRight" || walkType == "turnAround"
			 || walkType == "turnLeftAndGo" || walkType == "turnRightAndGo")
		{
			var d = (walkType == "turnLeft" || walkType == "turnLeftAndGo" ? 1 : -1);
			if(animCount == 0)
			{
				bufScreen.updateView(nextX, nextY, nextFront, nextDarkZone);
				sideScreen.left = 900 * d;
				sideScreen.width = 900;
				sideScreen.piledCopy(0, 0, bufScreen, 60, 40, 900, 600);
				viewScreen.left =  20 * d; sideScreen.left = -880 * d;
			}
			else if(animCount == 1){ viewScreen.left =  60 * d; sideScreen.left = -840 * d; }
			else if(animCount == 2){ viewScreen.left = 120 * d; sideScreen.left = -780 * d; }
			else if(animCount == 3){ viewScreen.left = 780 * d; sideScreen.left = -120 * d; }
			else if(animCount == 4){ viewScreen.left = 840 * d; sideScreen.left =  -60 * d; }
			else if(animCount == 5){ viewScreen.left = 880 * d; sideScreen.left =  -20 * d; }
			else
			{
				viewScreen.left = 900 * d; sideScreen.left = 0;
				walkTimer.enabled = false;
				viewScreen <-> sideScreen;
				if(walkType == "turnAround")
				{
					master.walk("turnRight");
					return;
				}
				else if(walkType == "turnLeftAndGo" || walkType == "turnRightAndGo")
				{
					master.walk("goForward");
					return;
				}
			}
		}

		if(! walkTimer.enabled)
		{
			master.walkFinished();
			return;
		}

		animCount ++;		// アニメカウントアップ
	}

	function repeatLastWalkingByMouse()
	{
		// マウスを押しっぱなしにした時に同じ移動を繰り返す
		if(! enabled) return;
		if(! repeatStarted) waitTimer.enabled = true;
		else master.walk(walkType);
	}

	function startRepeat()
	{
		// 連続移動開始
		repeatStarted = true;
		waitTimer.enabled = false;
		master.walk(walkType);
	}

	function stopWaitingStartRepeat()
	{
		// 連続移動開始を待つのを中断する
		waitTimer.enabled = false;
		repeatStarted = false;
	}

	function onKeyDown(key, shift, process=true)
	{
		// このレイヤーにフォーカスがあるときにキー入力があったら
		// 方向キーだったら移動、キャンセルキーならメニューを出すなどする

		if(walkTimer.enabled) return;
		if(window.preProcessKeys(key, shift)) return;

		// マウスが押されているとき
		if(System.getKeyState(VK_LBUTTON) || System.getKeyState(VK_RBUTTON))
		{
			return;
		}

		// マウスが表示されているとき
		if(! MOUSE_HIDDEN)
		{
			master.turnOffCharasHilight();
			window.hideMouseCursor();	// 誤解を招かないため、カーソルを一時的に隠す
		}

		// 決定キーの追加機能
		if(key == BT_OK || key == BT_OK2) key = anotherDecideKey;

		// 各種キー操作
		if(key == BT_UP || key == BT_UP2) master.walk("goForward");
		else if(key == BT_DOWN || key == BT_DOWN2) master.walk(downKeyAction);
		else if(key == BT_LSTEP || key == BT_LSTEP2) master.walk("stepToLeft");
		else if(key == BT_RSTEP || key == BT_RSTEP2) master.walk("stepToRight");
		else if(key == BT_LEFT || key == BT_LEFT2) master.walk("turnLeft");
		else if(key == BT_RIGHT || key == BT_RIGHT2) master.walk("turnRight");
		else if(key == BT_OPTION || key == BT_OPTION2) master.clickObjectByKey();
		else if(kag.focusedLayerIsNull) return;	// フォーカス null 時のキーイベント二重送信問題対策
		else if(key == BT_CANCEL || key == BT_CANCEL2) window.onPrimaryRightClick();
		else if(key == BT_MAP || key == BT_MAP2) master.gameFrame.openAutoMap();
		else if(key == BT_SEARCH || key == BT_SEARCH2) master.gameFrame.playSearchCommand();
		else if(key == BT_MAGIC || key == BT_MAGIC2) master.gameFrame.openMagicCommand();
		else if(key == BT_ITEM || key == BT_ITEM2) master.gameFrame.openItemCommand();
		else if(key == BT_SAVE || key == BT_SAVE2) master.gameFrame.openSaveCommand();
		super.onKeyDown(key, shift, false);
	}

	function onKeyUp(key, shift, process=true)
	{
		if(objectLayer.visible) objectLayer.releaseObject();
		super.onKeyUp(key, shift, false);
	}

	function focus()
	{
		focusable = true;
		super.focus();
		repeatStarted = false;
		if(sf.controlBoardVisible) controlBoard.visible = true;
		else if(focused) onMouseMove(cursorX, cursorY);	// カーソルを適切な形に変える
		if(sf.cursorsBorderVisible) drawControllerLine();
	}

	function unfocus()
	{
		super.unfocus();
		focusable = false;
		cursorDirect = "crArrow";	// とりあえず
		cursor = crArrow;
		borderLayer.visible = false;
		controlBoard.visible = false;
	}

	function onMouseEnter()
	{
		if(MOUSE_HIDDEN) return;
			// ↑ キーボード操作時に隠れたマウスの所にフォーカスが再度動いてしまうのを防ぐため
		focus();
	}

	function onMouseUp(x, y, button, shift)
	{
		if(button == mbLeft) stopWaitingStartRepeat();
		super.onMouseUp(...);
	}

	function onMouseDown(x, y, button, shift)
	{
		// レイヤーが当たり判定を失った後も
		// マウスメッセージを受け付けることがあるのが判明
		// hitThreshold が 256 になってからマウスメッセージを受け付けなくなるまで
		// タイムラグがあるようなので、ここでも判定をする
		if(walkTimer.enabled || hitThreshold ==256) return;
		if(button == mbRight) window.onPrimaryRightClick();
		else if(button == mbLeft && ! controlBoard.visible) master.walk(cursorDirect);
		super.onMouseDown(...);
	}

	function onMouseMove(x, y, shift)
	{
		if(sf.controlBoardVisible) return;
		if(x < leftBorder)
		{
			if(y < sideBorder) changeCursor("turnLeft");
			else changeCursor("stepToLeft");
		}
		else if(x > rightBorder)
		{
			if(y < sideBorder) changeCursor("turnRight");
			else changeCursor("stepToRight");
		}
		else
		{
			if(y < centerBorder) changeCursor("goForward");
			else changeCursor(downKeyAction);
		}
	}

	function changeCursor(direct)
	{
		if(cursorDirect == direct) return;
		cursorDirect = direct;
		cursor = direct + ".cur";
	}

	function drawControllerLine()
	{
		// 分割線を描画する
		var col = 0x80FF0000;
		var upper = sideBorder, lower = centerBorder;
		if(upper > lower) upper <-> lower;
		with(borderLayer)
		{
			.clear();
			.fillRect(leftBorder, centerBorder - 1, rightBorder - leftBorder, 2, col);
			.fillRect(leftBorder - 100, sideBorder - 1, 100, 2, col);
			.fillRect(rightBorder, sideBorder - 1, 100, 2, col);
			.fillRect(leftBorder - 1, upper - 100, 2, lower - upper + 200, col);
			.fillRect(rightBorder - 1, upper - 100, 2, lower - upper + 200, col);
			.visible = true;
		}
	}
}


class ControlButton extends Layer
{
	// 移動操作ボードに乗せるボタン

	var onButtonDownAction;
	var onButtonUpAction;
	var value;

	function ControlButton(par)
	{
		super.Layer(par.window, par);
		setSize(50, 50);
		fillRect(0, 0, width, height, 0xFFFFFFFF);
		opacity = 0;
		hitThreshold = 0;
		visible = true;
		type = ltDodge;
	}

	function finalize()
	{
		super.finalize();
	}

	function onMouseEnter()
	{
		opacity = 192;
		super.onMouseEnter();
	}

	function onMouseLeave()
	{
		opacity = 0;
		super.onMouseLeave();
	}

	function onMouseDown(x, y, button, shift)
	{
		parent.onButtonDownAction(button, value);
		super.onMouseDown(...);
	}

	function onMouseUp(x, y, button)
	{
		parent.onButtonUpAction(button, value);
		super.onMouseUp(...);
	}
}


class ControlBoard extends DecoLayer
{
	// 移動操作ボード

	var master;
	var buttons = [];	// ボタン

	function ControlBoard(par, master)
	{
		super.DecoLayer(par);
		name = "移動操作ボード";
		this.master = master;
		loadImages("frame_control_back");

		for(var i = 0; i < 6; i++)
		{
			buttons[i] = new ControlButton(this);
		}
		buttons[0].setPos( 54,  2);
		buttons[0].value = "goForward";
		buttons[1].setPos( 54, 54);
		buttons[1].value = "goBackward";
		buttons[2].setPos(  2,  2);
		buttons[2].value = "turnLeft";
		buttons[3].setPos(106,  2);
		buttons[3].value = "turnRight";
		buttons[4].setPos(  2, 54);
		buttons[4].value = "stepToLeft";
		buttons[5].setPos(106, 54);
		buttons[5].value = "stepToRight";
	}

	function finalize()
	{
		for(var i = 0; i < buttons.count; i++) invalidate buttons[i];
		super.finalize();
	}

	function onButtonDownAction(button, value)
	{
		if(master.dungeonView.walkTimer.enabled) return;
		if(button == mbLeft) master.walk(value);
	}

	function onButtonUpAction(button, value)
	{
		if(button == mbLeft) master.dungeonView.stopWaitingStartRepeat();
		else if(button == mbRight) window.onPrimaryRightClick();
	}

	function changeDownKey(funcName)
	{
		if(funcName == "turnAround") loadImages("frame_control_turn");
		else loadImages("frame_control_back");
		buttons[1].value = funcName;
	}
}


class PartsLayer extends Layer
{
	// ビュー画面を構成する各パーツを作成

	var suffix = "";	// 接尾辞
	var img = "_";	// 読み込まれている画像ファイル
	var flip = false;	// 反転して表示するパーツかどうか
	var masked = false;	// 現在マスクされているかどうか（サブクラスで利用）

	function PartsLayer(par, suf, w, h, x, y, z, anim = false, flp = false)
	{
		super.Layer(par.window, par);
		setSize(w, h);
		setPos(x, y);
		absolute = z;
		setImageSize(w * (anim ? 5 : 1), h);
		hitThreshold = 256;
		if(suf !== void) suffix = "_" + suf;
		flip = flp;
	}

	function load(v)
	{
		// ここに画像ファイル名を指定するとパーツ画像を読み込む
		// 無効な画像名なら非表示にする
		// 画像読込み回数を減らすように工夫しないとアニメが遅くなるので注意

		if(v === void)
		{
			visible = false;
			return;
		}

		if(! Storages.isExistentStorage(v + suffix + ".png"))
		{
			if(! Storages.isExistentStorage(PROXY[v] + suffix + ".png"))
			{
				visible = false;
				return;
			}
			v = PROXY[v];
		}

		visible = true;

		if(img != v || masked)
		{
			loadImages(v + suffix);
			if(flip) flipLR();
			img = v;
			masked = false;
		}
	}
}


class WallLayer extends PartsLayer
{
	// 壁を作成。マスクを利用したり屋外で背の高いパーツを使えたりする

	var mask = "_";	// 読み込まれているマスクファイル
	var maskLayer;	// マスク画像を保持するレイヤー

	function WallLayer(par, suf, w, h, x, y, z, anim = false, flp = false, useMask = false)
	{
		super.PartsLayer(...);
		if(useMask)
		{
			maskLayer = new global.Layer(window, this);
			maskLayer.setSize(w, h);
			maskLayer.setImageSize(w * (anim ? 5 : 1), h);
			maskLayer.hitThreshold = 256;
		}
	}

	function finalize()
	{
		invalidate maskLayer;
		super.finalize();
	}

	function loadMask(v)
	{
		if(! Storages.isExistentStorage(v + "_m" + suffix + ".png")) return;
		if(mask != v)
		{
			maskLayer.loadImages(v + "_m" + suffix);
			if(flip) maskLayer.flipLR();
			mask = v;
		}
		clipAlphaRect(0, 0, maskLayer, 0, 0, imageWidth, imageHeight);
		masked = true;
	}

	function load(v, short)
	{
		// "_h" を付けた名前を指定すると屋内では "_h" 抜きの画像が読み込まれる
		if(short && v !== void && v.substr(v.length - 2, 2) == "_h")
		{
			v = v.substr(0, v.length - 2);
		}
		super.load(v);
	}
}


class TouchableObject extends Layer
{
	// ダンジョン内で触ってイベントを起こせるオブジェクトのレイヤー
	// オブジェクト画像は正面壁レイヤーのサイズ 820 x 680 で作る
	// 領域画像の当たり判定は目的のオブジェクトの
	// 左上座標から (-24, 2)  右下座標から (-4, 28) の範囲に設定する
	// （カーソルのホットスポットが何故か左下にあるため）

	var isButton = false;	// ボタンなら押した瞬間画像が変化する

	function TouchableObject(par, master)
	{
		super.Layer(par.window, par);
		name = "触れるオブジェクト";
		this.master = master;
		hitType = htProvince;
		hitThreshold = 256;	// touchable プロパティで必要になる
		cursor = "pushbutton.cur";
	}

	property touchable
	{
		setter(v){ hitType = v ? htProvince : htMask; }
	}

	function loadImages(storage)
	{
		if(Storages.isExistentStorage(storage + "_click.png")) super.loadImages(storage + "_click");
		else super.loadImages("default_click");
		if(! Storages.isExistentStorage(storage + "_click_p.png"))
		{
			storage = PROXY[storage];
			if(storage === void) return;
		}
		loadProvinceImage(storage + "_click_p.png");
	}

	function touchObject()
	{
		if(isButton) imageLeft = -width;
		master.checkClickObject();
	}

	function releaseObject()
	{
		if(isButton) imageLeft = 0;
	}

	function onMouseDown(x, y, button, shift)
	{
		if(button == mbLeft) touchObject();
		super.onMouseDown(...);
	}

	function onMouseUp(x, y, button, shift)
	{
		if(button == mbLeft) releaseObject();
		else if(button == mbRight) window.onPrimaryRightClick();
		super.onMouseUp(...);
	}
}


class ViewLayer extends Layer
{
	// 位置情報からダンジョンのビュー（景色）画面を作成

	/*
	＜フィールドオブジェクトの名称＞
		     front
		  left ▲ right
		      back
		floor: 床    roof: 天井

		d4  c4  b4  a4  B4  C4  D4
		d3  c3  b3  a3  B3  C3  D3
		d2  c2  b2  a2  B2  C2  D2
		    c1  b1  a1  B1  C1
		        b0 (a0) B0
	*/

	// 正面壁レイヤー
	var wall_front_a0, wall_front_a1, wall_front_a2, wall_front_a3
	 ,wall_front_b0, wall_front_b1, wall_front_b2, wall_front_b3
	 ,wall_front_B0, wall_front_B1, wall_front_B2, wall_front_B3
	 ,wall_front_c1, wall_front_c2, wall_front_c3, wall_front_C1, wall_front_C2, wall_front_C3
	 ,wall_front_d2, wall_front_d3, wall_front_D2, wall_front_D3;

	// 左の壁レイヤー
	var wall_left__a0, wall_left__a1, wall_left__a2, wall_left__a3, wall_left__a4
	 ,wall_left__b1, wall_left__b2, wall_left__b3, wall_left__b4
	 ,wall_left__c2, wall_left__c3, wall_left__c4
	 ,wall_left__a5, wall_left__b5, wall_left__c5;

	// 右の壁レイヤー
	var wall_right_a0, wall_right_a1, wall_right_a2, wall_right_a3, wall_right_a4
	 ,wall_right_B1, wall_right_B2, wall_right_B3, wall_right_B4
	 ,wall_right_C2, wall_right_C3, wall_right_C4
	 ,wall_right_a5, wall_right_B5, wall_right_C5;

	// 床レイヤー
	var floor_a0, floor_a1, floor_a2, floor_a3, floor_a4
	 ,floor_b0, floor_b1, floor_b2, floor_b3, floor_b4, floor_B0, floor_B1, floor_B2, floor_B3, floor_B4
	 ,floor_c1, floor_c2, floor_c3, floor_c4, floor_C1, floor_C2, floor_C3, floor_C4
	 ,floor_d2, floor_d3, floor_d4, floor_D2, floor_D3, floor_D4;

	// 置物レイヤー
	var put_a0, put_a1, put_a2, put_a3, put_a4
	 ,put_b0,put_b1, put_b2, put_b3, put_b4, put_B0, put_B1, put_B2, put_B3, put_B4
	 ,put_c2, put_c3, put_c4, put_C2, put_C3, put_C4 ,put_d3 ,put_D3 ,put_d4 ,put_D4;

	// 特殊な置物レイヤー（演出用）
	var put_ex;

	// 正面壁貼付レイヤー
	var hang_front_a0, hang_front_a1, hang_front_a2, hang_front_a3
	 ,hang_front_b0, hang_front_b1, hang_front_b2, hang_front_b3
	 ,hang_front_B0, hang_front_B1, hang_front_B2, hang_front_B3
	 ,hang_front_c1, hang_front_c2, hang_front_c3, hang_front_C1, hang_front_C2, hang_front_C3
	 ,hang_front_d2, hang_front_d3, hang_front_D2, hang_front_D3;

	// 左の壁貼付レイヤー
	var hang_left__a0, hang_left__a1, hang_left__a2, hang_left__a3
	 ,hang_left__b1, hang_left__b2, hang_left__b3
	 ,hang_left__c2, hang_left__c3;

	// 右の壁貼付レイヤー
	var hang_right_a0, hang_right_a1, hang_right_a2, hang_right_a3
	 ,hang_right_B1, hang_right_B2, hang_right_B3
	 ,hang_right_C2, hang_right_C3;

	// 屋根レイヤー
	var roof;

	// 床と屋根の影レイヤー
	var shadow_floor;
	var shadow_roof;

	// 透視を防止する壁
	var scopeGuard;

	// ダークゾーン・網レイヤー（拡縮をしないのでこれらは別途合成する）
	var darkZone;
	var duelNet;

	// 現在、屋根のあるところを描画しようとしているかどうかを保存するフラグ
	var ceiling = false;

	// 現在、水面の直下を描画しようとしているかどうかを保存するフラグ
	var underSurface = false;

	function ViewLayer(par)
	{
		super.Layer(par.window, par);
		name = "ViewLayer";
		focusable = false;
		visible = false;
		setPos(0, 0);
		setSize(1020, 680);

		wall_left__a0 = new WallLayer(this, "side_a0" , 360, 680,   0, 0, 980,,, true);
		wall_right_a0 = new WallLayer(this, "side_a0" , 360, 680, 660, 0, 980,, true, true);
