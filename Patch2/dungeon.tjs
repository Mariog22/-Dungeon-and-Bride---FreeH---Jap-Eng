	function shiftWallImage(n)
	{
		// アニメの際に影の位置を調整した別のパターンに切り替える

		shadow_floor.imageTop = -150 * n;
		shadow_roof.imageTop  = -350 * n;
		wall_left__a2.imageLeft = -140 * n;
		wall_left__a3.imageLeft = -100 * n;
		wall_left__a4.imageLeft = - 70 * n;
		wall_left__b2.imageLeft = -240 * n;
		wall_left__b3.imageLeft = -130 * n;
		wall_left__b4.imageLeft = - 80 * n;
		wall_left__c2.imageLeft = -130 * n;
		wall_left__c3.imageLeft = -170 * n;
		wall_left__c4.imageLeft = -110 * n;
		if(floor_a3.imageWidth == 1100) floor_a3.imageLeft = -220 * n;
		if(floor_b2.imageWidth == 1900) floor_b2.imageLeft = -380 * n;
		if(floor_b3.imageWidth == 1300) floor_b3.imageLeft = -260 * n;
		if(floor_c2.imageWidth == 1350) floor_c2.imageLeft = -270 * n;
		if(floor_c3.imageWidth == 1350) floor_c3.imageLeft = -270 * n;
		if(floor_d2.imageWidth ==  450) floor_d2.imageLeft = - 90 * n;
		if(floor_d3.imageWidth == 1000) floor_d3.imageLeft = -200 * n;
		n = 4 - n;
		wall_right_a2.imageLeft = -140 * n;
		wall_right_a3.imageLeft = -100 * n;
		wall_right_a4.imageLeft = - 70 * n;
		wall_right_B2.imageLeft = -240 * n;
		wall_right_B3.imageLeft = -130 * n;
		wall_right_B4.imageLeft = - 80 * n;
		wall_right_C2.imageLeft = -130 * n;
		wall_right_C3.imageLeft = -170 * n;
		wall_right_C4.imageLeft = -110 * n;
		if(floor_B2.imageWidth == 1900) floor_B2.imageLeft = -380 * n;
		if(floor_B3.imageWidth == 1300) floor_B3.imageLeft = -260 * n;
		if(floor_C2.imageWidth == 1350) floor_C2.imageLeft = -270 * n;
		if(floor_C3.imageWidth == 1350) floor_C3.imageLeft = -270 * n;
		if(floor_D2.imageWidth ==  450) floor_D2.imageLeft = - 90 * n;
		if(floor_D3.imageWidth == 1000) floor_D3.imageLeft = -200 * n;
	}

