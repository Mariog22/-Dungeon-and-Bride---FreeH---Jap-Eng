@eval exp='tf.result = void, tf.num = 0'
@eval exp='tf.num += 4' cond='o.サキュバス.contracted'
@eval exp='tf.num += 2' cond='o.エルダーサキュバス.contracted'
@eval exp='tf.num += 1' cond='o.見習いサキュバス.contracted'
[baroff cond='tf.num == 0']
@command type=long title="Do you want to summon a succubus?"
@select text="Summon Succubus" exp='tf.result = "girl"' cond='tf.num >= 4'
@select text="Summon Elder Succubus" exp='tf.result = "adult"' cond='tf.num % 4 >= 2'
@select text="Summon Apprentice Succubus" exp='tf.result = "baby"' cond='tf.num % 2 == 1'
@select text="Summon every succubus" exp='tf.result = "all"' cond='tf.num == 7'
@select text="Don't summon one"
[ask]
[baroff cond='tf.result === void']

