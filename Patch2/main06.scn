[iscript]

// ここでは、リーゼルとデートできる状態にする

// キャラ
game.party.ejectItem(o.リーゼルの髪飾り);
game.temporaryBox.ejectItem(o.リーゼルの髪飾り);
game.trunkRoom.ejectItem(o.リーゼルの髪飾り);
game.lockerRoom.ejectItem(o.リーゼルの髪飾り);

o.テオ.removeEquipmentsByForce();
o.テオ.dressEquipment(o.主人公の私服);
o.テオ.dressEquipment(o.トランクス);
o.テオ.updateByChangeEquipment();

o.リーゼル.removeEquipmentsByForce();
o.リーゼル.dressEquipment(o.リーゼルの私服);
o.リーゼル.dressEquipment(o.白いブラ);
o.リーゼル.dressEquipment(o.白いパンツ);
o.リーゼル.updateByChangeEquipment();
o.リーゼル.moveHeart(o.テオ, 20);

for(var i = game.party.members.count - 1; i >= 0; i--)
{
	var one = game.party.members[i];
	one.recovery();
	if(one != o.リーゼル && one != o.テオ) game.removeMemberTemporary(one);
}
game.guest.eraseHiring();

