@monster pos=1 name=ブルースライム
@monster pos=2 name=レッドスライム
@monster pos=3 name=スライム
@monster pos=4 name=ゴーストスライム
@monster pos=5 name=ブラックスライム
@monster pos=6 name=マジカルスライム
@monster pos=10 name=ジャンボスライム
@call target=*match_start

; 勝利
[texton]
[name n=Commentator]「Congratulations on winning the first round! Please wait until the second round begins.」[k]
[textoff]
@out
@w1
@bg f=0023
@mu f=city
[texton]
[   if exp='HUM'][リム v=vh023 f=03]「We did it, Captain!」[k]
[elsif exp='ELF'][クレア v=ve024 f=01]「We won! Captain!」[k]
[elsif exp='DWA'][フレデリカ v=vd023 f=03]「We did it, Captain!」[k]
[elsif exp='GNO'][ミューズ v=vg016 f=01]「You won... Captain...!」[k]
[elsif exp='SYL'][マルエット v=vs025 f=01]「We won! Captain!」[k]
[endif]
[テオ f=01]「Let's keep winning at this pace!」[k]
[textoff]
