class CharaEditBoard extends BoardLayer
{
	// キャラエディットを作るクラス

	var parameters = [];
	var jobCommands = [];
	var sampleLayer;
	var nameEdit;	// エディット
	var modelSelect;
	var colorSelect;
	var alignmentSelect;
	var bonusLayer;
	var bonusPoint = 0;
	var initialBonus = 0;
	var jobBoard;
	var nameBoard;
	var modelBoard;
	var sexBoard;
	var detailBoard;
	var cautionBoard;
	var randomButton;

	function CharaEditBoard(par, master)
	{
		super.BoardLayer(...);
		name = "Edit Character";
		adjustX = 1;
		adjustY = 100;
		//font.face = "ＭＳ 明朝";
		font.bold = true;
		font.height = 27;
		loadImages("back_charaedit");
		setSizeToImageSize();
		hitThreshold = 256;

		sampleLayer = new DecoLayer(this);
		with(sampleLayer)
		{
			.setPos(-20, 0);
			.setSize(420, 768);
			.visible = true;
		}

		bonusLayer = new DecoLayer(this);
		with(bonusLayer)
		{
			.loadImages("frame_bonus");
			.setPos(769, 210);
			.visible = true;
			.font.height = 72;
			.font.face = "Tahoma";
			.font.bold = true;
		}

		detailBoard = new DetailBoard(this, master);
		with(detailBoard)
		{
			.setPos(742, 376);
			.visible = true;
		}

		cautionBoard = new global.TextWindow(this, master);
		with(cautionBoard)
		{
			.setPos(760, 168);
			.setSize(240, 60);
			.marginL = 3;
			.marginR = 3;
			.marginT = 3;
			.marginB = 3;
			.lineSpacing = 2;
			.visible = true;
			.font.height = 16;
			//.font.face = "Tahoma";
			.font.bold = true;
		}

		nameEdit = new EditLayerOnBoard(this);
		with(nameEdit)
		{
			.font.height = 24;
			.setPos(539, 50);
			.setSize(9 * 24 + 7, 30);	// 幅はこれ以上小さくしてはならない
			.visible = true;
			.selectable = true;
		}
		targetLayers.add(nameEdit);

		nameBoard = new DecoLayer(this);
		with(nameBoard)
		{
			.setPos(560, 52);
			.setSize(256, 30);
			.visible = true;
			.font.height = 26;
		}

		randomButton = new LightCommandButton(this);
		with(randomButton)
		{
			.loadImages("btn_random");
			.setPos(805, 49);
			.visible = true;
			.onSelectAction = setRandomName;
		}
		targetLayers.add(randomButton);

		modelSelect = new SelectModelSpinButton(this);
		with(modelSelect)
		{
			.valueLength = 6;
			.loadImages("spinbtn");
			.setPos(530, 106);
			.onChangeAction = setModel;
			.detailRef = detailBoard;
		}
		targetLayers.add(modelSelect);

		modelBoard = new DecoLayer(this);
		with(modelBoard)
		{
			.setSize(256, 32);
			.setPos(560, 111);
			.visible = true;
			.font.height = 26;
			.detailRef = detailBoard;
		}

		sexBoard = new DecoLayer(this);
		with(sexBoard)
		{
			.setSize(32, 32);
			.setPos(910, 109);
			.visible = true;
			.font.height = 30;
		}

		colorSelect = new ArraySpinButton(this);
		with(colorSelect)
		{
			.loadImages("spinbtn");
			.setPos(530, 165);
			.onChangeAction = setColor;
		}
		targetLayers.add(colorSelect);

		alignmentSelect = new SelectAlignmentSpinButton(this);
		with(alignmentSelect)
		{
			.name = "alignment";
			.loadImages("spinbtn");
			.setPos(530, 224);
			.array = master.alignment;
			.onChangeAction = setAlignment;
			.detailRef = detailBoard;
		}
		targetLayers.add(alignmentSelect);

		var paramKey = ["power", "intellect", "piety", "vitality", "speed", "luck"];
		var paramDetail = [
			 "Affects hit chance"
			,"Affects spirit & alchemy magic learning speed and MP growth,<r>magic success rate,<r>identification chance"
			,"Affects holy & summoning magic learning speed and MP growth,<r>status resistance,<r>purification chance"
			,"Affects HP growth and<r>resurrection success<r>chance"
			,"Affects action order<r>and disarm/unlock<r>success chance"
			,"Affects trap evasion<r>rate and resistance to<r>special attacks and more"
		];
		for(var i = 0; i < paramKey.count; i++)
		{
			parameters[i] = new AdjustParamSpinButton(this);
			with(parameters[i])
			{
				.name = paramKey[i];
				.paramDetail = paramDetail[i];
				.loadImages("spinbtn");
				.setPos(530, 283 + 40 * i);
				.onChangeAction = setParameter;
				.detailRef = detailBoard;
			}
			targetLayers.add(parameters[i]);
		}

		jobBoard = new JobCommandBoard(this, master);
		with(jobBoard)
		{
			.name = "職業ボード";
			.setPos(431, 541);
			.absolute = 1;
			.cmdParent = this;
			.detailRef = detailBoard;
			.visible = true;
		}
	}

	function finalize()
	{
		invalidate sampleLayer;
		invalidate bonusLayer;
		invalidate jobBoard;
		invalidate detailBoard;
		invalidate nameEdit;
		invalidate modelSelect;
		invalidate nameBoard;
		invalidate randomButton;
		invalidate modelBoard;
		invalidate sexBoard;
		invalidate colorSelect;
		invalidate alignmentSelect;
		for(var i = 0; i < parameters.count; i++) invalidate parameters[i];
		super.finalize();
	}

	function open()
	{
		super.open();
		master.setPrev(checkBonusPoint);
		master.setPrev();

		// ボーナスポイント
		initialBonus = bonusPoint = getBonusPoint();

		// 属性選択を初期化
		alignmentSelect.setControl(2);

		// 素体選択を初期化
		modelSelect.array = master.getEditableModels();
		// Use the last race selected, if there was one.
		var modelId = (!modelSelect.value)? 0 : Math.max(0, modelSelect.array.find(modelSelect.value));
		modelSelect.setControl(modelId);
		setModel(modelSelect.array[modelId]);
		modelSelect.visible = true;
		modelBoard.visible = false;

		// 説明欄を初期化
		detailBoard.clear();

		// 名前欄にフォーカス
		nameEdit.focus();
		nameBoard.visible = false;
		randomButton.visible = true;
		jobBoard.visible = true;
	}

	function continueEdit()
	{
		// キャンセルしようとしたのをやめて作成を続ける
		master.yesNoWin.close();
		enabled = true;
	}

	function cancelEdit()
	{
		// 警告を無視してキャンセルする
		master.yesNoWin.close();
		enabled = true;
		master.popPrev();
		master.popPrev();
		master.processPrev();	// ギルドメニューへ
	}

	function checkBonusPoint()
	{
		// キャンセルする前にＢＰをチェックして高いＢＰだった場合は問い合わせる
		if(bonusPoint < sf.thresholdOfBonusNotified)
		{
			master.processPrev();	// ギルドメニューへ
			return;
		}
		playSound("buzzer");
		enabled = false;
		master.setPrev(continueEdit);
		master.setPrev();
		var cmds = [];
		cmds.add(%[text: "Edit", func: master.processPrev]);
		cmds.add(%[text: "Cancel", func: cancelEdit]);
		master.yesNoWin.open(cmds, "<y>Bonus points are high. Continue editing?");
	}

	function setModel(dic)
	{
		// 使用する素体を選択する
		bonusPoint = initialBonus;	// ボーナスを元に戻す
		updateBonusLayer();
		jobBoard.clearJobCommands();	// 職業欄を初期化
		setRandomName(dic); // Custom: Might as well use this rather than a translated default JP name.
		sampleLayer.loadImages(dic.img + "_sample_" + dic.color[0]);

		// 色を設定
		colorSelect.array = [];
		for(var i = 0; i < dic.color.count; i++)
		{
			colorSelect.array.add(%[name: dic.color[i], key: dic.color[i]]);
		}
		colorSelect.setControl(0);	// 初期化

		// 性別表示
		sexBoard.clear();
		sexBoard.drawText(0, 0, master.sexSymbol(dic.sex)
			, 0xC0C0FF + (dic.sex == "女") * 0x3EFFC1,,, 2048, 0x002244, 2);

		// パラメータを種族に合わせた表示に
		parameters[0].value = dic.power;
		parameters[1].value = dic.intellect;
		parameters[2].value = dic.piety;
		parameters[3].value = dic.vitality;
		parameters[4].value = dic.speed;
		parameters[5].value = dic.luck;
		for(var i = 0; i < 6; i++)
		{
			parameters[i].min = parameters[i].value;
			parameters[i].max = parameters[i].value + 10;	// 種族基本値 + 10（後で変えるかも）
			parameters[i].setControl(parameters[i].value);
			parameters[i].enabled = true;
		}

		// 現時点でなれる職業があれば表示
		displayPossibleJob();

		return true;
	}

	function setRandomName(model=null)
	{
		// ランダムな名前を名前欄に入力する
		model = modelSelect.value if(model === null);
		var arr = [];
		var str = model.sex == "男" ? sampleMaleNames : sampleFemaleNames;
		arr.split(",", str);
		arr.remove(nameEdit.text);	// 続けて同じ名前を出さないため現在の名前は除外しておく
		nameEdit.text = arr.draw();
	}

	function fixName(name)
	{
		// 名前を固定してメイキングするとき
		nameEdit.text = name;
		nameBoard.clear();
		nameBoard.drawText(0, 0, name, 0xFFFFFF,,, 2048, 0x002244, 2);
		nameBoard.visible = true;
		nameEdit.visible = false;
		randomButton.visible = false;
	}

	function fixModel(dic)
	{
		// 素体を固定してメイキングするとき
		setModel(dic);
		modelSelect.value = dic;
		modelBoard.clear();
		modelBoard.drawText(0, 0, dic.race.displayName, 0xFFFFFF,,, 2048, 0x002244, 2);
		modelBoard.visible = true;
		modelSelect.visible = false;
	}

	function setColor(val, btn)
	{
		// 髪の色を選択する
		var dic = modelSelect.value;
		colorSelect.value = val.key;
		sampleLayer.loadImages(dic.img + "_sample_" + val.key);
		return true;
	}

	function setAlignment(val, btn)
	{
		// 属性を選択する
		alignmentSelect.value = val;	// ジョブを出すために先に入れる
		displayPossibleJob();
		return true;
	}

	function setParameter(val, meter)
	{
		// 能力値を設定する
		var d = meter.value - val;
		if(bonusPoint + d < 0)
		{
			playSound("buzzer");
			return false;
		}
		bonusPoint += d;
		updateBonusLayer();
		meter.value = val;	// ジョブを出すために先に入れる
		displayPossibleJob();
		return true;
	}

	function closeConfirmView()
	{
		// 作成をキャンセル
		master.yesNoWin.close();
		master.itemWin.close();
		visible = true;
		master.itemWin.curChara = void;	// 作成中のキャラでステータスを開いた後始末
	}

	function setJobAndConfirm(job)
	{
		// 職業を決定して仮作成キャラ表示後ユーザーに最終確認

		// ボーナスポイントのチェック
		if(bonusPoint > 0)
		{
			playSound("buzzer");
			master.notice.open();
			master.notice.write("Bonus points remain");
			return;
		}

		// 名前入力のチェック
		if(nameEdit.text.length == 0)
		{
			playSound("buzzer");
			master.notice.open();
			master.notice.write("<y>No name entered");
			return;
		}

		// 仮作成キャラ表示
		visible = false;
		master.setPrev(closeConfirmView);
		master.setPrev();
		var obj =  createChara(job);
		master.itemWin.openStatus(obj, "single");

		// 最終確認
		var cmds = [];
		cmds.add(%[text: "Yes", func: registerChara, param: obj]);
		cmds.add(%[text: "No", func: master.processPrev]);
		master.yesNoWin.open(cmds, "Create <p>" + obj.name + "<y>?");
		master.yesNoWin.setPos(245, 543);
	}

	function displayPossibleJob()
	{
		// 就職可能な職業を表示

		// 一覧取得
		var arr = getJobsFromControls();

		// チェックと警告
		if(arr.count == 0) displayCaution("Change alignment and<r>stats to select jobs");
		else if(bonusPoint > 0) displayCaution("Allocate all points");
		else displayCaution("Please pick a job");

		// 表示
		jobBoard.open(arr, setJobAndConfirm);
	}

	function getJobsFromControls()
	{
		// 各コントロールの結果から就業可能な職業をすべて返す
		var dic = %[];
		dic.sex = modelSelect.value.sex;
		dic[alignmentSelect.name] = alignmentSelect.value;
		for(var i = 0; i < parameters.count; i++)
		{
			dic[parameters[i].name] = parameters[i].value;
		}
		return getJobsMeetRequirement(dic);
	}

	function getJobsMeetRequirement(dic)
	{
		// 条件を満たしている職業をすべて返す
		var arr = [];
		for(var i = 0; i < master.job.count; i++)
		{
			var jb = master.job[i];
			if(jb.sex.find(dic.sex) == -1) continue;
			if(jb.alignment.find(dic.alignment) == -1) continue;
			if(jb.power > dic.power) continue;
			if(jb.intellect > dic.intellect) continue;
			if(jb.piety > dic.piety) continue;
			if(jb.vitality > dic.vitality) continue;
			if(jb.speed > dic.speed) continue;
			if(jb.luck > dic.luck) continue;
			if(! jb.appeared) jb.appeared = true;	// 発見おめでとう
			arr.add(jb);
		}
		return arr;
	}

	function updateBonusLayer()
	{
		// ボーナスポイント表示
		bonusLayer.clear();
		bonusLayer.drawText(60 + 24 * (bonusPoint < 10), 48, bonusPoint, 0xC9FFDF);
	}

	function getBonusPoint()
	{
		// ボーナスポイントの式。書いてみると結構シンプル
		var base = 6;
		var rate = 0.1;	// この値を大きくするとでかいボーナスが出やすくなる
		while(true)
		{
			if(base > 50 || random > rate) return base + intrandom(0, 4);
			base += 10;
		}
	}

	function displayCaution(str)
	{
		// 各種警告を表示する
		cautionBoard.clear();
		if(str === void) return;
		cautionBoard.chColor = 0xFFA080;
		cautionBoard.write(str);
	}

	function createChara(job)
	{
		// キャラクターを作成

		// 空いてる番号を探す
		var num = master.chara.count;
		for(var i = 0; i < num; i++)
		{
			if(master.chara[i] !== void) continue;
			num = i;
			break;
		}

		// 作成
		var obj = new CharaObject(master.gameBase, master, num);
		with(obj)
		{
			// エディットの結果を代入
			.name = master.convertName(nameEdit.text);
			.displayName = nameEdit.text;
			.alignment = alignmentSelect.value;
			.model = modelSelect.value;
			.color = colorSelect.value.key;
			.power = parameters[0].value;
			.intellect = parameters[1].value;
			.piety = parameters[2].value;
			.vitality = parameters[3].value;
			.speed = parameters[4].value;
			.luck = parameters[5].value;
			.setJob(job, true);
		}
		obj.initialize();	// キャラ初期化
		obj.setInitialItems();	// 初期アイテムを持たせる
		if(sf.usedJobsByCreating.find(job.name) == -1) sf.usedJobsByCreating.add(job.name);	// 記録
		return obj;
	}

	function registerChara(obj)
	{
		// 登録
		master.itemWin.close();
		master.popPrev();
		master.popPrev();
		master.yesNoWin.close();
		playSound("click");
		master.notice.open(master.processPrev);
		master.notice.write("<p>" + obj.name + "<y> was created");
		obj.activate();
		master.chara[obj.id] = obj;
		master.guildWin.addMember(obj);
		if(master.inEvent) kag.trigger("registerNewCharactor");	// シナリオ用
	}
}
//----------------------------------------------------------------------------------------
