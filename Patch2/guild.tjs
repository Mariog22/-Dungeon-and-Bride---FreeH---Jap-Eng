class JobCommandBoard extends CommandBoard
{
	// 職業ボード

	var jobCommands = [];
	var cmdParent;
	var detailRef;	// 詳細表示レイヤーへの参照

	function JobCommandBoard(par, master)
	{
		super.CommandBoard(...);
		loadImages("frame_joblist");
		absolute = 1;
		marginL = 25;
		marginT = 18;
		cover.visible = false;
		hitThreshold = 256;
	}

	function finalize()
	{
		for(var i = 0; i < jobCommands.count; i++) invalidate jobCommands[i];
		super.finalize();
	}

	function open(jobs, func)
	{
		// 職業一覧を表示
		if(notification) master.notifyWindowOpened(this);
		visible = true;
		clearJobCommands();
		if(jobs.count == 0)
		{
			displayInstructionAtNoJob();
			return;
		}
		var l = 0, t = 0;
		if(cmdParent == parent)
		{
			l = left;
			t = top;
		}
		for(var i = 0; i < jobs.count; i++)
		{
			var cmd = new JobCommandButton(cmdParent, detailRef);
			var num = jobCommands.count;
			cmd.setPos(i % 3 * 180 + l + marginL, i \ 3 * 35 + t + marginT);
			cmd.onSelectAction = func;
			cmd.onSelectActionParam = jobs[i];
			cmd.absolute = absolute + 1;
			write(jobs[i].displayName, cmd.left - l + 8, cmd.top - t + 5);
			jobCommands.add(cmd);
			cmdParent.targetLayers.add(cmd);
		}
	}

	function close()
	{
		clearJobCommands();
		if(notification) master.notifyWindowClosed(this);
		visible = false;
	}

	function clearJobCommands()
	{
		// 職業一覧をクリア
		for(var i = 0; i < jobCommands.count; i++)
		{
			cmdParent.targetLayers.remove(jobCommands[i]);
			jobCommands[i].selectable = false;
			jobCommands[i].visible = false;
		}
		jobCommands = [];
		clear();
	}

	function displayInstructionAtNoJob()
	{
		// 職業が表示されていないときに代わりに注意書きを表示する
		var defaultFontSize = font.height;
		clear();
		font.height = 20;
		chColor = 0xD0D0D0;
		write(
			"Available jobs are based on alignment, stats, and<r>extra conditions.<r>"
			 + "Example jobs include:<r>"
			 + "    Warrior: Strength >= 11<r>"
			 + "    Mage: Intelligence >= 11<r>"
			 + "    Priest: Faith >= 11, non-neutral alignment<r>"
			 + "    Thief: Speed >= 10, Luck >= 12<r>"
			 + "<r>"
		, 10, 20);
		chColor = 0xFFFFFF;
		font.height = defaultFontSize;
	}
}


