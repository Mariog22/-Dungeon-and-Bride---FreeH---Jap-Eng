}

property LIS2
{
	getter{ if(o.リーゼル２ === void) return false;  return true; }
}

// その他便利な関数
function isArrowButton(key, shift)
{
	if(shift != 0 && shift != ssRepeat) return false;
	return key == BT_UP || key == BT_DOWN || key == BT_LEFT || key == BT_RIGHT
			 || key == BT_UP2 || key == BT_DOWN2 || key == BT_LEFT2 || key == BT_RIGHT2;
}

