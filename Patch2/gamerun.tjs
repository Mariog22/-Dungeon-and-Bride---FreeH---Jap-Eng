// ダンジョンパーツの代替画像名
// パーツ用レイヤーに指定された画像がなければ代替画像を使う
var PROXY = %[];
var lines = csvToArray("_proxy.tsv", true);
for(var i = 0; i < lines.count; i++) PROXY[lines[i][0]] = lines[i][1];
delete lines;

// 装備の耐久度
const WHOLE = 12;
const BROKEN = 6;
const G_WHOLE = 24;	// ゲストは装備が実質１つしかないので耐久力を多めにする
const G_BROKEN = 12;
const G_PIECE = 6;
const G_FLYING = 100;	// 100 以上はすべて浮遊状態とする
const G_SWIM = 99;
const G_TOWELF = 98;
const G_TOWEL = 97;
const G_NUDE = 96;

//（格闘が可能な）極端に軽い装備重量
const SLIGHT = 5;

// 妊娠していない初期状態
const NO_PREGNANCY = -20;

// プロパティ
property KEY_PRESSED
{
	getter
	{
		return System.getKeyState(BT_OK)     || System.getKeyState(BT_OK2)
			  || System.getKeyState(BT_CANCEL) || System.getKeyState(BT_CANCEL2)
			  || System.getKeyState(BT_OPTION) || System.getKeyState(BT_OPTION2)
			  || System.getKeyState(BT_LSTEP)  || System.getKeyState(BT_LSTEP2)
			  || System.getKeyState(BT_RSTEP)  || System.getKeyState(BT_RSTEP2)
			  || System.getKeyState(BT_MAP)    || System.getKeyState(BT_MAP2)
			  || System.getKeyState(BT_MAGIC)  || System.getKeyState(BT_MAGIC2)
			  || System.getKeyState(BT_ITEM)   || System.getKeyState(BT_ITEM2)
			  || System.getKeyState(BT_SAVE)   || System.getKeyState(BT_SAVE2) ;
	}
}

property MOUSE_HIDDEN
{
	getter
	{
		return kag.mouseCursorState == mcsTempHidden;
	}
}

property EARLY
{
	getter{ return game.hour == "early"; }
}

property DAY
{
	getter{ return game.hour == "day"; }
}

property SUNSET
{
	getter{ return game.hour == "sunset"; }
}

property NIGHT
{
	getter{ return game.hour == "night"; }
}

property MIDNIGHT
{
	getter{ return game.hour == "midnight"; }
}

property SLAVE
{
	getter{ return game.hour == "slave"; }
}

property MORNING
{
	getter{ return game.hour == "morning"; }
}

property WAY
{
	getter{ return game.party.curFront; }
}

property CX
{
	getter{ return game.party.curX; }
}

property CY
{
	getter{ return game.party.curY; }
}

property isHUM
{
	getter{ return game.curChara == o.リム; }
}

property isELF
{
	getter{ return game.curChara == o.クレア; }
}

property isDWA
{
	getter{ return game.curChara == o.フレデリカ; }
}

property isGNO
{
	getter{ return game.curChara == o.ミューズ; }
}

property isSYL
{
	getter{ return game.curChara == o.マルエット; }
}

property isLIS
{
	getter{ return game.curChara == o.リーゼル; }
}

property isTEO
{
	getter{ return game.curChara == o.テオ; }
}

property isMAX
{
	getter{ return game.curChara == o.マックス; }
}

property HUM
{
	getter{ if(! game.party.members.has(o.リム)) return false; game.curChara = o.リム; return true; }
}

property ELF
{
	getter{ if(! game.party.members.has(o.クレア)) return false; game.curChara = o.クレア; return true; }
}

property DWA
{
	getter{ if(! game.party.members.has(o.フレデリカ)) return false; game.curChara = o.フレデリカ; return true; }
}

property GNO
{
	getter{ if(! game.party.members.has(o.ミューズ)) return false; game.curChara = o.ミューズ; return true; }
}

property SYL
{
	getter{ if(! game.party.members.has(o.マルエット)) return false; game.curChara = o.マルエット; return true; }
}

property LIS
{
	getter{ if(! game.party.members.has(o.リーゼル)) return false; game.curChara = o.リーゼル; return true; }
}

property TEO
{
	getter{ if(! game.party.members.has(o.テオ)) return false; game.curChara = o.テオ; return true; }
}

property MAX
{
	getter{ if(! game.party.members.has(o.マックス)) return false; game.curChara = o.マックス; return true; }
}

property HUM2
{
	getter{ if(o.リム２ === void) return false;  return true; }
}

property ELF2
{
	getter{ if(o.クレア２ === void) return false;  return true; }
