}

//----------------------------------------------------------------------------------------
class SummonedObject extends HelperObject
{
	// 召喚モンスターを作るクラス

	var contracted = false;	// 契約済みかどうか

	function SummonedObject(par, master, id)
	{
		super.HelperObject(...);
		isHiring = true;
	}

	property detail
	{
		getter{ return displayName + " LV " + level + " summon"; }
	}

	function store()
	{
		var dic = super.store();
		dic.contracted = contracted;
		return dic;
	}

	function restore(dic)
	{
		if(dic === void) return;
		super.restore(dic);
		contracted = dic.contracted;
		if(visible) beSoftenImage();
	}

	function resetPos()
	{
		setPos(772, 40);
		absolute = 3;
	}

	function loadData(dic, i)
	{
		super.loadData(dic, i);
		magicLV = dic.magicLV;
		displayName = dic.displayName;
		if (displayName === void) {
		    displayName = name;
		}
	}

	function retire(statusObj)
	{
		// 戦闘不能にさせられた時の処理
		if(statusObj != o.死亡 && statusObj != o.灰) return;
		master.guest.removeMember(this);	// 消滅
		recovery();	// ここで回復しておく
		dead = false;
		parent.rearMemberToFrontPos();
	}

	function tryToBreakItem(hitScore, pow)
	{
		// モンスターが装備を壊されることはない
		return false;
	}

	function beHeatedUpByOthers()
	{
		// 何もしない
	}

	function clearStatusOnDungeonExit()
	{
		// ダンジョンから出たら消える
		master.guest.removeMember(this);	// 消滅
	}

	function goToSleep(inStable)
	{
		// ダンジョン内で睡眠を取る機会があったら消滅する
		master.guest.removeMember(this);
	}

	function isLevelUp()
	{
		// レベルアップできるかどうか返す
		if(! contracted) return false;
		return super.isLevelUp();
	}

	function speak(msg)
	{
		// ポップアップにセリフを表示する
		if(msg === void) return;
		master.wordsBase.open();
		master.wordsBase.popUpMessage(master.wordsBase.wordLayers.count - 1, msg,, true);
	}

	function isHipNaked()
	{
		// 股間が出ているどうかを返す
		return false;
	}

	//---------------------------------------------------------------------------
	// 召喚魔法コマンドとして使われる場合のメンバ

	var category = "smagic";
	var auto = false;
	var magicLV = 1;
	var range = -1;
	var anime = "*calling";
	var showCutIn = true;
	var displayName;
	var bootTrap = false;
	var bootEvent = true;
	var superior;
	var inferior;

	function cond()
	{
		return ! master.guest.members.has(this) && master.map.kind == "dungeon"
			 && (! master.map.underWater || data.skill.has(o.潜水));
	}

	function checkCurrentAction(owner)
	{
		if(owner !== void)
		{
			// 召喚魔法コマンドとして使われる場合
			return global.BattleCommand.checkCurrentAction(owner);
		}
		else
		{
			// 本人が行動する場合
			return super.checkCurrentAction();
		}
	}

	function useResource(res, owner)
	{
		// 行動に消費（アイテム、ＭＰ等）が必要な場合、消費する
		if(owner !== void)
		{
			// 召喚魔法コマンドとして使われる場合
			global.BattleCommand.useResource(res, owner);
		}
		else
		{
			// 本人が行動する場合
			return super.useResource();
		}
	}

	function isForbiddenByAntiMagic()
	{
		// アンチマジックの効果により行動が禁じられるかどうかを返す
		if(! master.party.status.has(o.禁止)) return false;
		return true;
	}

	function doDamage(self, target)
	{
		master.noReturnMenu = true;
		master.guest.summonMonster(this);
		master.party.exciteOtherMembers(this, 50);
		return "0,0x80FFFF,SUMMON";
	}

	function actionMessage(self, target)
	{
		return self.displayName + " summoned " + displayName + "!";
	}

	function resultMessage(target, value)
	{
		return displayName + " has joined the party!";
	}

	function affectedParam(key, value)
	{
		return value;	// 何もせずそのまま返す
	}

	function copyCommandToImitateSkill(copyAction)
	{
		// 指定したコマンドにこのモンスターの攻撃を設定する（憑依術）
		// なお、術者の位置に左右されないように攻撃距離は常に最大とする
		var cmd = btcmd[0] !== void ? btcmd[0] : o.召喚モンスター攻撃;
		copyAction.range = cmd.range;
		copyAction.toEnemy = cmd.toEnemy;
		copyAction.toGuest = cmd.toGuest;
		copyAction.anime = cmd.anime;
		copyAction.doDamage = cmd.doDamage;
		copyAction.resultMessage = cmd.resultMessage;
	}
}

//----------------------------------------------------------------------------------------
class HelperObject extends AutoActionObject
{
	// オートで動く補助メンバーを作るクラス

	var _trust = 0;	// 信頼度
	var formation = "fore";	// どちらの隊列につくか
	var charaLayer;	// 顔画像。全身画像から切り抜いたもの
	var lifeLayer;	// ライフ表示
	var figureLayer;	// 全身画像。カットインにも使う
	var faceWidth = 108;	// 顔画像の一辺の長さ
	var adjustLeft = -50;	// 肖像左端の微調整
	var newAbility = [];	// レベルアップ時に追加される能力
	var direction;	// プレイヤーから受けている大まかな指示
	var directionList = ["直接攻撃", "身を守る", "魔法優先", "スキル優先"];	// 選択できる指示

	function HelperObject(par, master, id)
	{
		super.AutoActionObject(...);
		super.loadImages("charaslot_guest");
		setSize(imageWidth \ 2, imageHeight);
		hitThreshold = 0;
		callOnPaint = true;
		isGuest = true;

		statusLayer.setPos(8, 10);
		statusLayer.setSize(66, 88);
		statusLayer.absolute = 110;

		charaLayer = new global.Layer(window, this);
		with(charaLayer)
		{
			.setSize(faceWidth, faceWidth);
			.setImageSize(faceWidth + 56, faceWidth + 56);	// 宿屋マーカーの転写元にもなっているので大きめに取る
			.setPos(10, 11);
			.setImagePos(-28, -28);
			.visible = true;
			.absolute = 5;
			.hitThreshold = 256;
		}

		figureLayer = new KAGLayer(window, master.gameBase);
		with(figureLayer)
		{
			.setSize(560, 768);
			.absolute = 1;
			.hitThreshold = 256;
		}

		lifeLayer = new DecoLayer(this);
		with(lifeLayer)
		{
			.frameGraphic = void;
			.setSize(100, 20);
			.setPos(18, 99);
			.font.height = 18;
			.absolute = 50;
			.visible = true;
		}

		darkCoverLayer.paintAll(charaLayer);
		darkCoverLayer.setPos(charaLayer.left, charaLayer.top);
		darkCoverLayer.hitThreshold = 256;
		lightingLayer.paintAll(charaLayer);
		lightingLayer.setPos(charaLayer.left, charaLayer.top);
		flashLayer.paintAll(charaLayer);
		flashLayer.setPos(charaLayer.left, charaLayer.top);
	}

	function finalize()
	{
		invalidate charaLayer;
		invalidate figureLayer;
		invalidate lifeLayer;
		super.finalize();
	}

	property keyName
	{
		getter{ return data.name; }
	}

	property selectable
	{
		setter(v)
		{
			super.selectable = v;
			if(v && ! dead) darkCoverLayer.visible = false;
			else darkCoverLayer.visible = true;
		}
		getter{ return super.selectable; }
	}

	property index
	{
		getter{ return master.helper.find(this); }
	}

	property infoVisible
	{
		setter(v)
		{
			lifeLayer.visible = v;
			statusLayer.visible = v;
		}
	}

	property trust
	{
		setter(v){ CharaObject.trust = v; }
		getter{ return CharaObject.trust; }
	}

	property attack
	{
		getter
		{
			var addPow = (power - data.power) * 3;
			return [data.attack[0] + addPow, data.attack[1] + addPow];
		}
	}

	function store()
	{
		var dic = super.store();
		dic.trust = _trust;
		dic.direction = direction;
		return dic;
	}

	function restore(dic)
	{
		if(dic === void) return;
		super.restore(dic);
		_trust = dic.trust;
		direction = dic.direction;

		// 初期化が必要なもの
		act = void;
		hitThreshold = 256;	// あとで Node を enabled にすることで判定を発生させる。初期値は無判定
		imageLeft = -width * (formation == "back");
	}

	function onMouseEnter()
	{
		if(master.onSelectAction == master.openWindowByFaceClick) lightingLayer.visible = true;
		else super.onMouseEnter();
	}

	function onMouseLeave()
	{
		if(master.onSelectAction == master.openWindowByFaceClick) lightingLayer.visible = false;
		else super.onMouseLeave();
	}

	function setGroup(depth = 0)
	{
		// グループを設定する
		master.party.setGuestGroup(this, depth);
		imageLeft = -width * depth;
	}

	function loadData(dic, i)
	{
		// ゲストの情報や画像を読み込み
		super.loadData(dic, i);
		loadImages(img);
		newAbility = dic.newAbility;
		formation = dic.formation;
		imageLeft = -width * (formation == "back");
		brave = 100;	// ゲストキャラは逃げない
		exp = getNeedExp(level);
		for(var i = btcmd.count - 1; i >= 0; i--)
		{
			if(! btcmd[i].auto || btcmd[i].category == "capture" || btcmd[i].category == "call")
			{
				btcmd.erase(i);	// ゲストキャラとして有効でないコマンドは除外
			}
		}
	}

	function loadImages(storage)
	{
		var temp = new global.Layer(window, this);
		temp.loadImages(storage + (Storages.isExistentStorage(storage + "_l.png") ? "_l" : ""));
		temp.setSizeToImageSize();
		if(temp.width > figureLayer.width) figureLayer.width = temp.width;
		figureLayer.operateRect(cap((figureLayer.width - temp.width) \ 2 + adjustLeft)
			, cap(figureLayer.height - temp.height) \ 2, temp, 0, 0, temp.width, temp.height);
		charaLayer.operateRect(0, 0, temp
			, data.facePos[0] + charaLayer.imageLeft, data.facePos[1] + charaLayer.imageTop
			, charaLayer.imageWidth, charaLayer.imageHeight);
	}

	function activate()
	{
		// パーティーに加入すると呼ばれる
		// ここで初期化・表示更新等を行う
		updateLife();
		updateStatus();
		visible = true;
		enabled = true;
		selectable = true;
		if(status.has(o.石化)) beStonedImage();
		if(status.has(o.凍結)) beFrozenImage();
	}

	function updateLife()
	{
		if(! lifeLayer.visible) return;
		var str = "%3d".sprintf(life) + "/" + "%3d".sprintf(maxLife);
		var col = life / maxLife > 0.1 ? 0xFFFFFF : (life == 0 ? 0xFFA0A0 : 0xFFFF80);
		lifeLayer.clear();
		lifeLayer.drawText(98 - lifeLayer.font.getTextWidth(str), 2
			, str, col,,, 2048, 0x000000, 2);
	}

	function cutInFigure(faceNum, type, x, y)
	{
		master.cutInFigure(figureLayer, type, x, y);
	}

	function cutInFigureOnBattle()
	{
		if(act === void || act.category == "other") return;
		master.cutInFigure(figureLayer, "alternate", 1160 - figureLayer.width, 0, true);
	}

	function drawDamage(value)
	{
		numberLayer.setPos(left + (width - numberLayer.width) \ 2 + 5, parent.top + top + height - 60);
		super.drawDamage(...);
	}

	function processDamageAnim()
	{
		var l = thisAnimList[animCounter];
		if(l !== void && shakeAnim) charaLayer.left += l;
		super.processDamageAnim();
	}

	function isCounterAttacking(en)
	{
		if(! en.act.toGuest) return false;
		return super.isCounterAttacking(en);
	}

	function getAffectedParam(key, value)
	{
		// 様々な条件によって変化したパラメータを返す
		// ゲストはパーティーの一員なのでここではパーティー付加効果も見る
		return CharaObject.getAffectedParam(key, value);
	}

	function getIncreaseOfLife()
	{
		// このキャラに適当なＨＰの増加量を返す
		return intrandom(1, cap(level * 15 - maxLife, 9999 - maxLife, 1));
	}

	function levelUp()
	{
		// レベルアップする

		var increase = 20;	// 基本値（素体の能力値）から上昇させられる範囲
		var rate = 0.5;	// １度のレベルアップで上昇する確率
		var dic = %[];	// 表示用の情報を書き込む辞書配列
		dic.param = [];	// 上昇した能力値の情報
		dic.magic = [];	// 覚えた魔法の情報（使わない）
		dic.ability;	// 覚えたコマンド・スキルの情報

		// レベル増加
		level ++;

		// 能力値の上昇範囲を決める すでにレベルアップにより上昇したであろう値を差し引く
		// レベルアップ回数 * 上昇が起こる確率 = そのレベルに至るまでの上昇値
		// レベル１での能力値 = 初期データにおける能力値 - そのレベルに至るまでの上昇値
		increase -= int((data.level - 1) * rate);

		// ＨＰと能力値
		var l = getIncreaseOfLife();
		maxLife = _maxLife + l;
		life = maxLife;
		dic.param[0] = l;

		if(_power < data.power + increase && random < rate)
		{
			_power ++;
			dic.param[1] = "1";
		}
		if(_intellect < data.intellect + increase && random < rate)
		{
			_intellect ++;
			dic.param[2] = "1";
		}
		if(_piety < data.piety + increase && random < rate)
		{
			_piety ++;
			dic.param[3] = "1";
		}
		if(_vitality < data.vitality + increase && random < rate)
		{
			_vitality ++;
			dic.param[4] = "1";
		}
		if(_speed < data.speed + increase && random < rate)
		{
			_speed ++;
			dic.param[5] = "1";
		}
		if(_luck < data.luck + increase && random < rate)
		{
			_luck ++;
			dic.param[6] = "1";
		}

		// 新しいコマンド or スキル
		var newAbilities = Job.getNewAbility(level);	// Job クラスのものをそのまま使える
		for(var i = 0; i < newAbilities.count; i++)
		{
			if(! learnSkill(newAbilities[i])) continue;
			if(newAbilities[i].magicLV > 0) dic.magic = [newAbilities[i].displayName];
			else dic.ability = newAbilities[i].displayName;
			break;
		}

		return dic;
	}

	function levelDown()
	{
		// レベルダウンする

		var rate = 0.5;	// １度のレベルダウンで減少する確率

		// レベル減少
		level --;

		// ＨＰと能力値
		if(_maxLife > 1)
		{
			maxLife = cap(_maxLife - getIncreaseOfLife(),, 1);
			if(life > maxLife) life = maxLife;
		}
		if(_power     > 1 && random < rate) _power --;
		if(_intellect > 1 && random < rate) _intellect --;
		if(_piety     > 1 && random < rate) _piety --;
		if(_vitality  > 1 && random < rate) _vitality --;
		if(_speed     > 1 && random < rate) _speed --;
		if(_luck      > 1 && random < rate) _luck --;
	}

	function learnSkill(obj)
	{
		// 新たなスキル・魔法を習得する
		if(btcmd.has(obj) || skill.has(obj)) return false;
		if(/passive|cancel|status/.test(obj.category))
		{
			skill.add(obj);
		}
		else
		{
			btcmd.add(obj);
			while(btcmd.count > 4)
			{
				// 増えすぎたら古いものから捨てる
				if(btcmd[0] == o.イレースマジック) btcmd.erase(1);
				else btcmd.shift();
			}
		}
		return true;
	}

	function isLevelUp()
	{
		return CharaObject.isLevelUp();
	}

	function getReachableLevel()
	{
		return CharaObject.getReachableLevel();
	}

	function levelUpToTheLast()
	{
		return CharaObject.levelUpToTheLast();
	}

	function getNeedExp(lv)
	{
		// レベルアップに必要な経験値を返す
		if(lv <= 1) return 0;
		if(lv <= 15) return getNeedExp(lv - 1) + int(Math.pow(1.5, lv - 2) * 400);
		else return getNeedExp(lv - 1) + int(Math.pow(1.5, 13 + lv / 20) * 400);
	}

	function isAbleToGetExp()
	{
		// 経験値を得る資格があるかどうかを返す
		return ! dead;
	}

	function getExtraExp(baseExp)
	{
		// 追加で入る経験値を返す
		return 0;
	}

	function isNovice()
	{
		return false;
	}

	function avoidTrap()
	{
		// 罠を回避する
		return CharaObject.avoidTrap();
	}

	function checkStatusByMoving()
	{
		// １歩歩くごとに状態をチェックし何かあれば効果が発動したり状態が変化したりする
		if(dead || status.has(o.石化)) return;
		super.checkStatusByMoving();
	}

	function beStonedImage()
	{
		// 画像を石化状態にする
		charaLayer.noise(128);
		charaLayer.colorize(0, 0, 1);
	}

	function beFrozenImage()
	{
		// 画像を凍結状態にする
		charaLayer.doGrayScale();
		charaLayer.adjustGamma(1, 0 ,255, 1, 64, 255, 1, 128, 255);
	}

	function beSoftenImage()
	{
		// 画像を状態異常から元に戻す
		charaLayer.clear();
		loadImages(img);
	}

	function isFloating()
	{
		// 浮遊しているかどうかを返す
		if(master.party.status.has(o.浮遊)) return true;
		return super.isFloating();
	}

	function isProofAgainstFire()
	{
		// 地形の熱に耐えられるかどうかを返す
		if(skill.has(o.耐熱)) return true;
		if(block.has("火")) return true;
		return false;
	}

	function switchFaceState(str)
	{
		// フェイスウインドウを指定した表情の画像に変化させる
		if(str == "hiding") charaLayer.visible = false;
		else charaLayer.visible = true;
	}

	function revive(statusObj)
	{
		// 戦闘不能から復活する時の処理
		darkCoverLayer.visible = dead = false;
		super.revive(statusObj);
	}

	function recovery()
	{
		// 回復。ゲストキャラは死亡含め状態異常を引きずらない
		clearStatus();
		revive();
		life = maxLife;
	}

	function beRaised()
	{
		// 蘇生
		life = maxLife \ 10 + intrandom(1, 3);
		clearStatus();
		revive();
		master.party.restoreFaces();
	}

	function getCurePrice(algn)
	{
		// 寺院での治療に必要な金額を得る
		var price = 0;
		for(var i = 0; i < status.count; i++)
		{
			price += status[i].getPrice(this);
		}
		return price;
	}

	function speak(msg, flip)
	{
		// ポップアップにセリフを表示する
		if(msg === void) return;
		master.wordsBase.open();
		master.wordsBase.popUpMessage(slot + master.party.maxMembers, msg);
	}

	function switchDirection(forward)
	{
		// 戦闘時の指示を切り替える
		if(trust < 0)
		{
			playSound("buzzer");
			master.notice.open();
			master.notice.write("<p>" + displayName + "<y> didn't listen to my instructions!");
			return;
		}
		var num = directionList.find(direction) + (forward ? 1 : -1);
		if(num == -2) num = directionList.count - 1;
		if(num == -1 || num == directionList.count) direction = void;
		else direction = directionList[num];
	}

	function getUsableActions()
	{
		// 現在、使用可能なコマンドを列挙する
		if(direction == "身を守る") return [o.身を守る];
		var arr = super.getUsableActions();
		if(direction === void) return arr;
		if(direction == "直接攻撃" && arr.has(o.攻撃)) return [o.攻撃];
		arr.remove(o.攻撃);
		for(var i = arr.count - 1; i >= 0; i--)
		{
			if(direction == "魔法優先" && arr[i].magicLV <= 0) arr.erase(i);
			else if(direction == "スキル優先" && arr[i].magicLV > 0) arr.erase(i);
		}
		return arr;
	}

	function setAction()
	{
		super.setAction();
		if(act === void) return;	// 戦闘不能だった

		if(act.toEnemy && act.range == 2)
		{
			// 敵グループを攻撃するコマンドが選ばれている場合
			// 最も残り人数の多い敵グループをターゲットにする
			var et = team == master.enemy ? master.party : master.enemy;	// 敵チーム
			target = et.group0;
			var num = et.getNumExist(target.depth);
			if(num < et.getNumExist(et.group1.depth)) target = et.group1;
			if(et == master.enemy && num < et.getNumExist(et.group2.depth)) target = et.group2;
		}
	}
}

//----------------------------------------------------------------------------------------
