	function isFloating()
	{
		// 浮遊しているかどうかを返す
		if(equipLife >= G_FLYING) return true;
		return super.isFloating();
	}

	function isSwimming()
	{
		// 泳げるかどうかを返す
		if(equipLife == G_SWIM) return true;
		return super.isSwimming();
	}

	function checkStatusByMoving()
	{
		// １歩歩くごとに状態をチェックし何かあれば効果が発動したり状態が変化したりする
		super.checkStatusByMoving();
		if(dead || status.has(o.石化)) return;
		heatCounter ++;
		beHeatedUpByOthers();	// 興奮度上昇
	}

	function checkStatusByOneTurn()
	{
		// １ターン行動するごとに状態をチェックし何かあれば効果が発動したり状態が変化したりする
		super.checkStatusByOneTurn();
		if(active && master.inBattle) heatCounter += 5;
	}

	function clearStatusOnDungeonExit()
	{
		// ゲストの場合は深刻な状態異常も含めすべて治る
		if(life == 0) life = 1;
		clearStatus();
		revive();
		equipLife = G_WHOLE;
		makeBustups();
	}

	function goToSleep(inStable)
	{
		// 宿屋などで泊まったときの回復
		if(! inStable) recovery();
	}

	function tryRaising()
	{
		return true;
	}

	function tryToBreakItem(hitScore, pow = 1)
	{
		// 装備の破壊を試みる
		if(noBreak) return false;
		if(dead || status.has(o.石化) || status.has(o.凍結)) return false;
		if(equipLife == G_SWIM) return false;	// 水着の着用中は破壊が発生しない
		if(equipLife >= G_FLYING) return false;	// 羽衣の着用中は破壊が発生しない
		if(equipLife == G_TOWELF) return false;	// バスタオルの着用中は破壊が発生しない
		if(equipLife == 0) return false;
		var res = ((equipLife > G_BROKEN && equipLife - pow <= G_BROKEN)
			 || (equipLife > G_PIECE && equipLife - pow <= G_PIECE)
			 || equipLife <= pow);
		if(res) createFigure(FACE["fight"].num, getFigureImageKey("fight"));	// 破壊発生なら破壊前の像を準備
		equipLife = cap(equipLife - pow);	// 耐久度を減らす
		if(! res) return false;
		brokenItem = %[name: "装備", displayName: "equipment", sound: "tear", part: "guestBody"];
		return true;
	}

	function getBrokenItemPos()
	{
		// 装備破壊アニメの表示位置
		return [figureLayer.width \ 2 - master.itemWin.left, figureLayer.height \ 2];
	}

	//---------------------------------------------------------------------------
	// 宿泊イベント関連

	function checkEvent(checkOnly = false)
	{
		// 宿イベントをチェックし、あれば実行する
		master.curChara = this;
		for(var i = 0; i < events.count; i++)
		{
			var num = events[i];
			if(! (conditions[num] !)) continue;
			if(checkOnly) return true;
			master.onGameBreak();
			kag.process("hevent.ks", "*event_" + name + "_" + num);
			dm("ゲストイベント発生   " + name + " No." + num);
			events.erase(i);	// 一度発生したイベントは後ろに回す
			events.add(num);	//     〃
			master.curEventObj = this;
			master.curEventNum = num;
			return true;
		}
		return false;
	}

	function checkReservation(checkOnly = false)
	{
		// 部屋割りに問題がないかチェックし、あればセリフを返す
		master.curChara = this;
		for(var i = 0; i < booking.count; i++)
		{
			if(! (bookingExp[booking[i]] !)) continue;
			if(checkOnly) return true;
			master.onGameBreak();
			kag.process("stay.ks", "*booking_" + name + "_" + booking[i]);	// この行がちょっと違う
			kag.skipToPage();	// ただの警告なので一気に表示する
			return true;
		}
	}

	function beSeducedEarly(guy, forced = false)
	{
		// 散策中に指定した男と行為に及ぶ会話が発生するかどうかを返す（女性専用）

		// 同じ部屋で２人きりでなければ行為に及ばない
		if(! inSameRoomOnly(guy)) return false;

		// 男が指定した相手と行為に及びたいと思っているかどうかを調べる
		if(! guy.wantToSexWithHeroine(this)) return false;

		// 女の警戒度が０じゃないなら何も起こらない（強制された場合除く）
		if(! forced && guard[guy.img] > 0) return false;

		// 条件を満たしていれば会話が変化
		return true;
	}

	function seduceAnyGirlEarly(forced = false)
	{
		return CharaObject.seduceAnyGirlEarly(...);
	}

	function beSeduced(guy)
	{
		// ゲスト女性キャラが男とＨするかどうかを返す

		// 口説かれるのは夜だけ
		if(! MIDNIGHT) return false;

		// 同じ部屋にいなければ口説かれない
		if(! inSameRoomOnly(guy)) return false;

		// 男が指定した相手と行為に及びたいと思っているかどうかを調べる
		if(! guy.wantToSexWithHeroine(this)) return false;

		// 条件を満たしていれば口説きイベント発生
		dm("口説きイベント発生 : " + name + " <- " + guy.name);
		return true;
	}

	function getEmitter()
	{
		// 宿イベントをチェックし、エミッターがあればその名前を返す
		master.curChara = this;
		for(var i = 0; i < events.count; i++)
		{
			var num = events[i];
			if(conditions[num] !) return emitters[num];
		}
	}

