	function getSexAppealOfAppearance()
	{
		// 服装のセクシー度を返す
		if(sex != "女" || dead || status.has(o.石化)) return 0;
		var score = 0;	// セクシー度スコア
		if(isHipNaked()) score += 100;	// 股間が露出
		if(isBustNaked()) score += 100;	// 乳首が露出
		return score;
	}

	function isBustNaked()
	{
		// 乳房が出ているどうかを返す。女性以外は意味がないので false を返す
		if(sex != "女") return false;
		if(equipLife == G_SWIM && expose >= 50) return true;	// 露出が平気なキャラは水着も過激
		if(equipLife <= G_BROKEN) return true;
		return false;
	}

	function isHipNaked()
	{
		// 股間が出ているどうかを返す
		return equipLife == 0;
	}

	function isErected()
	{
		if(! visible) return false;
		return CharaObject.isErected();
	}

	function isPenisNaked()
	{
		if(sex != "男" || dead || status.has(o.石化)) return;
		if(equipLife == G_SWIM && isErected()) return "erected";
		if(equipLife == G_TOWELF && isErected()) return "erected";
		if(isHipNaked())
		{
			if(isErected()) return "erected";
			else return "droop";
		}
	}

	function isSeasoned()
	{
		return CharaObject.isSeasoned();
	}

	function updateStatus()
	{
		// 状態表示を更新
		super.updateStatus();
		switchFaceState();
	}

	function updateHeart()
	{
		// 興奮度表示を更新する
		heartLayer.clear();
		var col = 0xFFFFFF - (heat \ 50 * 0x002020);
		heartLayer.drawText(9 + (heat < 100) * 3, 11, heat, col,,, 1024, 0x000000, 2);
	}

	function emitHeart(val)
	{
		// 興奮度が変化したらそれをアニメで表示する
		CharaObject.emitHeart(val, slot + 9);
	}

	function retire(statusObj)
	{
		// 戦闘不能にさせられた時の処理
		if(statusObj != o.死亡 && statusObj != o.灰) return;
		darkCoverLayer.visible = dead = true;
		cancelAction();
		act = void;
		trust -= 10;
		master.guest.rearMemberToFrontPos();
	}

	function revive(statusObj)
	{
		// 戦闘不能から復活する時の処理
		master.guest.resetRearMemberPos();
		super.revive(statusObj);
	}

	function beStonedImage()
	{
		// 画像を石化状態にする
		switchFaceState("surprise");
		charaLayer.operateRect(faceLayer.left - charaLayer.imageLeft, faceLayer.top - charaLayer.imageTop
			, faceLayer, -faceLayer.imageLeft, 0, faceLayer.width, faceLayer.height);
		super.beStonedImage();
	}

	function beFrozenImage()
	{
		// 画像を凍結状態にする
		switchFaceState("asleep");
		charaLayer.operateRect(faceLayer.left - charaLayer.imageLeft, faceLayer.top - charaLayer.imageTop
			, faceLayer, -faceLayer.imageLeft, 0, faceLayer.width, faceLayer.height);
		super.beFrozenImage();
	}

	function beSoftenImage()
	{
		// 画像を状態異常から元に戻す
		super.beSoftenImage();
		switchFaceState();
	}

