// guest.tjs
// ゲスト・召喚モンスターを管理


//----------------------------------------------------------------------------------------
class GuestGroup extends BoardLayer
{
	// ゲストグループを作成・管理するクラス

	var members = [];
	var maxMembers = 5;	// 最大数

	function GuestGroup(par, master)
	{
		super.BoardLayer(...);
		name = "ゲスト管理レイヤー";
		members.name = "ゲストグループ";
		setSize(900, 410);
		setPos(0, 140);
		targetLayers = members;
		enabled = false;
	}

	function finalize()
	{
		super.finalize();
	}

	property memberClickable
	{
		setter(v)
		{
			enabled = v;
			for(var i = 0; i < members.count; i++)
			{
				members[i].focusable = ! v;
			}
		}
	}

	function store()
	{
		var dic = %[];
		dic.membersName = [];
		for(var i = 0; i < members.count; i++)
		{
			dic.membersName[i] = members[i].name;
		}
		return dic;
	}

	function restore(dic)
	{
		for(var i = 0; i < dic.membersName.count; i++)
		{
			entry(o[dic.membersName[i]], true);
		}
		rearMemberToFrontPos();
		update();
	}

	function clearMembers()
	{
		// ゲストをすべてクリアする。データロード時などに使う
		for(var i = 0; i < members.count; i++)
		{
			master.party.updateByGuestRemoved(members[i]);
			members[i].enabled = members[i].visible = members[i].selectable = false;
		}
		members.clear();
	}

	function update()
	{
		// 再配置
		for(var i = 0; i < members.count; i++) members[i].resetPos();
		visible = (members.count > 0);
	}

	function rearMemberToFrontPos()
	{
		// 前衛が全滅したとき後衛のメンバーを前に出す
		if(members.count == 0) return;
		if(master.party.getNumExist(0) > 0) return;
		for(var i = 0; i < members.count; i++)
		{
			if(! members[i].dead) members[i].setGroup(0);
		}
	}

	function resetRearMemberPos()
	{
		// 後衛のメンバーの位置を元に戻せるなら戻す
		// レギュラーメンバーが１人でも復活しているか
		// 基本位置が前衛のゲストメンバーがだれか１人でも元気なら後衛に下がる
		if(members.count == 0) return;
		var res = (master.party.getNumExist(0, true) > 0);
		for(var i = 0; i < members.count; i++)
		{
			if(res) break;
			var obj = members[i];
			res = (! obj.knockOut && obj.formation == "fore");
		}
		if(! res) return;
		for(var i = 0; i < members.count; i++)
		{
			if(members[i].formation == "back") members[i].setGroup(1);
		}
	}

	function entry(obj, loading)
	{
		// ゲスト・召喚モンスターをメンバーに加える
		if(! loading && ! obj.isHiring) members.unshift(obj);
		else members.add(obj);
		master.party.updateByGuestAdded(obj, obj.formation == "fore" ? 0 : 1);
		obj.activate();
		if(! loading) resetRearMemberPos();
		if(obj instanceof "SummonedObject") obj.copyCommandToImitateSkill(o.憑依術);	// 憑依術に設定
		if(! loading) update();
		if(sf[obj.name] === void) sf[obj.name] = 0;	// モンスター図鑑に載せるためここで記録
	}

	function removeMember(obj)
	{
		// ゲスト・召喚モンスターをメンバーから外す
		obj.cancelAction();	// 戦闘中の行動をキャンセル
		obj.visible = false;
		obj.selectable = false;
		members.remove(obj);
		master.party.updateByGuestRemoved(obj);
		update();
		if(master.itemWin.curChara == obj) master.itemWin.curChara = void;
	}

	function summonHiring(hiring)
	{
		// 傭兵を仲間に加える
		eraseHiring();
		hiring.recovery();
		entry(hiring);
	}

	function summonMonster(monster)
	{
		// モンスターを召喚する
		eraseMonster();
		monster.recovery();
		entry(monster);
		if(master.inBattle)
		{
			monster.setAction();
			master.fightingOrder.add(monster);	// 途中参加
		}
	}

	function getSummonedMonster()
	{
		// 現在の召喚モンスターを得る
		for(var i = 0; i < members.count; i++)
		{
			if(members[i] instanceof "SummonedObject") return members[i];
		}
	}

	function getHiring()
	{
		// 現在の一時雇用人間型モンスターを得る
		for(var i = 0; i < members.count; i++)
		{
			if(members[i] instanceof "HiringObject") return members[i];
		}
	}

	function eraseHiring()
	{
		// 一時雇用人間型を外す
		var obj = getHiring();
		if(obj !== void) removeMember(obj);
	}

	function eraseMonster()
	{
		// 召喚モンスターを外す
		var obj = getSummonedMonster();
		if(obj !== void) removeMember(obj);
	}

	function eraseSummonedMonster(skillObj)
	{
		// 召喚モンスター（一時雇用人間型は含まない）を消去する
		// skillObj にスキルを指定すると、そのスキルを持たない場合のみ削除する
		var obj = getSummonedMonster();
		if(obj === void) return false;
		if(skillObj !== void && obj.skill.has(skillObj)) return false;
		removeMember(obj);
		return true;
	}

	function dressSpecialSuits(type)
	{
		// ゲスト全員に特殊な服を着せる
		var val;
		if(type == "swim") val = G_SWIM;
		if(type == "flying") val = G_FLYING;
		if(type == "towel") val = G_TOWELF;
		for(var i = 0; i < members.count; i++)
		{
			var obj = members[i];
			if(obj instanceof "SummonedObject") continue;
			if(obj.equipLife == val) continue;
			if(type == "flying" && obj.isFloating()) continue;
			if(type == "flying" && obj.sex == "男")
			{
				// 男の場合、現在の服装値に G_FLYING を加算する
				// equipLife から G_FLYING を引くことで元の服装を割り出す
				obj.equipLife += val;
			}
			else obj.equipLife = val;
			obj.makeBustups();
		}
	}

	function setPartyActions()
	{
		// ゲストたちの行動を決定する
		for(var i = 0; i < members.count; i++)
		{
			members[i].setAction();
		}
	}

	function getFirstGuest()
	{
		// 最初のゲストを返す
		if(members.count > 0) return members[0];
		for(var i = 0; i < master.smagic.count; i++)
		{
			if(master.smagic[i].contracted) return master.smagic[i];
		}
	}

	function getNumGuests()
	{
		// 現在の傭兵・召喚獣を除いたゲストを人数を返す
		var num = 0;
		for(var i = 0; i < members.count; i++)
		{
			if(! members[i].isHiring) num ++;
		}
		return num;
	}

	function getLayerByKey(curLayer, key)
	{
		// 最下段で下を押した時パーティー領域にフォーカスを移動
		if(master.party.enabled)
		{
			if(((key == BT_DOWN || key == BT_DOWN2) && curLayer.slot == 0)
				 || ((key == BT_UP || key == BT_UP2) && curLayer.slot == members.count - 1))
			{
				master.party.members[0].focus();
				return;
			}
			else if(key == BT_LEFT || key == BT_LEFT2)
			{
				master.party.members[-1].focus();
				return;
			}
			else if(key == BT_RIGHT || key == BT_RIGHT2)
			{
				// 自然に見える位置へ。curLayer.slot に加算する値で調整すること
				master.party.members[min(curLayer.slot + 1, master.party.members.count - 1)].focus();
				return;
			}
		}
		return super.getLayerByKey(...);
	}
}

//----------------------------------------------------------------------------------------
class HiringObject extends GuestObject
{
	// 雇用キャラ（人型モンスター）を作るクラス
	// ゲストと同様に宿泊できる

	var labelLayer;
	var dragging = false;
	var holding = false;
	var alignment = o.中立;
	var contracted = false;	// 契約済みかどうか

	function HiringObject(par, master, id)
	{
		super.GuestObject(...);
		isHiring = true;
		isSpecial = false;
		dressInfo["通常"] = %[img: "l"];
		equipLife = G_WHOLE;
		invalidate heartLayer;
	}

	property heat
	{
		setter(v){ return; }
		getter{ return; }
	}

	property infoVisible
	{
		setter(v){ global.HelperObject.infoVisible = v; }
	}

	function store()
	{
		var dic = super.store();
		dic.contracted = contracted;
		return dic;
	}

	function restore(dic)
	{
		if(dic === void) return;
		super.restore(dic);
		contracted = dic.contracted;
	}

	function loadImages(storage)
	{
		createFigure(0, getFigureImageKey());
		makeBustups();
	}

	function resetPos()
	{
		setPos(772, 170);
		absolute = 3;
	}

	function transformToGuildType()
	{
		// ギルドでの表示に切り替える
		parent = master.guildWin;
		setSize(master.guildWin.cellWidth, master.guildWin.cellHeight);
		labelLayer.visible = true;
		lifeLayer.visible = statusLayer.visible = heartLayer.visible = false;
		updateLabel();
	}

	function updateLabel()
	{
		// ギルド一覧に表示するラベルを更新
		if(! labelLayer.visible) return;
		labelLayer.clear();
		var w = labelLayer.font.height - 2;	// ピッチ調整のため
		var num = 0;
		for(var i = 0; i < name.length; i++)
		{
			if(name[i] == "`") continue;
			labelLayer.drawText(w \ (1 + (#name[i] < 0x7F)) * num, 9, name[i], 0xFFFFFF);
			num ++;
		}
		labelLayer.drawText(32, 49, "LV " + level, 0x80FF80);
		labelLayer.drawText(102, 49, sex, 0x80FF80);
	}

	function createFigure(faceNum, clothesImg)
	{
		figureLayer.loadImages(img + "_" + clothesImg);
		figureLayer.setSizeToImageSize();
	}

	function getFigureImageKey()
	{
		if(equipLife == G_SWIM) return "swim_fight";
		if(equipLife == G_TOWELF) return "towel_fight";
		if(equipLife == G_TOWEL) return "towel";	// イベントでタオル姿になる時
		if(equipLife == G_NUDE) return "nude";	// イベントでヌードになる時
		if(equipLife == G_FLYING) return "flying_fight";	// 傭兵は女性のみなのでこれで良い
		if(equipLife == 0) return "nude_fight";
		if(equipLife <= G_BROKEN) return "topless_fight";
		return "l";
	}

	function cutInFigureOnBattle()
	{
		if(act === void || act.category == "other") return;
		createFigure(, getFigureImageKey());
		master.cutInFigure(figureLayer, "alternate", 810 - figureLayer.width \ 2, 0, true);
	}

	function makeFaces(l, t)
	{
		return;
	}

	function switchFaceState(str)
	{
		global.HelperObject.switchFaceState(str);
	}

	function updateHeart()
	{
		// なにもしない
	}

	function checkStatusByMoving()
	{
		global.HelperObject.checkStatusByMoving();
	}

	function checkStatusByOneTurn()
	{
		global.HelperObject.checkStatusByOneTurn();
	}

	function isBustNaked()
	{
		// 乳房が出ているどうかを返す
		if(equipLife == G_SWIM) return true;	// 傭兵は罰ゲーム的にトップレス水着を着る
		return super.isBustNaked();
	}

	function isHipNaked()
	{
		// 股間が出ているどうかを返す
		return equipLife == G_NUDE || equipLife == 0;
	}

	function tryToBreakItem(hitScore, pow = 1)
	{
		// 装備の破壊を試みる
		if(dead || status.has(o.石化) || status.has(o.凍結)) return false;
		if(equipLife == G_SWIM) return false;	// 水着の着用中は破壊が発生しない
		if(equipLife >= G_FLYING) return false;	// 羽衣の着用中は破壊が発生しない
		if(equipLife == G_TOWELF) return false;	// バスタオルの着用中は破壊が発生しない
		if(equipLife == 0) return false;
		var res = ((equipLife > G_BROKEN && equipLife - pow <= G_BROKEN)
			 || equipLife <= pow);
		if(res) createFigure(FACE["fight"].num, getFigureImageKey("fight"));	// 破壊発生なら破壊前の像を準備
		equipLife = cap(equipLife - pow);	// 耐久度を減らす
		if(! res) return false;
		brokenItem = %[name: "装備", sound: "tear", part: "guestBody"];
		return true;
	}

	function beSeducedEarly(guy, forced = false)
	{
		// 散策中に指定した男と行為に及ぶ会話が発生するかどうかを返す（女性専用）

		// 同じ部屋で２人きりでなければ行為に及ばない
		if(! inSameRoomOnly(guy)) return false;

		// 男が指定した相手と行為に及びたいと思っているかどうかを調べる
		if(! guy.wantToSexWithHeroine(this)) return false;

		// 無条件で会話が変化
		return true;
	}
}

//----------------------------------------------------------------------------------------
class SubActorObject extends GuestObject
{
	// 表情などは変化するがパーティーには参加しないキャラクター
	// イベントで使う

	function SubActorObject(par, master, id)
	{
		super.GuestObject(...);
		isGuest = false;
		isSpecial = false;
	}

	function loadImages(storage)
	{
		// 戦闘カットインはないので figureLayer への読み込みは必要ない
		return;
	}

	function getFigureImageKey()
	{
		return "default";
	}

	function store()
	{
		var dic = %[];
		dic.name = name;	// ロード時の識別のため名前だけは保存する
		dic.sexCount = sexCount;
		dic.loversCount = loversCount;
		dic.desire = desire;
		dic.technic = technic;
		dic.penis = penis;
		dic.faceNumByTag = faceNumByTag;
		dic.clothesNamesByTag = clothesNamesByTag;
		return dic;
	}

	function restore(dic)
	{
		if(master.retryMode) return;	// 再プレイ時には読み出さない
		(Dictionary.assign incontextof sexCount)(dic.sexCount);
		loversCount = dic.loversCount;
		desire = dic.desire;
		technic = dic.technic;
		penis = dic.penis;
		faceNumByTag = dic.faceNumByTag;
		clothesNamesByTag = dic.clothesNamesByTag;
	}
}

//----------------------------------------------------------------------------------------
class GuestObject extends HelperObject
{
	// ゲストメンバーを作るクラス
	// キャラデータはモンスターデータから読み込む

	// ＫＡＧ用立ち絵表示用
	var faceNumByTag = 0;	// ＫＡＧタグで指定された表情を表す番号
	var clothesNamesByTag;	// ＫＡＧタグで指定された服装を示す文字列
	var face = [0, 0];	// 立ち絵での表情合成位置
	var trim = [0, 0];	// フェイスウインドウ画像切り出し位置
	var largeFace = [0, 0];	// 大型立ち絵のフェイスウインドウ画像切り出し位置
	var figureTop = 0;	// 立ち絵での標準表示高さ（ＫＡＧ用）

	// 服装差分ファイル名情報
	var dressInfo = %[
		  "通常"       => %[img: "default", face: 0]
		, "戦闘"       => %[img: "fight"]
		, "水着"       => %[img: "swim"]
		, "バスタオル" => %[img: "towel"]
		, "上半身裸"   => %[img: "topless"]
		, "下着"       => %[img: "under", face: 25]
		, "裸"         => %[img: "nude", face: 94]
		, "汗だく"     => %[img: "sweat", face: 98]
	];

	// 宿泊イベント関連
	var events = [];	// 宿泊イベント
	var conditions = [];	// イベント条件を表す式
	var capturers = [];	// キャラを捕らえるモンスターたち
	var rapeStep = 0;	// モンスターによる陵辱段階
	var emitters = [];
	var booking = [];	// 現在チェックする部屋割り条件
	var bookingExp = [];	// 部屋割り条件を表す式
	var beCursed = false;	// 呪われているかどうか。ゲストは基本的に呪われないので false
	var love = %[theo: 0, max: 0, linus: 0, blue: 0, alex: 0];
		// 男たちへの好感度（女子ゲスト用）
	var sexCount = %[theo: 0, max: 0, linus: 0, blue: 0, alex: 0, other: 0];
		// 男たちとの性交回数（女子ゲスト用・男が彼女に飽きる基準になる）
	var guard = %[theo: 0, max: 0, linus: 0, blue: 0, alex: 0];	// 警戒度
		// 男たちへの警戒度（女子ゲスト用・男との行為を受け入れるかどうかをこれで判定）
	var develop = %[theo: 0, max: 0, linus: 0, blue: 0, alex: 0];	// 開発度合い
		// 男たちの開発度（女子ゲスト用・特定の男の言いなりかどうかを設定）
	var strip = %[theo: "通常", max: "通常", linus: "通常", blue: "通常", alex: "通常"];	// 見せた姿
	var _heat = 0;	// 興奮度
	var _desire = 0;	// 性欲値
	var _moral = 0;	// 貞淑度
	var expose = 0;	// 露出したい・露出しても平気な度合い（ゲストは変化しない）
	var _feel = 10;	// 感じやすさ（ヒロイン用）
	var loversCount = 0;	// 経験人数（ヒロイン用）
	var sellCount = 0;	// 売春回数（ヒロイン用）
	var affairCount = 0;	// 不貞行為数（ヒロイン用）
	var pourCount = 0;	// 中出し回数（ヒロイン用）
	var pregnant = NO_PREGNANCY;	// 妊娠の進行度（ヒロイン用）
	var pregnantCount = 0;	// 妊娠回数（ヒロイン用）
	var technic = 10;	// 性的なテクニック（男性用）
	var penis = 10;	// 総合的なペニス最大性能（男性用）
	var sexActs = ["キス", "正常位"];	// 実行可能なプレイの一覧（男性用）
	var diary = [];	// セックス記録（ヒロイン用）
	var moved = false;	// 部屋を移動したかどうか
	var dontMove = false;	// 移動させないフラグ
	var moveType = "auto";	// 部屋移動の種類
	var breakCount = 1;	// １回の盾破壊で破壊される数
	var priorTarget;	// 部屋移動・ヒロイン攻略時に男たちが優先するターゲット
	var sleepEmit;	// 就寝時のエフェクト
	var heatCounter = 0;	// 興奮度上昇に間隔を設けるためのカウンター
	var firstPartnerKey;	// 初めての相手のキー名
	var lastGuyKey;	// 最後に表示した男キャラのキー名（ヒロイン情報表示用）
	var threeSize = [90, 65, 90];	// スリーサイズ
	var married = false;	// 結婚しているかどうか

	// 装備関連
	var equipLife = G_WHOLE;	// 耐久値
	var noBreak = false;	// 破壊が起きるかどうか

	// フェイスウインドウ
	var heartLayer;	// 眠気・興奮度表示
	var heartEmitter;	// 興奮度表示アニメ
	var faceLayer;	// 表情レイヤー

	function GuestObject(par, master, id)
	{
		super.HelperObject(...);
		isGuest = true;
		isSpecial = true;
		if(sex == "男") sexCount = %[self: 0];	// 男は self というメンバに書くことにする

		faceLayer = new global.Layer(window, charaLayer);
		with(faceLayer)
		{
			.absolute = 1;
			.hitThreshold = 256;
		}

		heartLayer = new DecoLayer(this);
		with(heartLayer)
		{
			.loadImages("charaslot_gheat");
			.setSizeToImageSize();
			.setPos(9, 94);
			.font.height = 14;
			.font.bold = true;
			.absolute = 20;
		}

		heartEmitter = new global.Layer(window, this);
		with(heartEmitter)
		{
			.loadImages("PE_base_heart");
			.setSizeToImageSize();
			.setPos(-15, 70);
			.absolute = 50;
		}
	}

	property heat
	{
		setter(v){ CharaObject.heat = v; }
		getter{ return CharaObject.heat; }
	}

	property desire
	{
		setter(v){ CharaObject.desire = v; }
		getter{ return CharaObject.desire; }
	}

	property moral
	{
		setter(v){ CharaObject.moral = v; }
		getter{ return CharaObject.moral; }
	}

	property feel
	{
		setter(v){ CharaObject.feel = v; }
		getter{ return CharaObject.feel; }
	}

	property infoVisible
	{
		setter(v)
		{
			heartLayer.visible = v;
			super.infoVisible = v;
		}
	}

	function store()
	{
		var dic = super.store();

		// 装備
		dic.equipLife = equipLife;

		// パラメータ
		dic.heat = _heat;

		// 宿泊イベント関連
		dic.events = events;
		dic.booking = booking;
		dic.moved = moved;
		dic.dontMove = dontMove;
		dic.moveType = moveType;
		if(priorTarget !== void) dic.priorTargetID = master.chara.find(priorTarget);

		// 性的パラメータ
		dic.love = love;
		dic.sexCount = sexCount;
		dic.strip = strip;
		dic.develop = develop;
		dic.guard = guard;
		dic.desire = desire;
		dic.feel = feel;
		dic.loversCount = loversCount;
		dic.sellCount = sellCount;
		dic.pourCount = pourCount;
		dic.technic = technic;
		dic.penis = penis;
		dic.firstPartnerKey = firstPartnerKey;
		dic.lastGuyKey = lastGuyKey;
		dic.heatCounter = heatCounter;
		dic.diary = diary;
		dic._moral = _moral;
		dic.expose = expose;

		// 立ち絵
		dic.faceNumByTag = faceNumByTag;
		dic.clothesNamesByTag = clothesNamesByTag;

		return dic;
	}

	function restore(dic)
	{
		if(dic === void) return;	// 後から追加された分をスルー
		super.restore(dic);

		// 再プレイ時は読み込まないもの
		if(! master.retryMode && ! master.nextRoundMode)
		{
			// 装備
			equipLife = dic.equipLife;

			// パラメータ
			_heat = dic.heat;

			// 宿泊イベント関連
			events.assign(dic.events);
			booking.assign(dic.booking);
			moved = dic.moved;
			dontMove = dic.dontMove;
			moveType = dic.moveType;
			priorTarget = dic.priorTargetID === void ? void : master.chara[dic.priorTargetID];

			// 性的パラメータ
			(Dictionary.assign incontextof love)(dic.love);
			(Dictionary.assign incontextof sexCount)(dic.sexCount);
			(Dictionary.assign incontextof strip)(dic.strip);
			(Dictionary.assign incontextof develop)(dic.develop);
			(Dictionary.assign incontextof guard)(dic.guard);
			desire = dic.desire;
			feel = dic.feel;
			loversCount = dic.loversCount;
			sellCount = dic.sellCount;
			pourCount = dic.pourCount;
			technic = dic.technic;
			penis = dic.penis;
			firstPartnerKey = dic.firstPartnerKey;
			lastGuyKey = dic.lastGuyKey;
			heatCounter = dic.heatCounter;
			diary.assignStruct(dic.diary);
			_moral = dic._moral;
			expose = dic.expose;
		}

		// 立ち絵
		faceNumByTag = dic.faceNumByTag;
		clothesNamesByTag = dic.clothesNamesByTag;
	}

	function loadImages(storage)
	{
		createFigure(0, getFigureImageKey("fight"));
		makeBustups();
		makeFaces(face[0] - data.facePos[0], face[1] - data.facePos[1]);
		faceLayer.visible = heartLayer.visible = true;
		switchFaceState();
	}

	function resetPos()
	{
		var num = parent.members.find(this);
		setPos(0, 280 - num * 130);
		absolute = num;
	}

	function activate()
	{
		// パーティーに加入すると呼ばれる
		// ここで初期化・顔絵作成・表示更新等を行う
		super.activate();
		makeFaces(face[0] - data.facePos[0], face[1] - data.facePos[1]);
		makeBustups();
		updateHeart();
		switchFaceState();
	}

	function createFigure(faceNum, clothesImg, large)
	{
		// 表情・服装差分情報を元に立ち絵を作成する
		var largePrefix = large ? "lg" : "";
		figureLayer.loadImages(img + largePrefix + "_" + clothesImg);
		figureLayer.setSizeToImageSize();
		var temp = new global.Layer(window, this);
		var fileName = img + largePrefix + "_" + "%02d".sprintf(+faceNum);
		if(! Storages.isExistentStorage(fileName + ".png")) fileName = img + largePrefix + "_00";
		temp.loadImages(fileName);
		temp.setSizeToImageSize();
		var fc = large ? largeFace : face;
		figureLayer.operateRect(fc[0], fc[1], temp, 0, 0, temp.width, temp.height);
	}

	function createFigureByTag(faceNum, clothesName, forTalkerImage)
	{
		// ＫＡＧタグからの情報を元に立ち絵を作成する

		// ロード時に再現させるために情報を保存
		if(faceNum !== void) faceNumByTag = +faceNum;
		if(clothesName !== void) clothesNamesByTag = clothesName;

		// 服装の情報を取得
		var info;
		if(clothesNamesByTag === void || clothesNamesByTag == "現在の装備")
		{
			info = %[img: getFigureImageKey("fight")];
		}
		else
		{
			info = dressInfo[clothesNamesByTag];
		}

		// 立ち絵を作成
		createFigure(faceNumByTag, info.img, ! forTalkerImage && info.large);
	}

	function getFigureImageKey(poseKey = "default")
	{
		// 現在の装備の耐久力から服装の画像キー名を返す
		// ※男ゲストキャラの場合、浮遊時は天使のはねを利用するので服装は変更しない
		poseKey += isErected() ? "_erect" : "";	// 勃起時のサフィックス
		var el = equipLife;	// 服装の値を別の変数にコピー
		if(el == G_SWIM) return "swim_" + poseKey;
		if(el == G_TOWELF) return "towel_" + poseKey;
		if(el >= G_FLYING)
		{
			if(sex == "女") return "flying_" + poseKey;
			el -= G_FLYING;	// 男ゲストキャラの本来の服装の値を算出
		}
		if(el > G_BROKEN) return poseKey;
		if(el > G_PIECE) return "topless_" + poseKey;
		if(el > 0) return "under_" + poseKey;
		return "nude_" + poseKey;
	}

	function getTalkerImage(faceNum, clothesName)
	{
		// 現在の顔画像を返す（ＫＡＧ用）
		createFigureByTag(faceNum, clothesName, true);
		var lay = new global.Layer(kag, master.gameBase);
		lay.setSize(200, 200);
		lay.operateRect(0, 0, figureLayer, trim[0], trim[1], 200, 200);
		return lay;
	}

	function cutInFigure(faceNum, type, x, y)
	{
		createFigure(faceNum, getFigureImageKey("fight"));
		master.cutInFigure(figureLayer, type, x, y);
	}

	function cutInFigureOnBattle()
	{
		if(act === void || act.category == "other") return;
		createFigure(FACE[getFaceName()].num, getFigureImageKey("fight"));
		master.cutInFigure(figureLayer, "alternate", 600, 0, true);
	}

	function makeFaces(l, t)
	{
		CharaObject.makeFaces(...);
	}

	function makeBustups()
	{
		var temp = new global.Layer(window, this);
		temp.loadImages(img + "_" + getFigureImageKey("fight"));
		charaLayer.clear();
		charaLayer.operateRect(0, 0, temp
			, data.facePos[0] + charaLayer.imageLeft, data.facePos[1] + charaLayer.imageTop
			, charaLayer.imageWidth, charaLayer.imageHeight);
	}

	function updateByChangeEquipment(itemData)
	{
		makeBustups();
	}

	function switchFaceState(str)
	{
		// フェイスウインドウを指定した表情の画像に変化させる
		if(str === void) str = getFaceNameByCurrentState();
		faceLayer.imageLeft = -faceWidth * FACE[str].id;
		super.switchFaceState(str);
	}

