;------------------------------------------------------------------------------



;■陵辱後の処理
;------------------------------------------------------------------------------
*finish_rape_weaken
@eval exp='game.curChara.rapeStep = 0'
@eval exp='tf.damage = o.衰弱.doDamage(game.curChara)'
@eval exp='tf.message = o.衰弱.catchMessage(game.curChara)'
@eval exp='game.curChara.removeStatus(o.拘束)'
@eval exp='game.curChara.setStatus(o.衰弱, true)'
@eval exp='tf.energyDrainOccured = true'
@return

;------------------------------------------------------------------------------
*finish_rape_drain
@eval exp='game.curChara.rapeStep = 0'
@eval exp='tf.damage = o.ドレイン.doDamage(game.curChara.capturers[0], game.curChara)'
@eval exp='tf.message = o.衰弱.catchMessage(game.curChara) + "\n"'
@eval exp='tf.message += o.ドレイン.catchMessage(game.curChara)'
@eval exp='game.curChara.removeStatus(o.拘束)'
@eval exp='game.curChara.setStatus(o.衰弱, true)'
@eval exp='tf.energyDrainOccured = true'
@return

;------------------------------------------------------------------------------
*finish_rape_reverse
@eval exp='game.curChara.rapeStep = 0'
@eval exp='game.curChara.capturers[0].life = 0'
@eval exp='tf.temp = game.curChara.capturers[0].data.exp'
@eval exp='game.curChara.exp += tf.temp'
@eval exp='tf.damage = "0,0xC0FFFF,+" + tf.temp + "exp"'
@eval exp='tf.message = game.curChara.displayName + " had "+ tf.temp + "EXP drained!"'
@eval exp='game.curChara.removeStatus(o.拘束)'
@eval exp='tf.energyDrainOccured = true'
@return

