	};
}
//--------------------------------------------------------------------
Name = "リフレッシュ";
with(o[Name])
{
	.determined = function(owner)
	{
		if(owner instanceof "MonsterObject" || owner.status.has(o.魅了)) return false;
		var hp = master.party.hasPatient;
		if(hp(o.石化)) return true;
		if(hp(o.麻痺)) return true;
		if(hp(o.気絶)) return true;
		if(hp(o.凍結)) return true;
		if(hp(o.衰弱)) return true;
		if(hp(o.眠り)) return true;
		if(hp(o.魅了)) return true;
		if(hp(o.恐怖)) return true;
		if(hp(o.混乱)) return true;
		if(hp(o.酩酊)) return true;
		if(hp(o.沈黙)) return true;
		if(hp(o.毒)) return true;
		return false;
	};

	.pickUpTarget = function(array, owner)
	{
		// 深刻度の高い状態異常から検索する
		for(var i = array.count - 1; i >= 0; i--) if(array[i].status.has(o.石化)) return array[i];
		for(var i = array.count - 1; i >= 0; i--) if(array[i].status.has(o.麻痺)) return array[i];
		for(var i = array.count - 1; i >= 0; i--) if(array[i].status.has(o.気絶)) return array[i];
		for(var i = array.count - 1; i >= 0; i--) if(array[i].status.has(o.凍結)) return array[i];
		for(var i = array.count - 1; i >= 0; i--) if(array[i].status.has(o.衰弱)) return array[i];
		for(var i = array.count - 1; i >= 0; i--) if(array[i].status.has(o.眠り)) return array[i];
		for(var i = array.count - 1; i >= 0; i--) if(array[i].status.has(o.魅了)) return array[i];
		for(var i = array.count - 1; i >= 0; i--) if(array[i].status.has(o.恐怖)) return array[i];
		for(var i = array.count - 1; i >= 0; i--) if(array[i].status.has(o.混乱)) return array[i];
		for(var i = array.count - 1; i >= 0; i--) if(array[i].status.has(o.酩酊)) return array[i];
		for(var i = array.count - 1; i >= 0; i--) if(array[i].status.has(o.沈黙)) return array[i];
		for(var i = array.count - 1; i >= 0; i--) if(array[i].status.has(o.毒)) return array[i];
		return array[0];
	};

	.doDamage = function(self, target)
	{
		if(target.dead) return 0;
		target.removeStatus(o.毒);
		target.removeStatus(o.沈黙);
		target.removeStatus(o.酩酊);
		target.removeStatus(o.混乱);
		target.removeStatus(o.恐怖);
		target.removeStatus(o.魅了);
		target.removeStatus(o.眠り);
		target.removeStatus(o.衰弱);
		target.removeStatus(o.凍結);
		target.removeStatus(o.気絶);
		target.removeStatus(o.麻痺);
		target.removeStatus(o.石化);
		target.revive();
		return "0,0xC0FFC0,CURE";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		return "It cured " + target.displayName + "!";
	};
}
//--------------------------------------------------------------------
Name = "グランドキュア";
with(o[Name])
{
	.determined = function(owner)
	{
		var num = 0;
		for(var i =  master.party.members.count - 1; i >=0; i--)
		{
			var one = master.party.members[i];
			if(one.status.has(o.毒)) return num += 1;
			if(one.status.has(o.沈黙)) return num += 1;
			if(one.status.has(o.酩酊)) return num += 1;
			if(one.status.has(o.混乱)) return num += 1;
			if(one.status.has(o.恐怖)) return num += 1;
			if(one.status.has(o.魅了)) return num += 2;
			if(one.status.has(o.眠り)) return num += 2;
			if(one.status.has(o.衰弱)) return num += 2;
			if(one.status.has(o.凍結)) return num += 2;
			if(one.status.has(o.気絶)) return num += 2;
			if(one.status.has(o.麻痺)) return num += 3;
			if(one.status.has(o.石化)) return num += 3;
			if(num >= 3) return true;
		}
		if(num == 0) return false;
	};

	.doDamage = o.リフレッシュ.doDamage;
	.resultMessage = o.リフレッシュ.resultMessage;
}
//--------------------------------------------------------------------
Name = "レイズデッド";
with(o[Name])
{
	.showCutIn = false;	// 蘇生は後列に下がったキャラにすることが多いので

	.doDamage = function(self, target)
	{
		if(! target.status.has(o.死亡)) return 0;
		if(target.isGuest || (master.map.kind == "dungeon" && master.map.underWater)
			 || random < target.vitality / 50)
		{
			// 水中で灰になると潜水装備が外れ状況と矛盾するので水中では蘇生率を100%にする
			target.beRaised();
			return "0,0xC0FFFF,RAISE";
		}
		else
		{
			target.setStatus(o.灰, true);
			return "0,0xA0A0A0,ASHED";
		}
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		else if(target.dead) return target.displayName + " has become ashes!";
		else return target.displayName + " returned to life!";
	};
}
//--------------------------------------------------------------------
Name = "レザレクション";
with(o[Name])
{
	.showCutIn = false;	// 蘇生は後列に下がったキャラにすることが多いので

	.doDamage = function(self, target)
	{
		if(! target.dead) return 0;
		if(target.isGuest || random < target.vitality / 50)
		{
			target.beRaised();
			var heal = 9999;
			target.life += heal;
			return "0,0x80F080," + heal;
		}
		else
		{
			if(target.status.has(o.死亡))
			{
				target.setStatus(o.灰, true);
				return "0,0xA0A0A0,ASHED";
			}
			else if(master.isHeavyMode)
			{
				target.beLost();
				master.noReturnMenu = true;
				return "0,0xC0C0C0,LOST";
			}
			else
			{
				return 0;
			}
		}
	};

	.resultMessage = function(target, value)
	{
		if(value === 0 && target.dead) return "Failed to revive!";
		else if(value === 0) return "It didn't work on " + target.displayName + "!";
		else if(target.dead) target.displayName + " had vanished from this world!";
		else return target.displayName + " returned to life!";
	};
}
