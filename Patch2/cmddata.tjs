// 戦闘コマンド詳細登録
var Name;


// ◆通常攻撃
//--------------------------------------------------------------------
Name = "攻撃";
with(o[Name])
{
	.counterRate = 1.3;

	.pickUpTarget = function(array, owner, chooseWeakTraget = false)
	{
		if(! owner.isUserChara) return array.draw();
		var hasMagicalWeapon = false;
		if(owner.equip.main !== void && owner.equip.main.attrib !== void) hasMagicalWeapon = true;
		if(owner.status.has(o.付与)) hasMagicalWeapon = true;
		var target;
		for(var i = 0; i < array.count; i++)
		{
			if(! hasMagicalWeapon && array[i].skill.has(o.物理無効)) continue;
			if(target === void || target.life > array[i].life) target = array[i];
		}
		if(target === void) target = array.draw();
		return target;
	};

	.doDamage = function(self, target)
	{
		var dmg = 0;
		hitCount = 0;
		if(target.invincible) return 0;
		for(var i = 0; i < self.times; i++)
		{
			// var hitRate = cap(self.acu - target.def + 55, 95);
			var hitRate = cap(self.acu - target.def + 100, 200) \ 5 + 55;
			if(i == 0)
			{
				dm(self.name + " の攻撃  命中確率  " + hitRate + " %");
				dm("self.acu : " + self.acu + " target.def  " + target.def);
			}
			var rand = int(random * 100);
			if(rand >= hitRate) continue;	// 命中しなかった
			var v = self.atk;	// 基本ダメージ
			var atrb = self.getWeaponAttrib();	// 追加ダメージ属性名
			var slyr = self.getWeaponSlayers();	// 追加ダメージ属性名
			v = target.getAffectedDamage(v, atrb, slyr);	// 相手の属性・魔法により変動
			dm("基本ダメージ : " + self.atk + "   ダメージ加工後 : " + v);
			if(v == 0) continue;
			dmg += v;
			hitCount ++;
			if(master.extraEffect !== void) continue;	// 複数の追加効果は同時に発生しない
			var exf = doExtraEffect(self, target);	// 追加効果
			master.extraEffect = exf;
			if(exf == o.死亡 || exf == o.灰) return;	// 死亡時はダメージ値を出さない（蓄積も消さない）
		}
		dm("ヒット回数 : " + hitCount + "   総ダメージ : " + dmg);
		target.life -= dmg;	// ダメージを引く。life を下の文で参照するので位置を変えないこと
		for(var i = 0; i < hitCount; i++)
		{
			// 装備の破壊を試みる。表示が後になるため、壊れた上での判定を適用しないようにする
			if(target.tryToBreakItem(self.destroy)) break;
		}
		self.removeStatus(o.蓄積);	// 攻撃を繰り出すことで効果を失うステータスを削除
		return dmg;
	};
}
/*
	「力」* n が相手の「防御」を上回っている限り 95% の確率で攻撃が当たる
	「力」* n が相手の「防御」を 1P 下回るごとに 1% ずつ命中率が下がる
	（「力」が 1P 下がると n% ずつ命中率が下がる）
	「力」* n が相手の「防御」を 95P 下回るとまったく攻撃が当たらなくなる
	「力」が 1 しかない場合、相手が 100 以上の防御を持っていると攻撃が当たらない
	「力」が 30 ある相手から完全に防御しようと思ったら防御値は 30 * n + 100 必要
	防御の最高値はおそらく 150 程度だと思うので、完全防備を行っても
	相手の力が 20 あったら命中率は (20 * n - 50) %
	相手の力が 30 あり、n >= 5 なら、ほぼ確実に攻撃が当たることになる
	終盤の敵の力は 30 を超えてくるのは確実なので、もう少し調整が必要かも

	＜この条件を表す命中率(%)の式＞
	      cap( 力 * n - 防御 + 命中率最大値 - (命中率補正値), 命中率最大値 )

	平均的なケース   n = 5  命中率最大値 = 95
	力20 防御20 の場合 → 95%
	力10 防御30 の場合 → 95%
	力10 防御50 の場合 → 95%
	力10 防御70 の場合 → 75%

	平均的なケース   n = 3  命中率最大値 = 100
	力30 防御20 の場合 → 100%
	力30 防御100 の場合 → 90%
	力20 防御20 の場合 → 100%
	力20 防御80 の場合 →  80%
	力10 防御30 の場合 → 100%
	力10 防御50 の場合 →  80%
	力10 防御70 の場合 →  50%

	n = 3 の場合、
	力が 6 しかないキャラであっても、敵の防御が 118 なければ完全に攻撃を防がれることはない
	敵の防御が 68 でも 50% の確率で攻撃が当たることになる    (命中率補正値 = 50 なら 必要な防御は 18 )
	敵の防御が 43 でも 75% の確率で攻撃が当たることになる    (命中率補正値 = 50 なら 必要な防御は  0 )
	敵の防御が 18 以下なら 100% の確率で攻撃が当たることになる
	力が 18 あるキャラの場合、敵の防御が 154 なければ完全に攻撃を防がれることはない
	敵の防御が 104 でも 50% の確率で攻撃が当たることになる   (命中率補正値 = 50 なら 必要な防御は 54 )
	敵の防御が 79 でも 75% の確率で攻撃が当たることになる    (命中率補正値 = 50 なら 必要な防御は 29 )
	敵の防御が 54 以下なら 100% の確率で攻撃が当たることになる
	力が 30 あるキャラの場合、敵の防御が 190 なければ完全に攻撃を防がれることはない
	敵の防御が 140 でも 50% の確率で攻撃が当たることになる   (命中率補正値 = 50 なら 必要な防御は 90 )
	敵の防御が 115 でも 75% の確率で攻撃が当たることになる   (命中率補正値 = 50 なら 必要な防御は 65 )
	敵の防御が 90 以下なら 100% の確率で攻撃が当たることになる

	n = 2 の場合、
	力が 6 しかないキャラであっても、敵の防御が 112 なければ完全に攻撃を防がれることはない
	敵の防御が 87 でも 75% の確率で攻撃が当たることになる
	敵の防御が 62 でも 50% の確率で攻撃が当たることになる
	敵の防御が 12 以下なら 100% の確率で攻撃が当たることになる
	力が 18 あるキャラの場合、敵の防御が 136 なければ完全に攻撃を防がれることはない
	敵の防御が 111 でも 75% の確率で攻撃が当たることになる
	敵の防御が 86 でも 50% の確率で攻撃が当たることになる
	敵の防御が 36 以下なら 100% の確率で攻撃が当たることになる
	力が 30 あるキャラの場合、敵の防御が 160 なければ完全に攻撃を防がれることはない
	敵の防御が 135 でも 75% の確率で攻撃が当たることになる
	敵の防御が 110 でも 50% の確率で攻撃が当たることになる
	敵の防御が 60 以下なら 100% の確率で攻撃が当たることになる

	仮に 命中率補正値 = 50 （攻撃スコアから無条件に50引く）だと
	力が 6 なら相手の防御が０でも命中率は 62%
	力が 12 なら相手の防御が０でも命中率は 76%
	力が 17 ではじめて防御が０のとき命中率 100% が確保できる

	仮に 命中率補正値 = 40 （攻撃スコアから無条件に40引く）だと
	力が 6 なら相手の防御が０でも命中率は 72%
	力が 12 なら相手の防御が０でも命中率は 86%
	力が 14 ではじめて防御が０のとき命中率 100% が確保できる
	初期状態で戦士などを作った時の力はボーナスで粘らないと 12～15 くらいになると思われる
	スライム等最弱の敵の場合、14を確保すればほぼ確実に当たるので、この辺りが妥当か？
	初期状態で魔法使いなどを作った時の力はおそらく 5～7 程度
	頑張って最弱の敵相手に肉弾戦に参加したとして 70% 程度なら悪くない数値
	ちょっと強い相手（オークなど。防御は 10 程度？）に魔法使いがスリング等で攻撃したとして
	命中率は 62% ３回に１回は外れる計算になる

*/
//--------------------------------------------------------------------
Name = "再攻撃";
with(o[Name])
{
	.doDamage = o.攻撃.doDamage;
}
//--------------------------------------------------------------------
Name = "キック";
with(o[Name])
{
	.longHand = true;

	.affectedParam = function(key, value)
	{
		if(key == "speed") return 99;	// キックはスピードが上がる
		return value;
	};

	.doDamage = function(self, target)
	{
		var dmg = self.atk + intrandom(18, 24);
		target.life -= dmg;
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "飛びかかる";
with(o[Name])
{
	.longHand = true;

	.actionMessage = function(self, target)
	{
		return self.displayName + " leapt forward!";
	};

	.doDamage = o.攻撃.doDamage;
}
//--------------------------------------------------------------------
Name = "毒矢";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		var dmg = self.atk + intrandom(3, 10);
		target.life -= dmg;
		if(dmg > 0 && target.setStatus(o.毒)) master.extraEffect = o.毒;
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "火矢";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		var dmg = self.atk + intrandom(24, 36);
		dmg = target.getAffectedDamage(dmg, attrib);
		target.life -= dmg;
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "汚いかぎ爪";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		var dmg = cap(self.atk * 1 + intrandom(3, 10) - target.def);
		target.life -= dmg;
		if(dmg > 0 && target.setStatus(o.毒)) master.extraEffect = o.毒;
		return dmg;
	};
}
//--------------------------------------------------------------------


// ◆特殊攻撃
//--------------------------------------------------------------------
Name = "浄化";
with(o[Name])
{
	.cond = function(owner)
	{
		if(owner.isUserChara) return true;

		// assign メソッドは load みたいに作った配列にすぐデータを読み込んだり
		// 操作後の自分自身を返したりしないので、以下の３行の記述が必要
		var arr = [];
		arr.assign(master.enemy.members);
		return pickUpTarget(arr) !== void;
	};

	.pickUpTarget = function(array, owner)
	{
		array.shuffle();
		for(var i = 0; i < array.count; i++)
		{
			if(array[i].dead) continue;
			if(array[i].race.name == "アンデッド" || array[i].race.name == "幽霊") return array[i];
		}
	};

	.doDamage = function(self, target)
	{
		if(target.race.name != "アンデッド" && target.race.name != "幽霊") return 0;
		if(random < 0.3) return 0;
		target.life = 0;
		return "0,0x80F0F0,BANISH";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		return target.displayName + " was exorcised!";
	};
}
//--------------------------------------------------------------------
Name = "一列攻撃";
with(o[Name])
{
	.cond = function(owner)
	{
		if(! owner.isUserChara) return true;
		if(owner.equip.main === void) return false;
		return owner.equip.main.skill.has(o.複数);
	};

	.doDamage = function(self, target)
	{
		// 通常攻撃と違って追加効果は発生しない（演出が長くなりすぎるので）
		var dmg = 0;
		hitCount = 0;
		for(var i = 0; i < self.times; i++)
		{
			var hitScore = cap(self.acu - target.def \ 5 + 100 - target.group.depth, 19);
			dm("命中スコア   " + hitScore);
			if(hitScore <= int(random * 20)) continue;	// 命中しなかった
			var v = self.atk;	// 基本ダメージ
			var atrb = self.getWeaponAttrib();	// 追加ダメージ属性名
			var slyr = self.getWeaponSlayers();	// 追加ダメージ属性名
			v = target.getAffectedDamage(v, atrb, slyr);	// 相手の属性・魔法により変動
			dm("基本ダメージ : " + self.atk + "   ダメージ加工後 : " + v);
			if(v == 0) continue;
			dmg += v;
			hitCount ++;
		}
		dmg \= 2;	// ダメージを半分に
		target.life -= dmg;	// ダメージを引く。life を下の文で参照するので位置を変えないこと
		for(var i = 0; i < hitCount; i++)
		{
			// 装備の破壊を試みる。表示が後になるため、壊れた上での判定を適用しないようにする
			if(target.tryToBreakItem(self.destroy)) break;
		}
		self.removeStatus(o.蓄積);	// 攻撃を繰り出すことで効果を失うステータスを削除
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "電撃";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		var dmg = intrandom(24, 28);
		dmg = target.getAffectedDamage(dmg, attrib);
		target.life -= dmg;
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "冷たい風";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		var dmg = intrandom(12, 16);
		dmg = target.getAffectedDamage(dmg, attrib);
		target.life -= dmg;
		if(dmg > 0 && target.setStatus(o.凍結)) master.extraEffect = o.凍結;
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "睡魔の霧";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(! target.isUserChara) return 0;
		target.sleep += intrandom(8, 16);	// 睡魔追加
		if(random * 100 >= target.sleep) return;
		if(! target.setStatus(o.眠り)) return;
		return o.眠り.doDamage(self, target);	// 眠ったら表示
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		else if(value === void) return target.displayName + "'s fatigue increased!";
		else return o.眠り.catchMessage(target);
	};
}
//--------------------------------------------------------------------
Name = "吸血";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		var dmg = cap(intrandom(50, 100), target.life);
		target.life -= dmg;
		self.life += dmg;
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "破壊の爪";
with(o[Name])
{
	.cond = function(owner)
	{
		if(master.party.status.has(o.障壁)) return false;
		return owner.getRandomTarget(this) !== void;
	};

	.determined = function(owner)
	{
		if(cond(owner)) return true;
	};

	.pickUpTarget = function(array, owner)
	{
		array.shuffle();
		for(var i = 0; i < array.count; i++)
		{
			var one = array[i];
			if(one.dead) continue;
			if(one instanceof "SummonedObject") return one;
			if(one.isGuest && one.equipLife > 0) return one;
			if(one.isUserChara)
			{
				var partNamesArray = ["main", "sub", "chest", "waist", "arm", "leg", "bust", "hip"];
				for(var i = 0; i < partNamesArray.count; i++)
				{
					if(one.equip[partNamesArray[i]] !== void) return one;
				}
			}
		}
	};

	.doDamage = function(self, target)
	{
		result = 0;
		if(master.map.underWater) return 0;

		if(target instanceof "SummonedObject")
		{
			result = -1;
			target.life = 0;
			return "0,0xFFFFFF,ERASE";
		}

		var dmg = intrandom(120, 160);
		target.life -= dmg;

		if(target.isGuest)
		{
			if(target.equipLife > 0) result = 1;
			target.equipLife = 0;
			return dmg;
		}

		var partNamesArray = ["main", "sub", "chest", "waist", "arm", "leg", "bust", "hip"];
		target.reduceEquipmentsLives(partNamesArray, BROKEN);
		target.removeEquipmentsByForce(partNamesArray);
		result = 1;
		return dmg;
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		if(result == -1) return target.displayName + " has disappeared!";
		if(result == 1) return target.displayName + "'s equipment was all destroyed!"
			+ target.displayName + " took " + value + " damage!";
	};
}
//--------------------------------------------------------------------
Name = "粉砕の爪";
with(o[Name])
{
	.cond = o.破壊の爪.cond;
	.determined = o.破壊の爪.determined;

	.doDamage = function(self, target)
	{
		if(master.map.underWater) return 0;
		if(target.isGuest)
		{
			if(! target instanceof "SummonedObject") target.equipLife = 0;
			target.life = 0;
			return o.死亡.doDamage(self, target);
		}
		target.reduceEquipmentsLives(, BROKEN);
		if(! target.setStatus(o.灰, true)) return 0;
		return o.灰.doDamage(self, target);
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		if(target.isGuest) return target.displayName + " died!";
		return target.displayName + "'s equipment was all destroyed!\n" + target.displayName + " has become ashes!";
	};
}
//--------------------------------------------------------------------
Name = "冥府の光";
with(o[Name])
{
	.cond = function(owner)
	{
		return owner.getRandomTarget(this) !== void;
	};

	.determined = function(owner)
	{
		if(cond(owner)) return true;
	};

	.pickUpTarget = function(array, owner)
	{
		array.shuffle();
		for(var i = 0; i < array.count; i++)
		{
			var one = array[i];
			if(one.dead) continue;
			if(one.isSpecial) continue;
			if(one.isUserChara && one.regular) continue;
			return one;
		}
	};

	.doDamage = function(self, target)
	{
		if(target instanceof "SummonedObject")
		{
			target.life = 0;
			return "0,0xFFFFFF,ERASE";
		}
		master.removeMemberTemporary(target);
		target.opacity = 255;
		return "0,0xFFFFFF,ERASE";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		return target.displayName + " was sucked into another dimension through a hole!";
	};
}
//--------------------------------------------------------------------
Name = "ゲイズ";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(random < 0.3) return 0;
		if(! target.setStatus(o.麻痺)) return 0;
		return o.麻痺.doDamage(self, target);
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		else return o.麻痺.catchMessage(target);
	};
}
//--------------------------------------------------------------------
Name = "炎のブレス";
with(o[Name])
{
	.cond = function(owner)
	{
		if(owner.team == master.party) return true;
		if(owner.data.race != "ドラゴン") return true;
		if(master.party.isUsableSkill(o.ブレス抑制)) return false;
		return true;
	};

	.doDamage = function(self, target)
	{
		var dmg = intrandom(24, 32);
		dmg = target.getAffectedDamage(dmg, attrib);
		target.life -= dmg;
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "毒のブレス";
with(o[Name])
{
	.cond = o.炎のブレス.cond;

	.doDamage = function(self, target)
	{
		var dmg = intrandom(64, 128);
		dmg = target.getAffectedDamage(dmg, attrib);
		target.life -= dmg;
		if(dmg > 0 && target.setStatus(o.毒)) master.extraEffect = o.毒;
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "氷のブレス";
with(o[Name])
{
	.cond = o.炎のブレス.cond;

	.doDamage = function(self, target)
	{
		var dmg = intrandom(64, 128);
		dmg = target.getAffectedDamage(dmg, attrib);
		target.life -= dmg;
		if(dmg > 0 && target.setStatus(o.凍結)) master.extraEffect = o.凍結;
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "業火のブレス";
with(o[Name])
{
	.cond = o.炎のブレス.cond;

	.doDamage = function(self, target)
	{
		var dmg = intrandom(128, 256);
		dmg = target.getAffectedDamage(dmg, attrib);
		target.life -= dmg;
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "死のブレス";
with(o[Name])
{
	.cond = o.炎のブレス.cond;

	.determined = function(owner)
	{
		if(master.turnCount == 0) return true;
	};

	.doDamage = function(self, target)
	{
		if(target.race.name == "神") return 0;
		if(target.race.name == "アンデッド" || target.race.name == "幽霊") return 0;
		if(random > 0.8) return 0;
		if(! target.setStatus(o.死亡, true)) return 0;
		return "0,0xFF8080,DEAD";
	};
}
