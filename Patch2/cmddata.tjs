{
	.cond = function(owner)
	{
		// 盗んだ装備を宝箱に入れるため固定バトルのみのコマンドとする
		return master.inFixedBattle && ! master.inEventBattle;
	};

	.pickUpTarget = function(array, owner)
	{
		array.shuffle();
		var parts = ["main", "sub", "chest", "waist", "arm", "leg", "bust", "hip"];
		for(var i = 0; i < array.count; i++)
		{
			// 装備を脱がせそうなキャラを探す
			var one = array[i];
			if(one.sex == "男") continue;
			for(var j = 0; j < parts.count; j++)
			{
				if(one.hasRemovableEquipment(parts[j])) return one;
			}
		}
	};

	.doDamage = function(self, target)
	{
		if(result !== void) return "0,0xFFFFFF,STOLEN";
		return 0;
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "But " + target.displayName + " dodged it!";
		else return target.displayName + " had " + o[result].displayName + " stolen!";
	};
}
