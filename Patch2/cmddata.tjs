Name = "クラッシュデッド";
with(o[Name])
{
	.pickUpTarget = function(array, owner)
	{
		for(var i = 0; i < array.count; i++)
		{
			if(array[i].dead) continue;
			if(array[i].race.name == "アンデッド" || array[i].race.name == "幽霊") return array[i];
		}
	};

	.doDamage = function(self, target)
	{
		if(target.race.name != "アンデッド" && target.race.name != "幽霊") return 0;
		if(random > cap(self.level - target.level, 10, 2) / 10) return 0;
		var dmg = intrandom(840, 1090);
		target.life -= dmg;
		return dmg;
	};
}
//--------------------------------------------------------------------
Name = "ターンデビル";
with(o[Name])
{
	.pickUpTarget = function(array, owner)
	{
		for(var i = 0; i < array.count; i++)
		{
			if(array[i].race.name == "悪魔") return array[i];
		}
	};

	.doDamage = function(self, target)
	{
		if(target.race.name != "悪魔") return 0;
		if(random > cap(self.level - target.level, 10, 2) / 10) return 0;
		target.life = 0;
		return "0,0xC0FFFF,BANISH";
	};
}
