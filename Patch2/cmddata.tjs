Name = "触手攻撃";
with(o[Name])
{
	.cond = function(owner)
	{
		for(var i = 0; i < master.party.members.count; i++)
		{
			var one = master.party.members[i];
			if(! owner.isActionReachTarget(this, one)) continue;
			if(one.getTouchableCrotchsImage() !== void) return true;
		}
	};

	.pickUpTarget = function(array, owner)
	{
		array.shuffle();
		for(var i = 0; i < array.count; i++)
		{
			var one = array[i];
			if(one.isUserChara && one.getTouchableCrotchsImage() !== void) return one;
		}
	};

	.doDamage = function(self, target)
	{
		if(target.status.has(o.凍結)) return 0;
		if(! target.isUserChara || target.getTouchableCrotchsImage() === void)
		{
			// 触手で襲えない誰かがかばったりしたら通常攻撃になる
			self.act = o.攻撃;
			return o.攻撃.doDamage(self, target);
		}
		target.cancelAction();
		target.heat += 5;
		return "0,0xFF8080,ECSTASY";
	};

	.actionMessage = function(self, target)
	{
		return self.displayName + " extended its tentacles towards " + target.displayName + "!";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "But " + target.displayName + " dodged it!";
		else return target.displayName + " felt tentacles groping her body!";
	};
}
//--------------------------------------------------------------------
Name = "蛮人陵辱";
with(o[Name])
{
	.targetModels = ["クレア", "フレデリカ"];

	.cond = function(owner)
	{
		// 攻撃対象となる相手が一人でもいるかどうかを調べる
		// 誰もいなければ他の攻撃が選ばれる
		if(master.inDuelBattle) return false;
		if(owner.status.has(o.魅了)) return false;
		return owner.getRandomTarget(this) !== void;
	};

	.determined = function(owner)
	{
		// すでに前のターンまでに拘束されているメンバーがいるならそれにさらに乗っかる
		for(var i =  master.party.members.count - 1; i >=0; i--)
		{
			var one = master.party.members[i];
			if(one.status.has(o.拘束) && one.capturers[0].data == owner.data) return true;
		}

		// ターゲットを探す
		var arr = [];
		arr.assign(master.party.members);
		var her = pickUpTarget(arr, owner);
		if(her === void) return false;	// ターゲットになる相手がひとりもいなかった

		// 協力者を探し用件を満たしていれば行動決定
		if(owner.setCooperators(this, her, 3, true)) return true;
	};

	.pickUpTarget = function(array, owner)
	{
		array.shuffle();
		for(var i = 0; i < array.count; i++)
		{
			var one = array[i];
			if(one.isUserChara && targetModels.has(one.keyName)) return one;
		}
	};

	.doDamage = function(self, target)
	{
		if(! target.isUserChara || ! targetModels.has(target.keyName))
		{
			// 誰かがかばったりしたら通常攻撃になる
			self.act = o.攻撃;
			return o.攻撃.doDamage(self, target);
		}
		if(! target.beCaptured(self)) return 0;
		if(target.capturers.count >= 2 && target.equip.chest !== void)
		{
			target.removeEquipmentsByForce(["chest"]);
		}
		if(target.capturers.count >= 3 && target.equip.bust !== void)
		{
			target.removeEquipmentsByForce(["bust"]);
		}
		if(target.capturers.count >= 4 && target.equip.waist !== void)
		{
			target.removeEquipmentsByForce(["waist"]);
		}
		return "0,0xFFFFC0,CAPTURED";
	};

	.actionMessage = function(self, target)
	{
		return self.displayName + " lunged for " + target.displayName + "'s body!";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "But failed to restrain "+ target.displayName + "!";
		if(target.capturers.count == 1) return target.displayName + " has been pushed down!";
		else return target.displayName + " was restrained by more enemies!";
	};
}
