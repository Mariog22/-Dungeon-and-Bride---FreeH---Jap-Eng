Name = "下着スリ";
with(o[Name])
{
	.pickUpTarget = function(array, owner)
	{
		var girl;	// 適当な女性キャラ
		array.shuffle();
		for(var i = 0; i < array.count; i++)
		{
			// 下着着用中のキャラを探す
			var one = array[i];
			if(one.hasRemovableEquipment("bust")) return one;
			if(one.hasRemovableEquipment("hip")) return one;
			if(one.sex == "女") girl = one;
		}
		if(girl !== void) return girl;	// 見つからなかった場合適当な女性キャラを返す
		return array[0];	// 万一女性メンバーがいなかったら適当なキャラを返す
	};

	.doDamage = o.装備を盗む.doDamage;
	.resultMessage = o.装備を盗む.resultMessage;
}
//--------------------------------------------------------------------
Name = "淫魔の触手";
with(o[Name])
{
	.pickUpTarget = function(array, owner)
	{
		array.shuffle();
		for(var i = 0; i < array.count; i++)
		{
			var one = array[i];
			if(one.getTouchableCrotchsImage() !== void) return one;
		}
		return array[0];	// ヒロインが見つからなかった場合適当なキャラを返す
	};

	.doDamage = function(self, target)
	{
		if(target.avoidingTrap) return 0;
		if(target.getTouchableCrotchsImage() === void) return 0;
		return "0,0xFFFFC0,ECSTASY";
	};

	.resultMessage = o.触手攻撃.resultMessage;
}
//--------------------------------------------------------------------
Name = "魔力吸収";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(target.avoidingTrap) return;
		for(var i = 0; i < target.mmagic.count; i++)
		{
			if(target.mmagic[i] > 0) target.mmagic[i] --;
			if(target.pmagic[i] > 0) target.pmagic[i] --;
			if(target.amagic[i] > 0) target.amagic[i] --;
			if(target.smagic[i] > 0) target.smagic[i] --;
		}
		return "0,0xF0D0F0,1";
	};

	.resultMessage = function(target, value)
	{
		if(target.avoidingTrap) return target.displayName + " quickly dodged!";
		return target.displayName + "'s MP has been reduced!";
	};
}
