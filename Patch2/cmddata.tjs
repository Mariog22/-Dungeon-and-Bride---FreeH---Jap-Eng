// ◆特殊コマンド
//--------------------------------------------------------------------
Name = "逃げる";
with(o[Name])
{
	.showCutIn = false;

	.cond = function(owner)
	{
		if(master.isNeverEscapeBattle || master.inDuelBattle) return false;
		if(owner.isUserChara) return true;
		if(owner.isGuest) return false;
		if(owner.status.has(o.誘惑)) return false;
		if(owner.life / owner.maxLife > 0.4
			 && owner.level - master.party.members.values("level").average() > 1) return false;
		return random * 100 > owner.brave;
	};

	.doDamage = function(self, target)
	{
		result = false;
		master.curTarget = self;	// 表示のため
		if(master.isNeverEscapeBattle || master.inDuelBattle) return 0;
		if(self.team.hasPatient(o.拘束)) return 0;	// 捕らわれた仲間を置いて逃げられない
		if(master.firstStrike == "party" && self.team == master.party) result = true;
		if(master.firstStrike == "enemy" && self.team == master.enemy) result = true;
		var opponent = self.team == master.party ? master.enemy : master.party;
		var opponentMaxSpeed = opponent.getMaxParamsValue("speed");
		var score = cap((self.speed - opponentMaxSpeed) * 2, 30, -20) + cap(self.luck \ 2, 20) + 10;
		if(opponentMaxSpeed < 5) score = 100;	// スピードが４以下なら確実に逃げられる
		if(self.level - opponent.getMaxParamsValue("level") >= 20) score = 100;	// レベル差があったら確実
		dm(self.name + "  逃亡スコア : " + score);
		if(random * 100 <= score) result = true;
		if(! result) return 0;
		if(self.team == master.enemy) return "0,0x80FFFF,ESCAPE";	// 敵だったら単独で逃げる
		for(var i = 0; i < master.party.members.count; i++)
		{
			// 味方が逃げる場合、１人が成功したら全員が逃げるので全員に表示を出す
			master.party.members[i].damageAnim("0,0x80FFFF,ESCAPE");
		}
	};

	.actionMessage = function(self, target)
	{
		return self.displayName + " tried to run!";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0)
		{
			if(target.team == master.party && target.team.hasPatient(o.拘束))
			{
				return "But can't abandon their captured friends and run away!";
			}
			return "But failed to escape!";	// 0 と文字列を区別するため型もチェック
		}
		if(target.team == master.party) return "The party successfully escaped!";
		else return target.displayName + " has escaped!";
	};
}
