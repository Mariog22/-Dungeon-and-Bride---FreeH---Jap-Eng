Name = "リターン";
with(o[Name])
{
	.getByLevelUp = false;

	.checkCurrentAction = function(owner)
	{
		if(master.map.isAntiWarpZone())
		{
			playSound("buzzer");
			return displayName + " spell failed, since warping is forbidden here!";
		}
		return global.BattleCommand.checkCurrentAction(owner);
	};

	.doDamage = function(self, target)
	{
		if(master.inBattle)
		{
			if(master.isNeverEscapeBattle || master.inDuelBattle || master.inEventBattle) return 0;
		}
		master.noReturnMenu = true;
		kag.process("battle.ks", "*loktofeit_battle_end");
	};
}
