Name = "エスケープ";
with(o[Name])
{
	.cond = function(owner)
	{
		if(! master.inBattle) return false;
		if(! o.逃げる.cond(owner)) return false;
		return true;
	};

	.doDamage = function(self, target)
	{
		if(master.isNeverEscapeBattle || master.inDuelBattle) return 0;
		o.逃げる.result = true;
		useResource(true, self);	// act が o.逃げる に変わるので、ここでリソースを消費
		for(var i = 0; i < master.party.members.count; i++)
		{
			master.party.members[i].act = o.逃げる;
			master.party.members[i].damageAnim("0,0x80FFFF,ESCAPE");
		}
	};
}
