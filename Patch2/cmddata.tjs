with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(master.autoMap.randomMalor()) kag.process("battle.ks", "*treasure_teleport");
		else master.notice.write("<y>But the party dodged the trap.");	// レアケース
	};

	.resultMessage = function(target, value)
	{
		return "But the party dodged the trap.";
	};
}
//--------------------------------------------------------------------
Name = "警報";
with(o[Name])
{
	.actionMessage = function(self, target)
	{
		return "Alarms blared and monsters gathered!";
	};

	.doDamage = function(self, target)
	{
		master.onCloseTreasureBox();
		kag.process("battle.ks", "*treasure_warning");
	};
}
//--------------------------------------------------------------------


// ◆迷宮内の罠・設置物
//--------------------------------------------------------------------
Name = "隠し槍";
with(o[Name])
{
	.cond = function(owner)
	{
		return ! master.party.isFloating();
	};

	.actionMessage = function(self, target)
	{
		return "Spears came out of the floor!";
	};

	.doDamage = function(self, target)
	{
		if(target === void) return;
		if(target.avoidingTrap) return;
		var dmg = intrandom(9, 15);
		target.life -= dmg;
		return dmg;
	};

	.resultMessage = o.石つぶて.resultMessage;
}
//--------------------------------------------------------------------
Name = "火炎放射";
with(o[Name])
{
	.actionMessage = function(self, target)
	{
		return "Flames shot out of the walls!";
	};

	.doDamage = function(self, target)
	{
		if(target === void) return;
		if(target.avoidingTrap) return;
		var dmg = intrandom(9, 15);
		dmg = target.getAffectedDamage(dmg, attrib);
		target.life -= dmg;
		return dmg;
	};

	.resultMessage = o.石つぶて.resultMessage;
}
//--------------------------------------------------------------------
Name = "酸の噴水";
with(o[Name])
{
	.cond = function(owner)
	{
		return ! master.party.isFloating();
	};

	.actionMessage = function(self, target)
	{
		return "Acid spat out from the floor!";
	};

	.doDamage = function(self, target)
	{
		if(target === void) return;
		if(target.avoidingTrap) return;
		target.tryToBreakItem(100, BROKEN);	// 装備の破壊
	};

	.resultMessage = function(target, value)
	{
		return;
	};
}
//--------------------------------------------------------------------
Name = "催眠ガス";
with(o[Name])
{
	.actionMessage = function(self, target)
	{
		return "Sleeping gas spewed out of the walls!";
	};

	.doDamage = function(self, target)
	{
		if(target === void) return;
		if(target.avoidingTrap) return;
		return o.睡魔の霧.doDamage(...);
	};

	.resultMessage = function(target, value)
	{
		if(target.avoidingTrap) return target.displayName + " quickly dodged!";
		return o.睡魔の霧.resultMessage(...);
	};
}
//--------------------------------------------------------------------
Name = "毒沼";
with(o[Name])
{
	.cond = function(owner)
	{
		return ! master.party.isFloating();
	};

	.doDamage = function(self, target)
	{
		if(self.isFloating()) return;
		var dmg = intrandom(1, 3);
		self.life -= dmg;
	};

	.actionMessage = function(self, target)
	{
		return "The party was damaged by the poisonous swamp!";
	};
}
//--------------------------------------------------------------------
Name = "溶岩";
with(o[Name])
{
	.cond = function(owner)
	{
		return ! master.party.isFloating();
	};

	.doDamage = function(self, target)
	{
		if(self.isProofAgainstFire()) return;
		var dmg = intrandom(1, 3);
		self.life -= dmg;
	};

	.actionMessage = function(self, target)
	{
		return "The party was damaged by lava!";
	};
}
//--------------------------------------------------------------------
Name = "噴水";
with(o[Name])
{
	.cond = function(owner)
	{
		return true;
	};

	.doDamage = function(self, target)
	{
		// ここに何らかの効果を設定する
	};

	.actionMessage = function(self, target)
	{
		return "The party drank from the fountain!";
	};

	.resultMessage = o.ヒール.resultMessage;
}
//--------------------------------------------------------------------
Name = "樽の水";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(target === void) return 0;
	};

	.actionMessage = function(self, target)
	{
		if(target === void) return "But nothing happened!";
		return target.displayName + " drank water from the barrel!";
	};
}
