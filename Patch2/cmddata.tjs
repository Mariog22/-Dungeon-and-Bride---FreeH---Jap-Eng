{
	.cond = function(owner)
	{
		if(master.inDuelBattle) return false;
		if(master.enemy.getEmptySpaces(owner.size).count == 0) return false;
		if(owner.name != "グレーターデーモン" && random < master.turnCount / 5) return false;
		if(random < (master.enemy.getNumExist() - 5) / 10) return false;
		return true;
	};

	.doDamage = function(self, target)
	{
		if(result <= 0) return 0;
	};

	.actionMessage = function(self, target)
	{
		return self.displayName + " called friends!";
	};

	.resultMessage = function(target, value)
	{
		if(result == -1) return "But couldn't find their voice!";
		else if(result > 0) return result + " new enemies arrived!";
		else return "But no one came!";
	};
}
