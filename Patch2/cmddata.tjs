Name = "アウェイクン";
with(o[Name])
{
	.determined = function(owner)
	{
		if(owner instanceof "MonsterObject" || owner.status.has(o.魅了)) return false;
		if(master.party.hasPatient(o.気絶)) return true;
		if(master.party.hasPatient(o.眠り)) return true;
		return false;
	};

	.doDamage = function(self, target)
	{
		if(! target.status.has(o.眠り) && ! target.status.has(o.気絶)) return 0;
		target.removeStatus(o.眠り);
		target.removeStatus(o.気絶);
		return "0,0xC0FFC0,AWAKEN";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		return target.displayName + " is awake!";
	};
}
//--------------------------------------------------------------------
Name = "キュアパラライズ";
with(o[Name])
{
	.determined = function(owner)
	{
		if(owner instanceof "MonsterObject" || owner.status.has(o.魅了)) return false;
		if(master.party.hasPatient(o.麻痺)) return true;
		return false;
	};

	.pickUpTarget = function(array, owner)
	{
		for(var i = array.count - 1; i >= 0; i--)
		{
			if(array[i].status.has(o.麻痺)) return array[i];
		}
	};

	.doDamage = function(self, target)
	{
		if(! target.status.has(o.麻痺)) return 0;
		target.removeStatus(o.麻痺);
		target.revive();
		return "0,0xFFFFC0,CURE";
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		return "Treated " + target.displayName + "'s paralysis!";
	};
}
