Name = "かばう";
with(o[Name])
{
	// 作成は簡単かと思いきや意外にも凄く苦労した…
	// この機能作るの想像以上に面倒くさい。どうせあまり使われないのにｗ

	.showCutIn = false;

	.cond = function(owner)
	{
		return owner.team.getNumExist() >= 2;
	};

	.determined = function(owner)
	{
		if(cond(owner)) return true;
	};

	.pickUpTarget = function(array, owner)
	{
		for(var i = array.count - 1; i >= 0; i--)
		{
			if(array[i].group.depth != 0 || array[i] == owner) array.erase(i);
		}
		array.keysort("life");
		return array[0];
	};

	.affectedParam = function(key, value)
	{
		if(key == "speed") return 99;
		return value;
	};

	.doDamage = function(self, target)
	{
		if(target.dead) return;
		return "0,0xFFFFFF,PROTECT";
	};

	.actionMessage = function(self, target)
	{
		return self.displayName + " is protecting " + target.displayName + "!";
	};
}
