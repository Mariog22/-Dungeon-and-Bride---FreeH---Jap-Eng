Name = "耐性防御";
with(o[Name])
{
	.isCancelSucceed = function(self, target, inCounter)
	{
		return true;
	};

	.doDamage = function(self, target)
	{
		return "b,0xFFFF80,RESIST";
	};

	.resultMessage = function(target, value)
	{
		return "It didn't work on " + target.displayName + "!";
	};
}
//--------------------------------------------------------------------
Name = "物理無効";
with(o[Name])
{
	.isCancelSucceed = function(self, target, inCounter)
	{
		var atrb;
		if(inCounter || target.act.category == "normal") atrb = target.getWeaponAttrib();
		else atrb = target.act.attrib;
		if(atrb == "物理") return true;
		return false;
	};

	.doDamage = function(self, target)
	{
		return "b,0xFFFFFF,0";
	};

	.resultMessage = function(target, value)
	{
		return "It didn't work on " + target.displayName + "!";
	};
}
//--------------------------------------------------------------------
Name = "金属性無効化";
with(o[Name])
{
	.isCancelSucceed = function(self, target, inCounter)
	{
		var atrb;
		if(inCounter || target.act.category == "normal") atrb = target.getWeaponAttrib();
		else atrb = target.act.attrib;
		if(atrb == "酸" || atrb == "爆発") return false;
		return true;
	};

	.doDamage = function(self, target)
	{
		return "b,0xFFFFFF,0";
	};

	.resultMessage = function(target, value)
	{
		return "It didn't work on " + target.displayName + "!";
	};
}
//--------------------------------------------------------------------
Name = "無効化";
with(o[Name])
{
	.isCancelSucceed = function(self, target, inCounter)
	{
		if(inCounter) return false;	// カウンターは通常攻撃
		if(target.act.attrib == "物理" || target.act.attrib == "通過") return false;
		if(target.act.magicLV == 0) return false;
		if(! target.act.toEnemy) return false;
		return random < self.piety * 0.01;
	};

	.doDamage = function(self, target)
	{
		return "b,0xFFFF80,RESIST";
	};

	.resultMessage = function(target, value)
	{
		return target.displayName + " nullified the magic!";
	};
}
//--------------------------------------------------------------------
Name = "無効化完全";
with(o[Name])
{
	.isCancelSucceed = function(self, target, inCounter)
	{
		if(inCounter) return false;
		if(target.act.attrib == "物理" || target.act.attrib == "通過") return false;
		if(target.act.magicLV == 0) return false;
		return true;
	};

	.doDamage = function(self, target)
	{
		return "b,0xFFFF80,RESIST";
	};

	.resultMessage = function(target, value)
	{
		return target.displayName + " nullified the magic!";
	};
}
//--------------------------------------------------------------------
Name = "遠距離防御";
with(o[Name])
{
	.isCancelSucceed = function(self, target, inCounter)
	{
		// ・後列への魔法以外の攻撃を全て防ぐ（後列を守るということに特化する）
		//    → 後列が絶対的な安全地帯になり敵が脅威ではなくなる
		// ・距離２以上の直接攻撃を全て防ぐ（飛び道具を無効化。ミサイルシールドの名前通り）
		//    → 主に弓使いを完全無力化  これらの職業だけかなり不利
		// ・離れた所からの直接攻撃を全て防ぐ（遠距離攻撃は魔法以外でできない。逆に言えば近接戦なら弓でも届く）
		//    → 後列にいる敵が何もしてこなくなる

		if(self == master.party && ! self.status.has(o.障壁)) return false;
		if(target.act.magicLV != 0) return false;	// 魔法＆魔力的な攻撃は防げない
		if(target.act.category == "capture") return false;	// 捕縛攻撃は防げない
		if(target.getActionLength(target.act) <= 1) return false;	// 近・中距離（１以下）の攻撃は防げない
		if(target.act.longHand) return false;	// 長い手の攻撃なら防げない
		return true;
	};

	.doDamage = function(self, target)
	{
		return "b,0xFFFFFF,GUARD";
	};

	.resultMessage = function(target, value)
	{
		return target.displayName + " was too far away to attack!";
	};
}
//--------------------------------------------------------------------
Name = "退魔の力";
with(o[Name])
{
	.isCancelSucceed = function(self, target, inCounter)
	{
		if(! self.isUsableSkill(this)) return false;
		if(inCounter) return false;
		if(target.act == o.死のブレス) return true;
		return false;
	};

	.doDamage = function(self, target)
	{
		return "b,0xFFFF80,RESIST";
	};

	.resultMessage = function(target, value)
	{
		return target.displayName + " wasn't affected by Breath of Death!";
	};
}
