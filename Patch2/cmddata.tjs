//--------------------------------------------------------------------
Name = "マルチヒール";
with(o[Name])
{
	.determined = function(owner)
	{
		if(owner instanceof "MonsterObject" || owner.status.has(o.魅了)) return false;
		var front = 0, back = 0;
		for(var i = 0; i < master.party.allMembers.count; i++)
		{
			var one = master.party.allMembers[i];
			if(one.dead) continue;
			if(one.life / one.maxLife < 0.6)
			{
				if(one.group.depth == 0) front ++;
				else back ++;
			}
		}
		if(front >= 2 || back >= 2) return true;
		if(front == 0 && back == 0) return false;
	};

	.pickUpTarget = function(array, owner)
	{
		var front = [], back = [];
		for(var i = array.count - 1; i >= 0; i--)
		{
			var one = array[i];
			if(one.dead) continue;
			if(one.life / one.maxLife < 0.6)
			{
				if(one.group.depth == 0) front.add(one);
				else back.add(one);
			}
		}
		if(front.count < back.count) return back[0];
		return front[0];
	};

	.doDamage = function(self, target)
	{
		if(target.dead || target.status.has(o.石化)) return 0;
		var heal = intrandom(32, 48);
		target.life += heal;
		return "0,0x80F080," + heal;
	};

	.resultMessage = o.ヒール.resultMessage;
}
