//--------------------------------------------------------------------
Name = "チャーム";
with(o[Name])
{
	.determined = function(owner)
	{
		var members = master.getTeam(this, owner.status.has(o.魅了), true);
		if(pickUpTarget(members, owner) === void)
		{
			dm("チャームをコマンドから除外");
			return false;
		}
	};

	.pickUpTarget = function(array, owner)
	{
		for(var i = 0; i < array.count; i++)
		{
			if(array[i].dead) continue;
			if(array[i].sex != "無" && array[i].sex != owner.sex) return array[i];
		}
	};

	.doDamage = function(self, target)
	{
		if(self.sex == target.sex || self.sex == "無" || target.sex == "無") return 0;
		if(random * 200 > cap(self.getSexAppealOfAppearance(),, 20)) return 0;
		if(! target.setStatus(o.魅了)) return 0;
		return o.魅了.doDamage(self, target);
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		else return o.魅了.catchMessage(target);
	};
}
//--------------------------------------------------------------------
Name = "ペトロクラウド";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(! target.setStatus(o.石化)) return 0;
		return o.石化.doDamage(self, target);
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		else return o.石化.catchMessage(target);
	};
}
//--------------------------------------------------------------------
Name = "プリズムボルト";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(random * 100 > self.intellect + 40) return false;
		var arr = [o.毒, o.沈黙, o.恐怖, o.混乱, o.衰弱, o.魅了, o.眠り, o.気絶, o.麻痺, o.石化];
		result = arr.draw();
		if(! target.setStatus(result)) return 0;
		return result.doDamage(self, target);
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		else return result.catchMessage(target);
	};
}
//--------------------------------------------------------------------
Name = "イレースマジック";
with(o[Name])
{
	.bootTrap = true;
	.getByLevelUp = false;

	.cond = function(owner)
	{
		// ゲストによる意味のない魔法の多用を避ける
		if(! owner.isGuest) return true;
		if(master.party.status.has(o.禁止)) return true;
		return false;
	};

	.determined = function(owner)
	{
		// ほぼライナス専用。通常は使わせない
		if(master.party.status.has(o.禁止)) return true;
		return false;
	};

	.doDamage = function(self, target)
	{
		if(master.inBattle)
		{
			var arr = master.getAllLivingFighters();
			for(var i = 0; i < arr.count; i++)
			{
				arr[i].removeStatus(o.祝福);
				arr[i].removeStatus(o.硬化);
				arr[i].removeStatus(o.抵抗);
				arr[i].removeStatus(o.疾風);
				arr[i].removeStatus(o.鈍重);
				arr[i].removeStatus(o.倍加);
				arr[i].removeStatus(o.付与);
				arr[i].removeStatus(o.回復);
				arr[i].removeStatus(o.反射);
			}
			master.party.removeStatus(o.障壁);
			master.party.removeStatus(o.禁止);
		}
		else
		{
			master.party.removeStatus(o.照明);
			master.party.removeStatus(o.透視);
			master.party.removeStatus(o.浮遊);
			master.noReturnMenu = true;
		}
		master.party.removeStatus(o.加護);
	};

	.resultMessage = function(target, value)
	{
		return "Magical effects on enemies and allies eliminated!";
	};
}
//--------------------------------------------------------------------
Name = "ヒール";
with(o[Name])
{
	.determined = function(owner)
	{
		if(owner instanceof "MonsterObject" || owner.status.has(o.魅了)) return false;
		var num = 0;
		for(var i = 0; i < master.party.allMembers.count; i++)
		{
			var one = master.party.allMembers[i];
			if(one.dead) continue;
			if(one.life < 10 || one.life / one.maxLife < 0.4) return true;
			if(one.life < one.maxLife) num ++;
		}
		if(num == 0) return false;
	};

	.pickUpTarget = function(array, owner)
	{
		for(var i = array.count - 1; i >= 0; i--)
		{
			if(array[i].group.depth != 0) array.erase(i);	// 助けるなら前列から
		}
		array.keysort("life");
		return array[0];
	};

	.doDamage = function(self, target)
	{
		if(target.dead || target.status.has(o.石化)) return 0;
		var heal = intrandom(32, 48);
		target.life += heal;
		return "0,0x80F080," + heal;
	};

	.resultMessage = function(target, value)
	{
		if(value === 0) return "It didn't work on " + target.displayName + "!";
		return target.displayName + "'s wounds healed!";
	};
}
