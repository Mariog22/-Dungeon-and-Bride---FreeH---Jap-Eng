	.actionMessage = o.死霊召喚.actionMessage;
	.resultMessage = o.死霊召喚.resultMessage;
}
//--------------------------------------------------------------------
Name = "偵察";
with(o[Name])
{
	.pickUpTarget = function(array, owner)
	{
		for(var i = 0; i < array.count; i++)
		{
			if(array[i].name == owner.target.name) return array[i];
		}
	};
}
//--------------------------------------------------------------------
Name = "憑依術";
with(o[Name])
{
	.cond = function(owner)
	{
		if(owner.team == master.enemy) return false;
		return checkCurrentAction(owner) === void;
	};

	.checkCurrentAction = function(owner)
	{
		var summon = master.guest.getSummonedMonster();
		if(summon === void)
		{
			return owner.displayName + " has no monster summoned to help attack!";
		}
		if(owner.smagic[summon.magicLV - 1] == 0)
		{
			return owner.displayName + "'s summoned monster didn't have enough MP to attack!";
		}
	};

	.useResource = function(res, owner)
	{
		var summon = master.guest.getSummonedMonster();
		owner.smagic[summon.magicLV - 1] --;
	};

	.actionMessage = function(self, target)
	{
		return self.displayName + "'s summoned monster attacked!";
	};
}
//--------------------------------------------------------------------
Name = "召喚の歌";
with(o[Name])
{
	.showCutIn = false;

	.cond = function(owner)
	{
		if(owner.status.has(o.沈黙)) return false;
		return master.getBestSummoningMonster() !== void;
	};

	.checkCurrentAction = function(owner)
	{
		if(owner.status.has(o.沈黙)) return owner.displayName + " sung a summoning song!\nBut couldn't be heard!";
		if(master.getBestSummoningMonster() == master.guest.getSummonedMonster())
		{
			return owner.displayName + " sung a summoning song!\nBut monster was already present!";
		}
	};

	.actionMessage = function(self, target)
	{
		return self.displayName + "sung a summoning song!";
	};
}
//--------------------------------------------------------------------
Name = "召喚モンスター攻撃";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		return o.攻撃.doDamage(master.guest.getSummonedMonster(), target);
	};
}
