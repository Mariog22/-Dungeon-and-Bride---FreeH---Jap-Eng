Name = "トーチ";
with(o[Name])
{
	.doDamage = function(self, target)
	{
		if(! master.party.setStatus(o.照明)) return 0;
		master.miniMap.update(true);
		master.noReturnMenu = true;
	};

	.resultMessage = function(target, value)
	{
		if(master.map.getFloorInfo().eraseMagic) return "Magic was cancelled!";
