//--------------------------------------------------------------------
Name = "アンロック";
with(o[Name])
{
	.getByLevelUp = false;
	.unlockTarget = "";	// 解錠の対象を記憶しておく変数

	.checkUnlock = function()
	{
		// 解錠できるかどうかのチェック

		// 罠解除画面から来た場合すでに解錠できる
		if(unlockTarget == "trapWin") return true;

		// 置いてある宝箱
		var box = master.map.getTreasureBox(master.party.curX, master.party.curY);
		if(box !== void)
		{
			if(box.trap == o.鍵付き宝箱)
			{
				unlockTarget = "key";
				return false;
			}
			unlockTarget = "box";
			return true;
		}

		// 扉
		var wall = master.map.getWallInfo();
		if(wall.type == "door")
		{
			if(wall.key == "pickable")
			{
				unlockTarget = "door";
				return true;
			}
			unlockTarget = "key";
			return false;
		}

		return false;
	};

	.doDamage = function(self, target)
	{
		if(unlockTarget == "box")
		{
			var box = master.map.getTreasureBox(master.party.curX, master.party.curY);
			master.treasureBox.createTreasureBox(box);
			master.popPrev();
			master.popPrev();
			master.setPrev(master.openTreasureBox);
			master.setPrev();
		}
		else if(unlockTarget == "door")
		{
			master.map.unlockDoor();
			master.noReturnMenu = true;
		}
	};

	.resultMessage = function(target, value)
	{
		var msg;
		if(unlockTarget == "") msg = "Nothing happened.";
		else if(unlockTarget == "key") msg = "The spell didn't open it!";
		else if(unlockTarget == "box" || unlockTarget == "trapWin") msg = "Treasure chest trap disarmed!";
		else if(unlockTarget == "door") msg = "The door was unlocked!";
		unlockTarget = "";
		return msg;
	};
}
//--------------------------------------------------------------------
Name = "コールポラリス";
with(o[Name])
{
	.orbCount = 10;

	.choice = [];
	.choice[0] = %[type: 0, order: "Restore party's HP"        , result: " HP was fully recovered!"  ];
	.choice[1] = %[type: 1, order: "Restore party's MP"    , result: " MP is restored!"  ];
	.choice[2] = %[type: 0, order: "Restore drained levels", result: " Level is back to normal!"  ];
	.choice[3] = %[type: 0, order: "Increase party's magic attack power"  , result: " Magic attack power has been increased!"];
	.choice[4] = %[type: 2, order: "Seal the magic of all enemies"              , result: " Enemy magic is sealed!"        ];
	.choice[5] = %[type: 2, order: "Send all enemies to another dimension (except bosses)", result: " Banished to another dimension!"    ];

	.checkCurrentAction = function(owner)
	{
		if(master.party.countItem(o.ポラリスの宝珠) < orbCount)
		{
			playSound("buzzer");
			return displayName + " spell failed, due to lack of jewels!";
		}
		return global.BattleCommand.checkCurrentAction(owner);
	};

	.useResource = function(res, owner)
	{
		global.BattleCommand.useResource(res, owner);	// ＭＰを消費
		for(var i = 0; i < orbCount; i++)
		{
			master.party.ejectItem(o.ポラリスの宝珠);
		}
	};

	.doDamage = function(self, target)
	{
		if(result == 0)
		{
			target.recovery();
			if(target.slot == master.party.members.count - 1) master.party.restoreFormation();
			return "0,0x80FF80,9999";
		}
		else if(result == 1)
		{
			var arr = [9, 9, 9, 9, 9, 9, 9, 9, 9];
			target.mmagic.assign(arr);
			target.pmagic.assign(arr);
			target.amagic.assign(arr);
			target.smagic.assign(arr);
			return "0,0xFF80FF,9";
		}
		else if(result == 2)
		{
			return "0,0xFFC080,RESTORE";
		}
		else if(result == 3)
		{
			return "0,0xFFC080,BOOST";
		}
		else if(result == 4)
		{
			target.setStatus(o.沈黙, true, -1);
			return "0,0x80FFFF,SILENCE";
		}
		else if(result == 5)
		{
			if(target.boss) return 0;
			target.life = 0;
			return "0,0xFFFFFF,ERASE";
		}
	};

	.resultMessage = function(target, value)
	{
		if(value == 0) return "Alas, no miracle happened!";
		else return target.name + choice[result].result;
	};
}
//--------------------------------------------------------------------
Name = "コールアウラ";
with(o[Name])
{
	.orbCount = 10;
	.cursedChara = void;	// 変更したことで呪われたキャラ

	.choice = [];
	.choice[0] = %[range: 1, order: "Change the alignment of one person."  , result: " had alignment changed!"    ];
	.choice[1] = %[range: 1, order: "Increase the stats of one person"  , result: " had stats increased!"  ];
	.choice[2] = %[range: 3, order: "Clear party's lust", result: " Everyone's lust vanished!"];
	.choice[3] = %[range: 3, order: "Clear party's fatigue"  , result: " Everyone's fatigue vanished!"  ];
	.choice[4] = %[range: 3, order: "Repair and appraise party's items"
		, result: " All items were repaired or appraised!"];
	.choice[5] = %[range: -1, order: "Cancel"];

	.checkCurrentAction = function(owner)
	{
		if(master.party.countItem(o.アウラの宝珠) < orbCount)
		{
			playSound("buzzer");
			return displayName + " spell failed, due to lack of jewels!";
		}
		return global.BattleCommand.checkCurrentAction(owner);
	};

	.useResource = function(res, owner)
	{
		if(result == -1 || result == 5) return;
		global.BattleCommand.useResource(res, owner);	// ＭＰを消費
		for(var i = 0; i < orbCount; i++)
		{
			master.party.ejectItem(o.アウラの宝珠);
		}
	};

	.doDamage = function(self, target)
	{
		if(result == 5)
		{
			master.curTarget = self;	// 「CANCEL」の表示のため
			return "0,0xFFFFFF,CANCEL";
		}

		playSound("period");
		if(result == 0)
		{
			var res, cursedNow = target.beCursed;
			if(target.alignment != o.中立)
			{
				target.alignment = o.中立;
				res = "0,0xFFFFA0,NEUTRAL";
			}
			else if(random < 0.5)
			{
				target.alignment = o.神聖;
				res = "0,0xC0C0FF,HOLY";
			}
			else
			{
				target.alignment = o.極悪;
				res = "0,0xFFA0FF,EVIL";
			}
			if(! cursedNow && target.beCursed) cursedChara = target;
			target.updateBadge();
			return res;
		}
		else if(result == 1)
		{
			// 現時点では種族制限を超えて増やせるようにしてある
			if(target._power     < 99) target._power ++;
			if(target._intellect < 99) target._intellect ++;
			if(target._piety     < 99) target._piety ++;
			if(target._vitality  < 99) target._vitality ++;
			if(target._speed     < 99) target._speed ++;
			if(target._luck      < 99) target._luck ++;
			return "0,0x80FF80,1";
		}
		else if(result == 2)
		{
			target.heat = 0;
			return "0,0xFFC0C0,-100";
		}
		else if(result == 3)
		{
			target.sleep = 0;
			return "0,0xC0FFC0,-100";
		}
		else if(result == 4)
		{
			for(var i = 0; i < master.party.members.count; i++)
			{
				master.party.members[i].maintenanceItems();
			}
			return "0,0x80FFFF,REPAIR";
		}
	};

	.resultMessage = function(target, value)
	{
		if(result == 5) return " Cancelled";
		else if(value == 0) return "Unfortunately, my wish didn't come true!";
		else return target.name + choice[result].result;
	};
}
