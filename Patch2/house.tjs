	function HouseOfChurch(master)
	{
		super.HouseObject(...);
		loadImages("house_church");
	}

	function func()
	{
		master.churchWin.open(this);
	}
}

//----------------------------------------------------------------------------------------
class HouseOfDungeon extends HouseObject
{
	// ダンジョンの入り口

	var kind = "entrance";
	var entrance;	// ダンジョン内のスタート地点

	function HouseOfDungeon(master)
	{
		super.HouseObject(...);
		loadImages("house_enter");
		requireMembers = true;
	}

	function inputData(key, data)
	{
		if(key == "entrance")
		{
			entrance = strToDic(data);
		}
		else
		{
			super.inputData(...);
		}
	}

	function func()
	{
		if(! master.isFreeMode && requireMembers && master.party.getTiredMember(50) !== void)
		{
			master.onGameBreak();
			master.resetPrevForProcessOnly();
			kag.process("script.ks", "*town_stop_going");
			return;
		}

		if(checkEvent()) return;	// イベントチェック
		master.setPrev(master.townView.goToStreet);
		master.setPrev();
		master.exitTravelMode();
		var cmds = [];
		cmds.add(%[text: "Yes", func: master.enterDungeon, param: entrance]);
		cmds.add(%[text: "No", func: master.processPrev]);
		master.yesNoWin.open(cmds, "Enter the dungeon?");
	}
}

//----------------------------------------------------------------------------------------
class HouseOfOthers extends HouseObject
{
	// その他の施設

	var kind = "others";
	var img;
	var music;
	var links = [];	// 各コマンド
	var mindRead = false;	// マインドリードの魔法を持っていたときにコマンドが出るかどうか
	var displayLinks = [];

	function HouseOfOthers(master)
	{
		super.HouseObject(...);
		loadImages("house_others");
	}

	function store()
	{
		var dic = super.store();
		dic.links = links;
		return dic;
	}

	function restore(dic)
	{
		if(dic === void) return;	// 後から追加された分をスルー
		super.restore(dic);
		links.assign(dic.links);
	}

	function inputData(key, data)
	{
		if(key == "link") links.add(data);
		else if(key == "displayLink") displayLinks.add(data);
		else super.inputData(...);
	}

	function func()
	{
		master.othersWin.open(this);
	}
}

//----------------------------------------------------------------------------------------
class ChurchWindow extends Layer
{
	// 教会画面

	var curChurch;	// 現在の教会

	function ChurchWindow(par, master)
	{
		super.Layer(par.window, par);
		this.master = master;
		name = "教会ウインドウ";
		setSize(window.scWidth, window.scHeight - master.party.cellHeight);
		hitThreshold = 256;
	}

	function open(churchObj)
	{
		// 教会画面を開く
		master.exitTravelMode();
		if(churchObj.img !== void)
		{
			loadImages(churchObj.img);
			visible = true;
		}
		curChurch = churchObj;
		openCommand();
	}

	function openCommand()
	{
		// コマンド
		// 治療で治せた方がいいのは 酩酊 恐怖 衰弱 毒 麻痺 石化
		if(curChurch.checkEvent()) return;
		master.wordsBase.close();
		master.clearWindows();
		master.exitSelectTargetMode();
		master.resetPrev();
		master.setPrev(close);
		master.setPrev(openCommand);
		var hp = master.party.hasPatient;
		var cmds = [];
		cmds.add(%[text: "Cure", func: enterCureMode
			, cond: hp(o.毒) || hp(o.酩酊) || hp(o.恐怖) || hp(o.衰弱) || hp(o.麻痺) || hp(o.石化)]);
		cmds.add(%[text: "Raise", func: enterRaiseMode
			, cond: hp(o.死亡) || hp(o.灰)]);
		if(! curChurch.cruising)
		{
			cmds.add(%[text: "Donate (" + curChurch.price + "G)", func: enterDonateMode]);
			if(! master.isFreeMode && master.wife !== void && ! master.wife.married
				 && ! o.ブレイブタウン.events.has(4) && ! o.エミール平原.events.has(9))
			{
				cmds.add(%[text: "Wedding", func: wedding]);
			}
		}
		cmds.add(%[text: "Back", func: close]);
		master.cmdWin.open(cmds, "What will you do?");
	}

	function close()
	{
		// 終了
		visible = false;
		master.view.goToStreet(curChurch);
	}

	function enterDonateMode()
	{
		// 寄付する人を選ぶ
		master.clearWindows();
		master.setPrev();
		if(master.party.luck > 0)
		{
			playSound("buzzer");
			master.notice.open(master.processPrev);
			master.notice.write("<y>You can only donate once a day");
			return;
		}
		for(var i = 0; i < master.party.members.count; i++)
		{
			var one = master.party.members[i];
			if(! one.active) one.selectable = false;
		}
		master.enterSelectTargetMode(donate);
		master.instruct("Who will donate?");
	}

	function donate(obj)
	{
		// 寄付をする
		master.party.donate(curChurch);	// パーティーとしての寄付
		obj.donate(curChurch);	// 個人としての寄付
		master.clearWindows();
		playSound("coin", 1);
		master.notice.open(openCommand);
		master.notice.write("<p>" + obj.displayName + "<w> donated <y>" + curChurch.price + "G<w>");
	}

	function enterCureMode()
	{
		// 治療する人を選ぶ
		var hp = master.party.hasPatient;
		if(! hp(o.毒) && ! hp(o.酩酊) && ! hp(o.恐怖) && ! hp(o.衰弱) && ! hp(o.麻痺) && ! hp(o.石化))
		{
			openCommand();
			return;
		}
		master.clearWindows();
		master.setPrev();
		for(var i = 0; i < master.party.allMembers.count; i++)
		{
			var one = master.party.allMembers[i];
			var sh = one.status.has;
			if(sh(o.毒) || sh(o.酩酊) || sh(o.恐怖) || sh(o.衰弱) || sh(o.麻痺) || sh(o.石化))
			{
				one.speak("%9d".sprintf(one.getCurePrice(curChurch.alignment)) + " G");
			}
			else one.selectable = false;
		}
		master.enterSelectTargetMode(cureMember,, true);
		master.instruct("Who will you treat?", 420);
	}

	function cureMember(obj)
	{
		// 治療する
		master.wordsBase.close();
		master.clearWindows();
		master.exitSelectTargetMode();
		master.notice.open(enterCureMode);
		var price = obj.getCurePrice(curChurch.alignment);
		if(price > master.party.gold)
		{
			playSound("buzzer", 1);
			master.notice.write("<y>Not enough money");
			return;
		}
		master.party.gold -= price;
		obj.clearStatus();
		obj.revive();
		playSound("coin", 1);
		master.notice.write("<y>" + obj.displayName + "<w> was treated");
	}

	function enterRaiseMode()
	{
		// 蘇生する人を選ぶ
		if(! master.party.hasPatient(o.死亡) && ! master.party.hasPatient(o.灰))
		{
			openCommand();
			return;
		}
		master.clearWindows();
		master.setPrev();
		for(var i = 0; i < master.party.allMembers.count; i++)
		{
			var one = master.party.allMembers[i];
			if(! one.dead) one.selectable = false;
			else one.speak("%9d".sprintf(one.getCurePrice()) + " G");
		}
		master.enterSelectTargetMode(tryRaiseMember,, true);
		master.instruct("Revive who?", 420);
	}

	function tryRaiseMember(obj)
	{
		// 蘇生を試みる
		master.wordsBase.close();
		master.clearWindows();
		master.exitSelectTargetMode();
		var price = obj.getCurePrice();
		if(price > master.party.gold)
		{
			playSound("buzzer", 1);
			master.notice.open(enterRaiseMode);
			master.notice.write("<y>Not enough money");
			return;
		}
		master.party.gold -= price;
		master.curChara = obj;
		kag.process("script.ks", "*raise_start");
	}

	function wedding()
	{
		// フィアンセと結婚式を挙げる

		var rings = [];	// 結婚指輪
		master.clearWindows();

		// 呪いチェック
		var playerRing = master.playerChara.equip.finger;
		var fianceeRing = master.wife.equip.finger;
		if((playerRing !== void && playerRing.cursed) || (fianceeRing !== void && fianceeRing.cursed))
		{
			playSound("buzzer");
			master.notice.open(openCommand);
			master.notice.write(
				"<y>Cursed items must be removed to wear the wedding ring.");
			return;
		}

		// 指輪をリストアップ
		for(var i = 0; i < master.items.count; i++)
		{
			if(master.items[i].part == "finger") rings.add(master.items[i]);
		}

		// 指輪がそろっていれば結婚式に
		for(var i = 0; i < rings.count; i++)
		{
			if(master.party.countItem(rings[i]) >= 2)
			{
				master.onGameBreak(true);
				kag.process("script.ks", "*start_wedding");
				return;
			}
		}
		playSound("buzzer");
		master.notice.open(openCommand);
		master.notice.write("<y>I don't have a wedding ring<r>Please prepare two of the same wedding ring.");
	}
}

//----------------------------------------------------------------------------------------
class OthersHouseWindow extends Layer
{
	// その他の町の施設画面
	// 選択肢などが出る

	var curHouse;	// 現在扱われている施設

	function OthersHouseWindow(par, master)
	{
		super.Layer(par.window, par);
		this.master = master;
		setSize(1024, 560);
		hitThreshold = 256;
	}

	function store()
	{
		var dic = %[];
		if(curHouse !== void) dic.curHouseName = curHouse.name;
		dic.visible = visible;
		return dic;
	}

	function restore(dic)
	{
		if(dic.curHouseName !== void)
		{
			curHouse = o[dic.curHouseName];
			if(curHouse.img !== void) loadImages(curHouse.img);
		}
		visible = dic.visible;
	}

	function open(dic)
	{
		// その他の施設画面を開く
		master.exitTravelMode();
		curHouse = dic;
		if(curHouse.music !== void) playMusic(curHouse.music);
		if(curHouse.img !== void)
		{
			loadImages(curHouse.img);
			visible = true;
		}
		openCommand();	// 選択肢表示
	}

	function close()
	{
		// 終了
		visible = false;
		master.view.goToStreet(curHouse);
		curHouse = void;
	}

	function openCommand()
	{
		// コマンド表示
		if(curHouse.checkEvent()) return;	// イベントチェック
		master.clearWindows();
		master.exitSelectTargetMode();
		master.resetPrev();
		master.setPrev(close);
		master.setPrev(openCommand);
		var cmds = [];
		for(var i = 0; i < curHouse.links.count; i++)
		{
			var label = curHouse.links[i];
			var displayLabel = (curHouse.displayLinks.length > i)? curHouse.displayLinks[i] : master.getTranslation(label);
			cmds.add(%[text: displayLabel, func: startEvent, param: label]);
		}
		if(curHouse.mindRead)
		{
			cmds.add(%[text: o.マインドリード.displayName, func: askSpellMindRead, color: 0xFFFFC0
				, cond: master.party.isUsableMagic(o.マインドリード) || master.party.hasItem(o.マインドリードの巻物)]);
		}
		cmds.add(%[text: "Back", func: close]);
		master.cmdWin.open(cmds, curHouse.displayName);
	}

	function startEvent(label)
	{
		// 押したボタンが指定するラベルに飛ぶ
		master.cmdWin.close();
		master.onGameBreak();
		kag.process("street.ks", "*others_" + curHouse.name + "_" + label);
	}

	function askSpellMindRead(func)
	{
		// マインドリードを実行するメンバーを選ぶ
		BarWindow.askSpellMindRead(func);
	}

	function spellMindRead(charaObj)
	{
		// マインドリードを実行
		BarWindow.spellMindRead(charaObj);
	}

	function startMindReadEvent()
	{
		// マインドリードを実行したときのラベルに飛ぶ
		startEvent("マインドリード");
	}
}

//----------------------------------------------------------------------------------------
