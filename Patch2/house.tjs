// house.tjs
// 建物オブジェクト、一部施設の画面等


//----------------------------------------------------------------------------------------
class HouseObject extends LightCommandButton
{
	// 各施設の基底クラス
	// 光るレイヤーなどを使うために LightCommandButton を継承しているが
	// フォーカスを得ないことを前提とした仕組みで作り直している

	var master;	// 管理オブジェクトの参照（サブクラス内で色々参照しているので）
	var name;	// 名前
	var displayName;	// 表示名
	var kind = "other";	// 施設の種別
	var icon = "";	// 町ビューで表示されるアイコン
	var appeared = true;	// 出現しているかどうか
	var closed = false;	// 休業中かどうか
	var inHouse = false;	// 現在入場済みかどうか
	var closureComment = "<y>Currently not available";	// 閉じている時のコメント
	var events = [];	// 入場時のイベント
	var conditions = [];	// その条件
	var peopleAround = false;	// 周囲に人がいるかどうか
	var requireMembers = false;	// 
	var bgm = "shop";	// BGM

	function HouseObject(master)
	{
		super.LightCommandButton(master.townView);
		this.master = master;
		absolute = 1;	// 指定しないとどこまでも高くなるので
		focusable = false;	// フォーカスを得ない
		visible = false;	// 最初は消しておく
	}

	function store()
	{
		var dic = %[];
		dic.name = name;	// オブジェクト再現のキーとして使うため保存
		dic.appeared = appeared;
		dic.visible = visible;
		dic.closed = closed;
		dic.events = events;
		dic.requireMembers = requireMembers;
		return dic;
	}

	function restore(dic)
	{
		appeared = dic.appeared;
		visible = dic.visible;
		closed = dic.closed;
		requireMembers = dic.requireMembers;
		events.assignStruct(dic.events);
	}

	function initialize()
	{
		// 施設を初期化する
		appeared = true;
		visible = true;
		closed = false;
		events = [];
		requireMembers = false;
	}

	function loadImages(storage)
	{
		super.loadImages(...);
		visible = false;
	}

	function clear()
	{
		visible = false;
	}

	function onMouseEnter()
	{
		if(MOUSE_HIDDEN || ! visible) return;
		parent.setFocusToSpot(this);
		global.Layer.onMouseEnter();
	}

	function onMouseLeave()
	{
		global.Layer.onMouseLeave();
	}

	function inputData(key, data)
	{
		if(key == "pos")
		{
			var arr = strToArray(data);
			setPos(arr[0], arr[1]);
		}
		else if(key == "icon")
		{
			loadImages(data);
		}
		else
		{
			this[key] = data;
		}
	}

	function onSelectAction()
	{
		parent.enabled = false;
		parent.playerWalkStop();

		// 入店時イベントチェック
		if(master.inEvent) return;	// 同時押し対策
		master.inEvent = true;
		f.saveEnabled = false;
		inHouse = false;
		if(checkEvent()) return;
		master.inEvent = false;

		// パーティー人数チェック
		if((kind != "guild" || master.waitingRoom == this) && master.party.members.count == 0)
		{
			master.notice.open(master.enterTravelMode);
			master.notice.write("<y>You can't enter without forming a party.");
			playSound("buzzer");
			return;
		}

		if(! master.isFreeMode && requireMembers && master.party.members.count < 4)
		{
			playSound("buzzer");
			master.notice.open(master.enterTravelMode);
			master.notice.write("<y>In story mode, you must have at least 4 people to enter.");
			return;
		}

		// 閉店中
		if(closed)
		{
			master.notice.open(master.enterTravelMode);
			master.notice.write(closureComment);
			playSound("buzzer");
			return;
		}

		// 施設により、公衆の場を避けようとするメンバーがいたら入れない
		var charaObj = master.party.getMemberHipNaked();
		if(peopleAround && charaObj !== void)
		{
			playSound("buzzer");
			master.onGameBreak();
			master.curChara = charaObj;
			kag.process("speech.ks", "*avoid_" + charaObj.keyName);
			return;
		}

		// 入店
		inHouse = true;
		func();
	}

	function func()
	{
		// オーバーライド
	}

	function checkEvent(checkOnly = false)
	{
		// イベント発生チェック
		// street.ks の ;[exp] をチェックし真ならば該当イベントシナリオに飛ぶ
		// ※町と施設のイベントは後から追加した方を優先する
		for(var i = events.count - 1; i >= 0; i--)
		{
			var num = events[i];
			if(! (conditions[num] !)) continue;
			if(checkOnly) return true;
			master.onGameBreak(true);
			kag.process("street.ks", "*event_" + name + "_" + num);
			dm("イベント発生   " + name + "  No. " + num);
			master.curEventObj = this;
			master.curEventNum = num;
			return true;
		}
		return false;
	}
}

//----------------------------------------------------------------------------------------
class HouseOfEvent extends HouseObject
{
	// イベントボタン

	var kind = "event";
	var label;
	var hide = false;	// ボタンを一時的に隠すかどうか
	var eventRef;	// イベント情報への参照

	function HouseOfEvent(master)
	{
		super.HouseObject(...);
		setSize(60, 60);
		face = dfOpaque;
	}

	function store()
	{
		var dic = super.store();
		dic.label = label;
		dic.hide = hide;
		return dic;
	}

	function restore(dic)
	{
		super.restore(dic);
		label = dic.label;
		hide = dic.hide;
	}

	function set(dic)
	{
		// イベントボタンを設置する
		eventRef = dic;
		loadImages("house_" + dic.img);
		setPos(dic.x, dic.y);
		label = dic.label;
		name = dic.name;
		// This used to be taken from save file, so wasn't changeable without starting a new file.
		// Continue putting it through this method, just in case.
		displayName = master.getTranslation(name);
		visible = true;
	}

	function func()
	{
		// イベント開始
		master.onGameBreak();
		kag.process("street.ks", "*map_" + master.townView.curTown.name + "_" + eventRef.label);
	}
}

//----------------------------------------------------------------------------------------
class HouseOfGuild extends HouseObject
{
	// ギルド

	var kind = "guild";
	var maxMembers = 12;
	var members = [];
	var isWaitingRoom = false;	// 待合所かどうか（キャラの追加はできない）

	function HouseOfGuild(master)
	{
		super.HouseObject(...);
		loadImages("house_guild");
	}

	function store()
	{
		var dic = super.store();
		dic.membersID = [];
		for(var i = 0; i < members.count; i++)
		{
			dic.membersID[i] = master.chara.find(members[i]);
		}
		return dic;
	}

	function restore(dic)
	{
		if(dic === void) return;	// 後から追加された分をスルー
		super.restore(dic);
		members = [];
		for(var i = 0; i < dic.membersID.count; i++)
		{
			entry(master.chara[dic.membersID[i]]);
		}
	}

	function inputData(key, data)
	{
		if(key == "members")
		{
			var obj, arr = data.split(",");
			for(var i = 0; i < master.chara.count; i++)
			{
				obj = master.chara[i];
				if(obj === void) continue;
				if(arr.find(obj.name) != -1) entry(obj);
			}
		}
		else
		{
			super.inputData(...);
			if(key == "isWaitingRoom" && + data) master.waitingRoom = this;
		}
	}

	function entry(obj, id = members.count)
	{
		// ギルド画面以外から加入させるときはこれを呼ぶ
		members.insert(id, obj);
		obj.activate();
		obj.transformToGuildType();
	}

	function removeMember(obj)
	{
		// キャラを外す
		members.remove(obj);
	}

	function func()
	{
		master.guildWin.open(this);
	}
}

//----------------------------------------------------------------------------------------
class HouseOfBar extends HouseObject
{
	// 酒場

	var kind = "bar";
	var img = "";
	var quests = [];	// クエスト
	var foods = [];	// メニュー
	var defQuests = [];	// 初期化用
	var curTalk = 0;
	var curMind = 0;

	function HouseOfBar(master)
	{
		super.HouseObject(...);
		loadImages("house_bar");
	}

	function store()
	{
		var dic = super.store();
		dic.curTalk = curTalk;
		dic.curMind = curMind;
		dic.questNames = [];
		for(var i = 0; i < quests.count; i++) dic.questNames[i] = quests[i].name;
		return dic;
	}

	function restore(dic)
	{
		if(dic === void) return;	// 後から追加された分をスルー
		super.restore(dic);
		curTalk = dic.curTalk;
		curMind = dic.curMind;
		quests = [];
		for(var i = 0; i < dic.questNames.count; i++)
		{
			if(o[dic.questNames[i]] === void) continue;
			quests.add(o[dic.questNames[i]]);
		}
	}

	function initialize()
	{
		super.initialize();
		quests.assign(defQuests);
	}

	function inputData(key, data)
	{
		if(key == "quest")
		{
			quests.add(o[data]);
			defQuests.add(o[data]);
		}
		else if(key == "foods")
		{
			this[key] = master.getObjArrayByText(data);
		}
		else super.inputData(...);
	}

	function func()
	{
		master.barWin.open(this);
	}

	function tryGetSpaceOfQuests()
	{
		// クエスト枠の空きの確保を試みる
		if(quests.count < 5) return;
		for(var i = 0; i < quests.count; i++)
		{
			if(! quests[i].completed) continue;
			if(master.date < quests[i].end + 5) continue;	// 終わって間もない
			quests.remove(quests[i]);
			if(quests.count < 5) return;
			i--;
		}
	}

	function hasSpaceOfQuests()
	{
		// クエストで枠に空きがあるかどうかを返す
		return quests.count < 5;
	}
}

//----------------------------------------------------------------------------------------
class HouseOfInn extends HouseObject
{
	// 宿屋

	var kind = "hotel";
	var img = "";
	var innType = "normal";
	var rooms = [];
	var eventBtns = [];
	var exitBtnPos = %[];

	function HouseOfInn(master)
	{
		super.HouseObject(...);
		loadImages("house_inn");
	}

	function store()
	{
		var dic = super.store();
		dic.eventBtns = eventBtns;
		dic.lastMembers = [];
		for(var i = 0; i < rooms.count; i++)
		{
			dic.lastMembers[i] = rooms[i].lastMembers;
		}
		return dic;
	}

	function restore(dic)
	{
		if(dic === void) return;	// 後から追加された分をスルー
		super.restore(dic);
		eventBtns.assignStruct(dic.eventBtns);
		for(var i = 0; i < dic.lastMembers.count; i++)
		{
			rooms[i].lastMembers.assign(dic.lastMembers[i]);
		}
	}

	function inputData(key, data)
	{
		if(key == "rounge" || key == "guestRoom" || key == "stable")
		{
			var dic = strToDic(data);
			dic.type = key;
			rooms.add(dic);
			dic.lastMembers = [];	// 前回この部屋に宿泊したキャラの情報
		}
		else if(key == "exitBtn")
		{
			exitBtnPos = strToDic(data);
		}
		else
		{
			super.inputData(...);
		}
	}

	function addEventButton(elm)
	{
		// イベントボタンを追加する
		// mp はすぐ消えるので完全コピーすること
		for(var i = 0; i < eventBtns.count; i++)
		{
			// 重複チェック
			if(eventBtns[i].label == elm.label) return;
		}
		var dic = %[];
		(Dictionary.assign incontextof dic)(elm);
		if(dic.name === void) dic.name = dic.label;
		dic.map = name;
		eventBtns.add(dic);
		return dic;
	}

	function deleteEventButton(elm)
	{
		// イベントボタンを削除する
		for(var i = 0; i < eventBtns.count; i++)
		{
			if(eventBtns[i].label != elm.label) continue;
			eventBtns.erase(i);
			return;
		}
	}

	function func()
	{
		master.enterHotel(this);
	}
}

//----------------------------------------------------------------------------------------
class HouseOfShop extends HouseObject
{
	// 店

	var kind = "shop";
	var img = "";	// 店主の画像
	var shopItem = [];	// 通常商品
	var specialItem = [];	// 限定商品
	var selection = [];	// 通常商品の品揃え。再入荷のために記憶しておく
	var spSelection = [];	// 限定商品の品揃え。初期化のために記憶しておく
	var itemSeg = [];	// 通常商品の並び   [ 列, 行, 下辺の高さ ]
	var spItemSeg = [3, 1, 200];	// 限定商品の並び
	var keepItem = false;	// これが true の店は解呪でアイテムを消滅させない
	var noService = false;	// 売買以外のサービスが制限されているかどうか
	var welcome = "";	// 以下各種コメント
	var thanks = "";
	var paid = "";
	var repaired = "";
	var uncursed = "";

	function HouseOfShop(master)
	{
		super.HouseObject(...);
	}

	function store()
	{
		var dic = super.store();
		dic.shopItemNames = [];
		for(var i = 0; i < shopItem.count; i++)
		{
			if(shopItem[i] !== void) dic.shopItemNames[i] = shopItem[i].name;
		}
		dic.specialItemNames = [];
		for(var i = 0; i < specialItem.count; i++)
		{
			if(specialItem[i] !== void) dic.specialItemNames[i] = specialItem[i].name;
		}
		dic.selectionNames = [];
		for(var i = 0; i < selection.count; i++)
		{
			if(selection[i] !== void) dic.selectionNames[i] = selection[i].name;
		}
		return dic;
	}

	function restore(dic)
	{
		if(dic === void) return;	// 後から追加された分をスルー
		super.restore(dic);
//		return;	// ★品揃え更新用
		shopItem = [];
		for(var i = 0; i < dic.shopItemNames.count; i++)
		{
			if(dic.shopItemNames[i] !== void) shopItem[i] = o[dic.shopItemNames[i]];
		}
		specialItem = [];
		for(var i = 0; i < dic.specialItemNames.count; i++)
		{
			if(dic.specialItemNames[i] !== void) specialItem[i] = o[dic.specialItemNames[i]];
		}
		selection = [];
		for(var i = 0; i < dic.selectionNames.count; i++)
		{
			if(dic.selectionNames[i] !== void) selection[i] = o[dic.selectionNames[i]];
		}
	}

	function initialize()
	{
		super.initialize();
		shopItem.assign(selection);
		specialItem.assign(spSelection);
	}

	function inputData(key, data)
	{
		if(key == "shopItem")
		{
			shopItem = master.getObjArrayByText(data);
			selection.assign(shopItem);
		}
		else if(key == "specialItem")
		{
			specialItem = master.getObjArrayByText(data);
			spSelection.assign(specialItem);
		}
		else if(key == "itemSeg" || key == "spItemSeg")
		{
			this[key] = strToArray(data);
		}
		else
		{
			super.inputData(...);
		}
	}

	function func()
	{
		master.itemWin.openShop(this);
	}

	function restockItems()
	{
		// 在庫復活
		shopItem.assign(selection);
	}
}

//----------------------------------------------------------------------------------------
class HouseOfChurch extends HouseObject
{
	// 教会

	var kind = "church";
