o.マリア.equipLife = G_WHOLE;
game.guest.removeMember(o.マリア);
o.ブルー・ファミリア.slaves.remove(o.リーゼル);
o.リーゼル.recovery();
o.かもめ亭.events.push2(2);
game.view.close();
game.party.clearStatusOnDungeonExit();
game.openTownView(o.サファイアシティ);
