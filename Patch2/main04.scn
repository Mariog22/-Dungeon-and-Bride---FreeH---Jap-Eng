@wait time=500
[texton w=0]
[if exp='game.party.members.has(o.リーゼル)']
	[リーゼル v=vl041 f=05]「What a mess...」[k]
	[テオ f=02]「Yeah, but we have to do it. We can't leave that demon alone.」[k]
[endif]
[テオ f=05]「...I know I'm going to put you all through a lot of trouble, but please help me. Let's fight the demon Murmur together!」[k]
[if exp='HUM'][リム v=vh006 f=03]「Of course!」[k][endif]
[if exp='ELF'][クレア v=ve007 f=16]「It's just the way things are. I'll cooperate.」[k][endif]
[if exp='DWA'][フレデリカ v=vd006 f=01]「Yes, I'll help in any way I can.」[k][endif]
[if exp='GNO'][ミューズ f=05]「... ∗nod∗」[k][endif]
[if exp='SYL'][マルエット v=vs008 f=16]「I don't have a choice. I'll help you, too.」[k][endif]
[テオ f=02]「Thank you all! Well, it's time to head back to town.」[k]
