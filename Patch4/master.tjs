				if(! o.かもめ亭.quests.has(o.精霊の力を宿す石) && ! o.精霊の力を宿す石.completed)
				{
					o.かもめ亭.quests.unshift(o.精霊の力を宿す石);
				}
			}
		}
		//-----------------------------------------------------------------------------------
		if(+ver < 11.29)
		{
			if(! isFreeMode && wife !== void && protectHeroines)
			{
				playerChara.married = wife.married = false;
			}

			if(isFreeMode && o.オークの拠点を制圧せよ.completed)
			{
				f.policeChiefIsOut = false;
			}

			if(isFreeMode && o.教団を壊滅させろ.flag == 2 && ! game.guest.members.has(o.マリア))
			{
				o.ブルーのアジト１Ｆ.events.push2(9);
				o.ブルーのアジト１Ｆ.changed.unshift([%["type"=> "floor", "img"=> "wood", "pimg"=> "human"], 5, 1, "f"]);
			}
		}
		//-----------------------------------------------------------------------------------
		if(+ver < 11.30)
		{
			if(isFreeMode && ! o.ブルーのアジト１Ｆ.events.has(7) && ! game.guest.members.has(o.ミレディ))
			{
				o.ブルーのアジト１Ｆ.events.push2(7);
				o.ブルーのアジト１Ｆ.changed.unshift([%["type"=> "floor", "img"=> "wood", "pimg"=> "human"], 8, 1, "f"]);
			}

			if(map != o.常闇の城２Ｆ && map != o.試練の迷宮Ｂ３) f.saveIsForbidden = false;

			for(var i = 0; i < chara.count; i++)
			{
				chara[i].deleteDuplicateSkills();
			}

			for(var i = 0; i < helper.count; i++)
			{
				helper[i].deleteDuplicateSkills();
			}

			var num = getNumContractedHelpers(false);
			if(num > sf.numContractedHirings) sf.numContractedHirings = num;

			if(o.かもめ亭.quests.count >= 6) o.かもめ亭.hasSpaceOfQuests();
		}
		//-----------------------------------------------------------------------------------
		if(+ver < 11.31)
		{
			if(! isFreeMode && guest.members.has(o.マリア) && o.牢獄への潜入作戦.completed)
			{
				guest.removeMember(o.マリア);
				restoreMembers();
			}
		}
		//-----------------------------------------------------------------------------------
		if(+ver < 11.32)
		{
			if(! isFreeMode && party.status.has(o.禁止))
			{
				bevents.remove(8);
				bevents.remove(9);
				party.status.remove(o.禁止);
				inDuelBattle = false;
				enemy.reservedMonsters = [];
				party.updateStatus();
			}
		}
		//-----------------------------------------------------------------------------------
		if(+ver < 11.33)
		{
			if(! isFreeMode && map == o.ブレイブタウン && o.エミール平原.events.has(9)) party.recovery();
		}
		//-----------------------------------------------------------------------------------
		if(+ver < 11.34)
		{
			if(! isFreeMode && game.wife !== void)
			{
				o.リーゼル.noChangeOfJob = false;
				o.リーゼル.pregnant = NO_PREGNANCY;
				o.リーゼル.semiRegular = true;
			}

			o.ラドミラの塔８Ｆ.events.push2(4);
		}
		//-----------------------------------------------------------------------------------
		if(+ver < 11.37)
		{
			if(isFreeMode)
			{
				o.ダストウェルの町.events.remove(0);
				o.ダストウェルの町.events.remove(1);
				o.簡易宿泊所.events.remove(0);
			}

			if(isFreeMode && o.牢獄への潜入作戦.completed)
			{
				o.ブルーのアジト１Ｆ.events.push2(9);
				if(map == o.ブルーのアジト１Ｆ) map.changeObject(%[pimg: "human"], 5, 1, "f");
			}
		}
		//-----------------------------------------------------------------------------------
		if(+ver < 11.38)
		{
			if(o.ベトリヌスの酒場.quests.count > 5) o.ベトリヌスの酒場.hasSpaceOfQuests();
			if(o.かもめ亭.quests.count > 5) o.かもめ亭.hasSpaceOfQuests();
		}
		//-----------------------------------------------------------------------------------
		if(+ver < 11.39)
		{
			o.サファイア城.links.push2("記録の再取得");

			if(! isFreeMode && o.売春組織の実体を暴け.completed && guest.members.has(o.ブルー)
				 && ! guest.members.has(o.サンドラ) && ! waitingMembers.has(o.サンドラ))
			{
				guest.entry(o.サンドラ);
			}

			for(var i = 0; i < chara.count; i++)
			{
				var one = chara[i];
				if(one.model != o.シルフＡ) continue;
				if(one.events.has(62))
				{
					one.events.remove(62);
					one.events.push2(61);
				}
			}

			if(isFreeMode) o.ヤネクの森・霧の谷.events.remove(5);

			if(! isFreeMode && playerChara.married)
			{
				// 魔術師の指輪以外ではこの状況にならないので
				if(playerChara.equip.finger === void)
				{
					party.ejectItem(o.魔術師の指輪);
					playerChara.equip.finger = o.魔術師の指輪;
				}
				if(wife !== void && wife.equip.finger === void)
				{
					party.ejectItem(o.魔術師の指輪);
					wife.equip.finger = o.魔術師の指輪;
				}
			}
		}
		//-----------------------------------------------------------------------------------
		if(+ver < 11.42)
		{
			if(! isFreeMode && wife !== void && wife.events.has(17))
			{
				wife.events.push2(14, 15, 16);
			}
		}
		//-----------------------------------------------------------------------------------
		if(+ver < 11.43)
		{
			if(! isFreeMode && guest.members.has(o.ポラリス) && guest.members.has(o.マリア))
			{
				guest.removeMembers(o.マリア);
			}

		}
		//-----------------------------------------------------------------------------------
		if(+ver < 11.50)
		{
			if(isFreeMode || (guest.members.has(o.ライナス) || wife !== void))
			{
				o.エミール平原.events.push2(4);
			}
		}

		//-----------------------------------------------------------------------------------
		if(+ver < 11.52)
		{
			if(isFreeMode)
			{
				o.大洞窟Ｂ46.events.push2(20);
				if(o.盗賊メンバー派遣の依頼　.completed) o.ブルーのアジト１Ｆ.events.push2(11);

				for(var i = 0; i < chara.count; i++)
				{
					var one = chara[i];
					if(one.model == o.人間Ａ) one.events.push2(20, 40, 60);
					if(one.model == o.エルフＡ) one.events.push2(21, 40, 60);
					if(one.model == o.ドワーフＡ) one.events.push2(20, 40, 60);
					if(one.model == o.ノームＡ) one.events.push2(23, 40, 60);
					if(one.model == o.シルフＡ) one.events.push2(20, 40, 60);
				}

				if(o.マックス isvalid && o.マックス !== void)
				{
					o.マックス.desire = 90;
					o.マックス.technic = 25;
					o.マックス.penis = 20;
					o.マックス.sexActs = [
						  "ディープキス", "乳揉み", "正常位", "乳首吸い", "手マン", "バック", "クリ責め", "フェラチオ"
						, "背面座位", "対面座位", "手こき", "騎乗位", "６９", "立ちバック", "パイズリ", "足こき"
					];
					lovers.push2(o.マックス);
				}

				o.ミレディ.events.push2(3, 6);
				o.サンドラ.events.push2(2, 4, 5);
			}
		}

		//-----------------------------------------------------------------------------------
		// 修正終わり
	}
}
//========================================================================================
