; 各種クエストシナリオ＆婚約・悪魔２度目の退治まで




;■ラブホ売春組織壊滅クエスト

; ラブホで売春組織が暗躍している
; 主人公たちはラブホに一般のカップルのふりをして潜入し事件を解決する

;◇イベント01・ホテルに宿泊
*hotel_1

; ☆フリーモード
@jump storage="free02.scn" target=*hotel_1 cond='game.isFreeMode'

; ホテルの前
@saveon
@bg f=0037
@w05
[texton w=1]
[テオ f=06]「Here...」[k]
We arrived in front of Hotel Queen. Is prostitution taking place here?[k]
@fg c=サンドラ f=01
[サンドラ v=vn043 f=01]「Hey, Captain. I have a suggestion.」[k]
[テオ f=05]「What is it, Sandra?」[k]
[サンドラ v=vn044 f=01]「Actually, I used to work at this hotel.」[k]
[テオ f=05]「Really?!」[k]
[サンドラ v=vn045 f=02]「Yes. So I know the layout of this hotel well.」[k]
[サンドラ v=vn046 f=01]「I'll go in first and investigate things. Then we can come up with a plan. What do you think?」[k]
[テオ f=02]「Sure. Thank you, Sandra.」[k]

; 雇用キャラが同行していたら
@eval exp='game.curChara = game.guest.getHiring()'
[if exp='game.curChara !== void']
	[サンドラ v=vn047 f=01]「Well then, um... Hey, you, would you mind coming with me? I need another person to help me check out the hotel.」[k]
	With that, Sandra called out to [雇用キャラ].[k]
	[if exp='[o.スナイパー, o.マスターアーチャー, o.ミスティック, o.メイガス].has(game.curChara)']
		[雇用キャラ f=01]「Sure. That's no problem at all.」[k]
	[else]
		[雇用キャラ f=00]「Yes, if I can be of any help.」[k]
	[endif]
	@eval exp='game.guest.removeMember(game.curChara)'
	[サンドラ v=vn048 f=02]「Thank you. Well then, I'll borrow this one.」[k]
[endif]
@eval exp='game.guest.removeMember(o.サンドラ)'
[サンドラ v=vn049 f=01]「Everyone else, wait until I give you further instructions.」[k]
[テオ f=02]「Yes, Sandra.」[k]
[textoff]
@out
@w05

@bg f=0038
[texton]
A few hours later, Sandra returned.[k]
[テオ f=05]「How was it, Sandra?」[k]
@fg c=サンドラ f=06
[サンドラ v=vn050 f=06]「Hmm... I couldn't find any useful information. It looks like it's going to take a little longer.」[k]
[テオ f=06]「Okay...」[k]
[サンドラ v=vn051 f=05]「But there's no doubt that large-scale prostitution is taking place at this inn. Hey, everyone, how about staying at this hotel?」[k]
[テオ f=12]「W-what?! Are you really suggesting staying here?!」[k]
@fg c=サンドラ f=01
[サンドラ v=vn052 f=01]「By staying here for the night, we could narrow down our options, and you could look for any clues in the guest rooms. That's not too much to ask, is it?」[k]
[テオ f=10]「I-I get it...」[k]
[サンドラ v=vn053 f=01]「Then it's settled. Please make a reservation right away. Thank you.」[k]
[サンドラ v=vn054 f=01]「I'm sure you understand, but you'll have to pretend to be normal couples, and not interact with other pairs. Otherwise, people will get suspicious. I'm counting on you.」[k]
[サンドラ v=vn055 f=01]「Oh, yes, I'll give you the accommodation fee.」[k]
[textoff]
@se f=coin
@getitem gold=10000

; パーティーが６人でライナスがいなかったら
[if exp='game.party.members.count == 6 && ! game.guest.members.has(o.ライナス)']
	@eval exp='game.curChara = game.party.getMostHeartsHeroine(o.テオ, true)'
	@fg c=サンドラ f=05
	[texton]
	[サンドラ v=vn056 f=05]「Oh, wait a minute.」[k]
	[キャラ f=05]「？」[k]
	[サンドラ v=vn057 f=01]「There is one more girl than boys, so we need to make couples. You wait here.」[k]
	[キャラ f=05]「I understand.」[k]
	On Sandra's instructions, [キャラ] was put on standby.[k]
	[textoff]
	@se f=period
	@eval exp='game.removeMemberTemporary(game.curChara)'
	@notice text=&'"<y>" + game.curChara.displayName + " left the party."'
[endif]

; パーティーが５人以下 or ライナスがいない時に４人以下だったら
[if exp='game.party.members.count <= 4 + game.guest.members.has(o.ライナス)']
	@cl
	@fg c=ブルー e=通常 f=19
	[texton]
	[ブルー f=19]「Ugh... This is a hassle. I'm not going. You guys do it yourselves.」[k]
	[テオ f=06]「...」[k]
	In that sort of mood, Blue won't listen to anything anyone says. Oh well, I guess we'll just have to do it without him.[k]
	[textoff]
	@clf
	@se f=period
	@eval exp='game.removeMemberTemporary(o.ブルー)'
	@notice text="<y>Blue left the party."
[endif]

; パーティーが４人でライナスがいたら
[if exp='game.party.members.count == 4 && game.guest.members.has(o.ライナス)']
	@fg c=ライナス e=通常 f=05
	[texton]
	[ライナス f=05]「I'm not going either. Call me when you're done.」[k]
	[マックス f=05]「Damn, what a selfish guy.」[k]
	[textoff]
	@clf
	@se f=period
	@eval exp='game.removeMemberTemporary(o.ライナス)'
	@notice text="<y>Linus left the party."
[endif]

; 予約画面へ
@out
@gameon
;-----------------------------------------------------------------------------------------
[iscript]
// game.party.minimumRecovery();
game.elapse(1);	// 次の日にしておく
game.playersRoommates = [];
o.ホテル・クイーン.events.push2(1);
f.inLoveHotelQuest = true;
game.exitTravelMode();
game.innActionCount = 0;
game.openHotelView(o.ホテル・クイーン);
game.hotelView.exitButton.visible = false;
game.hotelView.sleepNowButton.visible = false;
game.hotelView.reserveRoom(, game.hotelView.getRoomFromRoomName("従業員通路"));
game.hotelView.checkEarlyEvent();
[endscript]
;-----------------------------------------------------------------------------------------
[s]
; この後、メンバーがペアを組んでホテルに潜入
; 夜の主人公と宿泊したキャラのイベントが発生
;  → 各ヒロインのホテルイベントシナリオへ（主人公と宿泊・夜）


;◇イベント02・マックスと宿泊・夜
*hotel_2
; 夜のマックスと宿泊したキャラのイベント
; マックスとすでに１回でも経験済みなら発生しない
@eval exp='game.curChara = o.マックス.getRoomMates()[0]'
@jump target=*hotel_1 cond='game.curChara === void'
@jump target=*hotel_3_skip cond='game.curChara !== void && game.curChara.sexCount.max > 0'
@wait time=1000
[texton]
At the same time, in another room...[k]
[textoff]

;  → 各ヒロインのホテルイベントシナリオへ
@jump storage="heroine01b.scn" target=*hotel_max_1 cond='game.curChara == o.リム'
@jump storage="heroine02b.scn" target=*hotel_max_1 cond='game.curChara == o.クレア'
@jump storage="heroine03b.scn" target=*hotel_max_1 cond='game.curChara == o.フレデリカ'
@jump storage="heroine04b.scn" target=*hotel_max_1 cond='game.curChara == o.ミューズ'
@jump storage="heroine05b.scn" target=*hotel_max_1 cond='game.curChara == o.マルエット'


*hotel_3_skip
@bgf f=0004
[texton]
At the same time, in another room, Max was thoroughly enjoying himself with [キャラ]...[k]
[textoff]
@out
@w05
@jump target=*hotel_3


;◇イベント03・主人公と宿泊・朝
*hotel_3
; 就寝時の演出（Ｈ記録はシナリオ上で行われる）
@addevent name=テオ num=0
@addevent name=テオ num=2
@addevent name=マックス num=0
@addevent name=ライナス num=0 cond='game.guest.members.has(o.ライナス)'
@addevent name=ブルー num=0 cond='game.guest.members.has(o.ブルー)'
@eval exp='game.hotelView.sleepButton.visible = false'
@gameon fade
@wait time=1000
@stopbgm
@playse buf=2 storage=goodnight
@image layer=0 storage=0000 visible=true opacity=0 cond='! game.hotelView.sleepNow'
@move layer=0 time=2000 path=,,255
@wait time=1500
@eval exp='game.instruct("Sleeping...", 630)'
@eval exp='game.hotelView.startSleepingEffect()'
@wait time=2000
@eval exp='game.instruction.close()'
@eval exp='game.hotelView.clearHotelView()'
@wait time=2000

; 翌朝の主人公と宿泊したキャラのイベント
