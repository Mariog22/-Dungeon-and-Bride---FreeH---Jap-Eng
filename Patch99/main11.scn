;-------------------------------------------------------------------------------
; 設定
[iscript]
// 全員にバスタオルを装着
for(var i = 0; i < game.party.members.count; i++)
{
	var one = game.party.members[i];
	one.storeAllItemsInOthers(game.temporaryBox,, false);
	if(one.equip.hip == o.鋼鉄の貞操帯（ブルーの所持品）)
		one.dressEquipment(o.マタニティドレス,,, true);
	else
		one.dressEquipment(o.バスタオル,,, true);
	one.makeBustups();
}
if(game.guest.members.has(o.ブルー))
{
	o.ブルー.equipLife = G_TOWELF;
	o.ブルー.makeBustups();
}
if(game.guest.members.has(o.ライナス))
{
	o.ライナス.equipLife = G_TOWELF;
	o.ライナス.makeBustups();
}
// ホテル地下へ
game.hour = "day";	// ダンジョン用の時刻に
game.guest.entry(o.サンドラ);	// サンドラ加入
game.inEvent = false;
game.townView.close();
game.loadDungeonAtBackGround(%[map:"ホテルの地下Ｂ１", x:11, y:3, way:"s"]);

[endscript]
;-------------------------------------------------------------------------------
[eventoff]

