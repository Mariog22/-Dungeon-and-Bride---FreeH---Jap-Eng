//--------------------------------------------------------------------
Name = '障壁';
o[Name] = new CharaStatus(Name, master);
with(o[Name])
{
	.sickTime = 5;
	.eraseAtEndOfBattle = true;
	.displayName = "Barrier";
	.icon = "icon_shield";

	.catchMessage = function(target)
	{
		return "A barrier protects against long-range attacks!";
	};

	.releaseMessage = function(target)
	{
		return "The barrier preventing long-range attacks has disappeared!";
	};
}
//--------------------------------------------------------------------
Name = '煙';
o[Name] = new CharaStatus(Name, master);
with(o[Name])
{
	.sickTime = 20;
	.eraseAtDungeonExit = true;
	.displayName = "Smoke";
	.icon = "icon_smoke";

	.catchMessage = function(target)
	{
		return "A cloud of white smoke billowed around the party!";
	};

	.onSetStatus = function(owner)
	{
		master.dungeonView.nextDarkZone = "smoke";
		var pt = master.party;
		master.dungeonView.bufScreen.updateView(pt.curX, pt.curY, pt.curFront, "smoke");
	};

	.onRemoveStatus = function(owner)
	{
		master.dungeonView.nextDarkZone = void;
		var pt = master.party;
		master.dungeonView.updateView(pt.curX, pt.curY, pt.curFront);
		master.miniMap.update(true);
	};
}
//--------------------------------------------------------------------
Name = '重力';
o[Name] = new CharaStatus(Name, master);
with(o[Name])
{
	.sickTime = 30;
	.eraseAtDungeonExit = true;
	.displayName = "Gravity";
	.icon = "icon_gravity";

	.catchMessage = function(target)
	{
		onRemoveStatus();
		return "Gravity intensified around the party!";
	};

	.onRemoveStatus = function(owner)
	{
		for(var i = 0; i < master.party.members.count; i++)
		{
			master.party.members[i].switchFaceState();
			master.party.members[i].updateWeightIcon();
		}
	};
}
//--------------------------------------------------------------------
Name = '禁止';
o[Name] = new CharaStatus(Name, master);
with(o[Name])
{
	.sickTime = -1;
	.eraseAtEndOfBattle = true;
	.icon = "icon_forbidden";

	.catchMessage = function(target)
	{
		return "The use of magic in this battle is forbidden!";
	};
}
