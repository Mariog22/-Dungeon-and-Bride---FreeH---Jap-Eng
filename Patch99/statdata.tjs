//--------------------------------------------------------------------
Name = '疾風';
o[Name] = new CharaStatus(Name, master);
with(o[Name])
{
	.sickTime = -1;
	.icon = "icon_speed";
	.displayName = "Gale";
	.eraseAtEndOfBattle = true;

	.affectedParam = function(key, value)
	{
		if(key == "speed") return value + 100;
		return value;
	};

	.doDamage = function(self, target)
	{
		return "0,0xC0FFFF,SPEED UP";
	};

	.onSetStatus = function(owner)
	{
		owner.removeStatus(o.鈍重);
	};

	.catchMessage = function(target)
	{
		return target.displayName + "'s speed is up!";
	};
}
//--------------------------------------------------------------------
Name = '鈍重';
o[Name] = new CharaStatus(Name, master);
with(o[Name])
{
	.sickTime = 5;
	.icon = "icon_slow";
	.displayName = "Dull";
	.eraseAtEndOfBattle = true;

	.affectedParam = function(key, value)
	{
		if(key == "defense") return value - 2;
		if(key == "speed") return value \ 2;
		return value;
	};

	.doDamage = function(self, target)
	{
		return "0,0xC0FFFF,SPEED DOWN";
	};

	.onSetStatus = function(owner)
	{
		owner.removeStatus(o.疾風);
	};

	.catchMessage = function(target)
	{
		return target.displayName + "'s speed is down!";
	};
}
//--------------------------------------------------------------------
Name = '倍加';
o[Name] = new CharaStatus(Name, master);
with(o[Name])
{
	.sickTime = -1;
	.icon = "icon_multiple";
	.displayName = "Double";
	.eraseAtEndOfBattle = true;

	.affectedParam = function(key, value)
	{
		if(key == "times") return max(value \ 2, 1);
		return value;
	};

	.doDamage = function(self, target)
	{
		return "0,0xC0FFFF,HITx2";
	};

	.catchMessage = function(target)
	{
		return target.displayName + "'s attack count doubled!";
	};
}
//--------------------------------------------------------------------
Name = '回復';
o[Name] = new CharaStatus(Name, master);
with(o[Name])
{
	.sickTime = 10;
	.icon = "icon_regenerate";
	.displayName = "Recovery";
	.eraseAtEndOfBattle = true;

	.doDamage = function(self, target)
	{
		return "0,0x80FF80,REGENERATE";
	};

	.catchMessage = function(target)
	{
		return target.displayName + " now heals automatically!";
	};

	.effectInBattle = function(owner)
	{
		var heal = intrandom(owner.maxLife \ 4, owner.maxLife \ 3);
		owner.life += heal;
		return "0,0x80F080," + heal;
	};

	.effectMessage = function(owner, value)
	{
		return owner.displayName + "'s HP restored by " + value.substr(11) + "!";
	};

	.releaseMessage = function(target)
	{
		return target.displayName + "'s automatic recovery has ended!";
	};
}
//--------------------------------------------------------------------
