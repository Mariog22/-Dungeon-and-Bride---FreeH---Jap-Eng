//--------------------------------------------------------------------

// パーティー用
//--------------------------------------------------------------------
Name = "照明";
o[Name] = new CharaStatus(Name, master);
with(o[Name])
{
	.sickTime = 150;
	.eraseAtDungeonExit = true;
	.displayName = "Illumination";
	.icon = "icon_light";

	.cond = function(owner)
	{
		if(master.map.kind == "dungeon" && master.map.getFloorInfo().eraseMagic) return false;
		return true;
	};

	.catchMessage = function(target)
	{
		return "The dungeon got brighter!";
	};

	.onSetStatus = function(owner)
	{
		master.dungeonView.setBlindScreen(false);
	};

	.onRemoveStatus = function(owner)
	{
		if(master.dungeonView.visible) playSound("erase.wav");
		master.dungeonView.setBlindScreen(true);
		master.miniMap.update(true);
	};
}
//--------------------------------------------------------------------
Name = "透視";
o[Name] = new CharaStatus(Name, master);
with(o[Name])
{
	.sickTime = 30;
	.eraseAtDungeonExit = true;
	.displayName = "Clairvoyant";
	.icon = "icon_eye";

	.cond = function(owner)
	{
		if(master.map.kind == "dungeon" && master.map.getFloorInfo().eraseMagic) return false;
		return true;
	};

	.catchMessage = function(target)
	{
		return "I saw through the wall in front of me!";
	};

	.onSetStatus = function(owner)
	{
		master.dungeonView.setClairvoyance(true);
	};

	.onRemoveStatus = function(owner)
	{
		if(master.dungeonView.visible) playSound("erase.wav");
		if(master.map.kind == "dungeon") master.dungeonView.setClairvoyance(false);
	};
}
//--------------------------------------------------------------------
Name = "浮遊";
o[Name] = new CharaStatus(Name, master);
with(o[Name])
{
	.sickTime = -1;
	.eraseAtDungeonExit = true;
	.displayName = "Floating";
	.icon = "icon_feather";
	.detail = "Floats slightly.<r>Avoids terrain damage.";

	.cond = function(owner)
	{
		if(! owner instanceof "PlayersParty") return true;
		if(master.map.kind == "dungeon" && master.map.getFloorInfo().eraseMagic) return false;
//		if(master.party.status.has(o.ボート)) return false;
		return true;
	};

	.affectedParam = function(key, value)
	{
		if(key == "speed") return value + 2;	// 少し速くなる
		return value;
	};

	.catchMessage = function(target)
	{
		return "The party was suspended in mid-air!";
	};

	.onSetStatus = function(owner)
	{
		var pt = master.party;
		master.view.updateView(pt.curX, pt.curY, pt.curFront);
	};

	.onRemoveStatus = function(owner)
	{
		if(master.dungeonView.visible) playSound("erase.wav");
		master.dungeonView.resetPos();	// 浮遊時の位置をリセット
	};
}
//--------------------------------------------------------------------
Name = "地図";
o[Name] = new CharaStatus(Name, master);
with(o[Name])
{
	.sickTime = -1;
	.eraseAtDungeonExit = true;
	.displayName = "Map";

	.cond = function(owner)
	{
		if(master.map.kind == "dungeon" && master.map.getFloorInfo().eraseMagic) return false;
		return true;
	};

	.catchMessage = function(target)
	{
		return "I can see a map of my surroundings now!";
	};

	.onSetStatus = function(owner)
	{
		master.miniMap.open(master.map);
	};

	.onRemoveStatus = function(owner)
	{
		if(master.dungeonView.visible) playSound("erase.wav");
		master.miniMap.close();
	};
}
//--------------------------------------------------------------------
Name = 'ボート';
o[Name] = new CharaStatus(Name, master);
with(o[Name])
{
	.sickTime = -1;
	.eraseAtDungeonExit = true;
	.displayName = "Boat";

	.catchMessage = function(target)
	{
		return "The party can now move over water!";
	};

	.onSetStatus = function(owner)
	{
		master.dungeonView.boatLayer.visible = true;
//		master.party.removeStatus(o.浮遊);
	};

	.onRemoveStatus = function(owner)
	{
		if(master.dungeonView.visible) playSound("erase.wav");
		master.dungeonView.boatLayer.visible = false;
	};
}
