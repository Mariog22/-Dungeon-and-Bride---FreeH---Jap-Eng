	@addevent map=ブルーのアジト１Ｆ num=9
	@eval exp='o.ブルーのアジト１Ｆ.changed.add([%["type" => "floor", "img" => "wood", "pimg" => "human"], 5, 1, "f"])'
	@eval exp='o.ブルーのアジト１Ｆ.loaded = false'
[endif]
[eventoff]


;■死者の沼  545

*pond_2
; 死者の沼・隠し通路の先
@saveon
[texton]
I can hear monsters talking nearby![k]
Looking around, I discovered a large number of monsters gathered in an open area![k]
