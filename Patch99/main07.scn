game.closeItems.remove(o.魔法の錠前);
game.closeItems.remove(o.レビテイトの巻物);
game.closeItems.remove(o.リターンの巻物);
f.safeReturnFromHeadless = false;
game.date ++;
game.townView.setPlayerSymbol(o.冒険者の宿);

[endscript]
