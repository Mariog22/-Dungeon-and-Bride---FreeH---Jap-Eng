; 設定
[iscript]
o.マルティナの酒場.quests.add(o.遺跡の財宝);
o.遺跡の財宝.accepted = true;
o.町外れの遺跡入口.visible = o.町外れの遺跡入口.appeared = true;
o.森の中の廃屋入口.events = [1];
o.自宅.events = [];
o.町外れの遺跡Ｂ１.events.push2(1, 3, 4);
o.町外れの遺跡Ｂ３.events.push2(1, 2, 3, 4);
o.町外れの遺跡入口.requireMembers = false;
game.guest.entry(o.エリック);
game.guest.entry(o.ブルー);
o.テオ.levelUpToTheLast();
o.マックス.levelUpToTheLast();
game.party.recovery();
game.date ++;	// 廃屋のイベントの翌日
game.clock = game.timeOfADay \ 4;	// 朝方
[endscript]
;-----------------------------------------------------------------------------------------

